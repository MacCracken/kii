# --- error.cyr ---

# @public — stable API surface for chitra error handling.
# error.cyr — chitra raster-decode error codes + Result helpers.
#
# ChitraErr is a 16-byte record layout-compatible with mabda's GpuErr
# so a consumer (mabda) can map a decode failure cleanly onto
# GPU_ERR_IMAGE_DECODE. Error codes are integer constants; for errors
# that carry context (a message pointer), use chitra_err_new(code, msg).
#
# ChitraErr struct layout (16 bytes):
#   +0: code    — error code constant (one of the CHITRA_* below)
#   +8: detail  — pointer to detail string (or 0)

# ================================================================
# Error code constants
# ================================================================

enum ChitraErrCode {
    CHITRA_OK              = 0;   # no error
    CHITRA_ERR_SIGNATURE  = 1;   # missing/corrupt PNG 8-byte signature
    CHITRA_ERR_TRUNCATED  = 2;   # input ends before a chunk/field completes
    CHITRA_ERR_BAD_CHUNK  = 3;   # malformed chunk (length/CRC/type/order)
    CHITRA_ERR_UNSUPPORTED = 4;  # valid PNG but a feature chitra can't decode
    CHITRA_ERR_INFLATE    = 5;   # sankoch zlib_decompress reported failure
    CHITRA_ERR_OOM        = 6;   # allocation failed / decompression-bomb cap hit
    CHITRA_ERR_CRC        = 7;   # chunk CRC-32 mismatch (corruption / tamper)
    CHITRA_ERR_INTERLACE  = 8;   # interlace != 0 (Adam7) — single-pass only (chitra 0.2)
    CHITRA_ERR_BIT_DEPTH  = 9;   # bit_depth != 8 — 1/2/4/16 are chitra 0.2 / AL.P0d scope
    CHITRA_ERR_DIMENSIONS = 10;  # width/height vs data: lying-IHDR / overflow / bomb caps
    CHITRA_ERR_FILTER     = 11;  # per-row filter byte not in {0,1,2,3,4} (spec § 9)
    CHITRA_ERR_NO_IDAT    = 12;  # structurally valid PNG with zero IDAT (no pixel data)
    # ---- JPEG (chitra 0.3.0, JFIF baseline) ----
    CHITRA_ERR_JPEG_MARKER      = 13;  # malformed/misplaced JPEG marker or bad 16-bit segment length
    CHITRA_ERR_JPEG_SOF         = 14;  # invalid SOF0 frame header (precision/components/sampling/dims)
    CHITRA_ERR_JPEG_DQT         = 15;  # malformed DQT quantization table
    CHITRA_ERR_JPEG_DHT         = 16;  # malformed DHT / Huffman-table build failure
    CHITRA_ERR_JPEG_SOS         = 17;  # malformed SOS scan header (selectors / table refs)
    CHITRA_ERR_JPEG_ENTROPY     = 18;  # corrupt entropy stream (undecodable code / bit overrun / bad RSTn)
    CHITRA_ERR_JPEG_PROGRESSIVE = 19;  # deferred: progressive DCT (SOF2) — baseline-only in 0.3.0
    CHITRA_ERR_JPEG_ARITHMETIC  = 20;  # deferred: arithmetic coding (SOF9/10/11, DAC) — Huffman-only
    CHITRA_ERR_JPEG_PRECISION   = 21;  # deferred: sample precision != 8 (12-bit) — 8-bit-only in 0.3.0
    CHITRA_ERR_JPEG_MODE        = 22;  # deferred: hierarchical/lossless/differential SOF modes
    CHITRA_ERR_JPEG_COMPONENTS  = 23;  # deferred: unsupported component count (CMYK/YCCK 4-component)
    CHITRA_ERR_OTHER      = 99;  # catch-all
}

# ================================================================
# ChitraErr struct
# ================================================================

# Create a ChitraErr with code and an optional detail string (0 = none).
fn chitra_err_new(code, detail): i64 {
    var e = alloc(16);
    store64(e, code);
    store64(e + 8, detail);
    return e;
}

# Create a ChitraErr with code only (no detail).
fn chitra_err(code): i64 {
    return chitra_err_new(code, 0);
}

# Get the error code.
fn chitra_err_code(e): i64 {
    return load64(e);
}

# Get the detail string pointer (or 0).
fn chitra_err_detail(e): i64 {
    return load64(e + 8);
}

# ================================================================
# Error name lookup — returns a cstring (never null).
# ================================================================

fn chitra_err_name(code): i64 {
    if (code == CHITRA_OK)              { return "ok"; }
    if (code == CHITRA_ERR_SIGNATURE)  { return "bad PNG signature"; }
    if (code == CHITRA_ERR_TRUNCATED)  { return "truncated input"; }
    if (code == CHITRA_ERR_BAD_CHUNK)  { return "malformed chunk"; }
    if (code == CHITRA_ERR_UNSUPPORTED) { return "unsupported feature"; }
    if (code == CHITRA_ERR_INFLATE)    { return "inflate failed"; }
    if (code == CHITRA_ERR_OOM)        { return "out of memory"; }
    if (code == CHITRA_ERR_CRC)        { return "chunk CRC mismatch"; }
    if (code == CHITRA_ERR_INTERLACE)  { return "interlace unsupported"; }
    if (code == CHITRA_ERR_BIT_DEPTH)  { return "bit depth unsupported"; }
    if (code == CHITRA_ERR_DIMENSIONS) { return "bad dimensions"; }
    if (code == CHITRA_ERR_FILTER)     { return "bad filter byte"; }
    if (code == CHITRA_ERR_NO_IDAT)    { return "no IDAT chunks"; }
    if (code == CHITRA_ERR_JPEG_MARKER)      { return "bad JPEG marker"; }
    if (code == CHITRA_ERR_JPEG_SOF)         { return "bad JPEG frame header"; }
    if (code == CHITRA_ERR_JPEG_DQT)         { return "bad JPEG quant table"; }
    if (code == CHITRA_ERR_JPEG_DHT)         { return "bad JPEG Huffman table"; }
    if (code == CHITRA_ERR_JPEG_SOS)         { return "bad JPEG scan header"; }
    if (code == CHITRA_ERR_JPEG_ENTROPY)     { return "corrupt JPEG entropy stream"; }
    if (code == CHITRA_ERR_JPEG_PROGRESSIVE) { return "progressive JPEG unsupported"; }
    if (code == CHITRA_ERR_JPEG_ARITHMETIC)  { return "arithmetic JPEG unsupported"; }
    if (code == CHITRA_ERR_JPEG_PRECISION)   { return "JPEG sample precision unsupported"; }
    if (code == CHITRA_ERR_JPEG_MODE)        { return "JPEG mode unsupported"; }
    if (code == CHITRA_ERR_JPEG_COMPONENTS)  { return "JPEG component count unsupported"; }
    if (code == CHITRA_ERR_OTHER)      { return "other error"; }
    return "unknown error";
}

# Print an error name to stderr (fd 2).
fn chitra_err_print_name(code): i64 {
    var name = chitra_err_name(code);
    syscall(1, 2, name, strlen(name));
    return 0;
}

# --- png_chunks.cyr ---

# @internal — PNG byte-buffer chunk framing + IDAT inflate (AL.P0b).
# png_chunks.cyr — turn untrusted PNG bytes into a parsed IHDR + the
# concatenated, inflated IDAT stream. Forked from kii/src/png.cyr's
# proven framing/CRC/security core, re-shaped from path-based io reads
# to a bounds-checked byte-buffer cursor over (src, len).
#
# Every read is validated against `len` BEFORE the access (untrusted
# input — a byte-buffer decoder over network/disk bytes must never read
# out of bounds). Chunk CRC-32 is validated via sankoch's crc32. The
# decompression-bomb / lying-IHDR / dimension caps are ported verbatim
# from kii (audit 2026-05-22 findings 1/2/3).
#
# The handoff to the later color pass (AL.P0d) is the ChitraPngRaw
# struct produced by chitra_png_parse_raw (see png_filter.cyr for the
# unfilter step that fills the scanline buffer).

# ================================================================
# PNG signature (W3C PNG § 5.2) — bytes 0..7 of every PNG.
#   0x89  high-bit byte (catches 7-bit-stripping gateways)
#   P N G ASCII identifier
#   \r \n CRLF (catches DOS<->Unix mangling)
#   0x1A  DOS EOF marker
#   \n    final LF (catches \r\n -> \r)
# String-literal storage: Cyrius cstrings are NUL-terminated and byte 8
# (the NUL) is never inspected — loops bound on CHITRA_PNG_MAGIC_LEN.
# ================================================================
var CHITRA_PNG_MAGIC     = "\x89PNG\r\n\x1a\n";
var CHITRA_PNG_MAGIC_LEN = 8;

# ================================================================
# Security ceilings (ported from kii — audit 2026-05-22 finding 1).
# Cap attacker-controllable IHDR fields BEFORE any allocation. PNG
# permits width/height up to 2^31-1; chitra's texture-loader use case
# stays far below the i64-overflow boundary. All caps trip
# CHITRA_ERR_DIMENSIONS / CHITRA_ERR_OOM.
# ================================================================
var CHITRA_MAX_PIXELS    = 16777216;   # 4096 x 4096
var CHITRA_MAX_RAW_BYTES = 268435456;  # 256 MB absolute single-buffer ceiling
var CHITRA_MAX_DIM       = 65535;      # per-side cap

# DEFLATE's theoretical maximum ratio is 1032:1 (RFC 1951 § 3.2.5).
# inflated/idat above 1100 is a decompression bomb (kii finding 3).
var CHITRA_MAX_INFLATE_RATIO = 1100;

# ================================================================
# ChitraPngRaw — the AL.P0b -> AL.P0d handoff record (104 bytes).
# Produced by chitra_png_parse_raw (framing + inflate + unfilter); the
# canonical-RGBA8 color pass (AL.P0d) consumes it. PLTE/tRNS spans are
# captured here as (offset-into-src, length) pairs — the bytes are NOT
# processed yet (that is the color pass's job). offset 0 with length 0
# means "chunk absent".
#
#   +0   width        (i64 — pixels)
#   +8   height       (i64 — pixels)
#   +16  bit_depth    (i64 — 1/2/4/8/16; valid combos per color_type, Table 11.1)
#   +24  color_type   (i64 — 0/2/3/4/6)
#   +32  channels     (i64 — samples per pixel: 1/3/1/2/4)
#   +40  scanlines    (ptr — owned unfiltered raw buffer, h*w*bpp bytes)
#   +48  scanlines_len(i64 — byte count of the scanline buffer)
#   +56  plte_off     (i64 — byte offset of PLTE data within src, 0 if none)
#   +64  plte_len     (i64 — PLTE data length, 0 if none)
#   +72  trns_off     (i64 — byte offset of tRNS data within src, 0 if none)
#   +80  trns_len     (i64 — tRNS data length, 0 if none)
#   +88  seen_iend    (i64 — 1 if an IEND chunk closed the stream, else 0;
#                      0 = clean IEND-less end, spec § 5.3 tolerance —
#                      surfaced so consumers can warn while still decoding)
#   +96  interlace    (i64 — 0 = none, 1 = Adam7; chitra 0.2.1)
# ================================================================
var RAW_WIDTH_OFFSET        = 0;
var RAW_HEIGHT_OFFSET       = 8;
var RAW_BIT_DEPTH_OFFSET    = 16;
var RAW_COLOR_TYPE_OFFSET   = 24;
var RAW_CHANNELS_OFFSET     = 32;
var RAW_SCANLINES_OFFSET    = 40;
var RAW_SCANLINES_LEN_OFFSET = 48;
var RAW_PLTE_OFF_OFFSET     = 56;
var RAW_PLTE_LEN_OFFSET     = 64;
var RAW_TRNS_OFF_OFFSET     = 72;
var RAW_TRNS_LEN_OFFSET     = 80;
var RAW_SEEN_IEND_OFFSET    = 88;
var RAW_INTERLACE_OFFSET    = 96;   # 0 = none, 1 = Adam7 (chitra 0.2.1)
var CHITRA_PNG_RAW_SIZE     = 104;

# ---- ChitraPngRaw accessors -------------------------------------
fn chitra_raw_width(raw): i64       { return load64(raw + RAW_WIDTH_OFFSET); }
fn chitra_raw_height(raw): i64      { return load64(raw + RAW_HEIGHT_OFFSET); }
fn chitra_raw_bit_depth(raw): i64   { return load64(raw + RAW_BIT_DEPTH_OFFSET); }
fn chitra_raw_color_type(raw): i64  { return load64(raw + RAW_COLOR_TYPE_OFFSET); }
fn chitra_raw_channels(raw): i64    { return load64(raw + RAW_CHANNELS_OFFSET); }
fn chitra_raw_scanlines(raw): i64   { return load64(raw + RAW_SCANLINES_OFFSET); }
fn chitra_raw_scanlines_len(raw): i64 { return load64(raw + RAW_SCANLINES_LEN_OFFSET); }
fn chitra_raw_plte_off(raw): i64    { return load64(raw + RAW_PLTE_OFF_OFFSET); }
fn chitra_raw_plte_len(raw): i64    { return load64(raw + RAW_PLTE_LEN_OFFSET); }
fn chitra_raw_trns_off(raw): i64    { return load64(raw + RAW_TRNS_OFF_OFFSET); }
fn chitra_raw_trns_len(raw): i64    { return load64(raw + RAW_TRNS_LEN_OFFSET); }
fn chitra_raw_seen_iend(raw): i64   { return load64(raw + RAW_SEEN_IEND_OFFSET); }
fn chitra_raw_interlace(raw): i64   { return load64(raw + RAW_INTERLACE_OFFSET); }

# Release a ChitraPngRaw. The stdlib `alloc` is a bump allocator with no
# per-block free, so this is a no-op kept for API symmetry / a future
# arena-backed allocator; documented so callers don't assume reclaim.
# Safe on a 0 ptr.
fn chitra_raw_free(raw): i64 {
    return 0;
}

# ================================================================
# Byte-buffer cursor — bounds-checked reads over (src, len).
# A 16-byte record:
#   +0  base ptr  (start of the byte buffer)
#   +8  pos       (current read offset; 0 <= pos <= len)
# `len` is carried separately by callers via _cur_remaining(cur, len)
# style? No — to keep every read self-validating we store len too. Use
# a 24-byte cursor instead:
#   +0  base, +8 pos, +16 len.
# ================================================================
var CUR_BASE_OFFSET = 0;
var CUR_POS_OFFSET  = 8;
var CUR_LEN_OFFSET  = 16;

# Init a stack cursor: caller passes a >=24-byte buffer.
fn _cur_init(cur, base, len): i64 {
    store64(cur + CUR_BASE_OFFSET, base);
    store64(cur + CUR_POS_OFFSET, 0);
    store64(cur + CUR_LEN_OFFSET, len);
    return 0;
}

fn _cur_pos(cur): i64       { return load64(cur + CUR_POS_OFFSET); }
fn _cur_len(cur): i64       { return load64(cur + CUR_LEN_OFFSET); }
fn _cur_remaining(cur): i64 {
    return load64(cur + CUR_LEN_OFFSET) - load64(cur + CUR_POS_OFFSET);
}

# True (1) iff `n` bytes can be read from the current position without
# running past len. n must be >= 0 (callers pass chunk_len which is
# masked to 31 bits, so always non-negative).
fn _cur_can_read(cur, n): i64 {
    if (n < 0) { return 0; }
    if (_cur_remaining(cur) < n) { return 0; }
    return 1;
}

# Read one u8 at the cursor and advance. Caller MUST have checked
# _cur_can_read(cur, 1) first; this asserts it returns 0 defensively if
# out of bounds (never an OOB load).
fn _cur_u8(cur): i64 {
    if (_cur_can_read(cur, 1) == 0) { return 0; }
    var p = load64(cur + CUR_BASE_OFFSET) + load64(cur + CUR_POS_OFFSET);
    var v = load8(p);
    store64(cur + CUR_POS_OFFSET, load64(cur + CUR_POS_OFFSET) + 1);
    return v;
}

# Read a big-endian u32 (PNG is big-endian throughout, spec § 7) and
# advance 4 bytes. Returns the value; caller checks _cur_can_read first.
# Masked to 32 bits so a high bit can't sign-extend into a negative i64.
fn _cur_u32_be(cur): i64 {
    if (_cur_can_read(cur, 4) == 0) { return 0; }
    var p = load64(cur + CUR_BASE_OFFSET) + load64(cur + CUR_POS_OFFSET);
    var b0 = load8(p + 0);
    var b1 = load8(p + 1);
    var b2 = load8(p + 2);
    var b3 = load8(p + 3);
    store64(cur + CUR_POS_OFFSET, load64(cur + CUR_POS_OFFSET) + 4);
    return ((b0 << 24) | (b1 << 16) | (b2 << 8) | b3) & 4294967295;
}

# Read a big-endian u16 and advance 2 bytes. JPEG segment lengths are 2-byte
# big-endian (ITU-T T.81 § B.1.1.4). Masked to 16 bits. Caller checks
# _cur_can_read(cur, 2) first; returns 0 defensively on OOB (never an OOB load).
fn _cur_u16_be(cur): i64 {
    if (_cur_can_read(cur, 2) == 0) { return 0; }
    var p = load64(cur + CUR_BASE_OFFSET) + load64(cur + CUR_POS_OFFSET);
    var b0 = load8(p + 0);
    var b1 = load8(p + 1);
    store64(cur + CUR_POS_OFFSET, load64(cur + CUR_POS_OFFSET) + 2);
    return ((b0 << 8) | b1) & 65535;
}

# Absolute pointer at the cursor's current position (for chunk-data
# scanning without copying). Caller validates the span via _cur_can_read.
fn _cur_ptr(cur): i64 {
    return load64(cur + CUR_BASE_OFFSET) + load64(cur + CUR_POS_OFFSET);
}

# Skip `n` bytes forward (no bounds clamp — caller pre-validates).
fn _cur_skip(cur, n): i64 {
    store64(cur + CUR_POS_OFFSET, load64(cur + CUR_POS_OFFSET) + n);
    return 0;
}

# ================================================================
# Signature check — pure in-memory, length-validated.
# ================================================================
fn chitra_png_check_signature(src, len): i64 {
    if (len < CHITRA_PNG_MAGIC_LEN) { return 0; }
    return memeq(src, CHITRA_PNG_MAGIC, CHITRA_PNG_MAGIC_LEN);
}

# ================================================================
# Chunk-type predicates — 4-byte case-sensitive ASCII (spec § 5.4).
# `p` points at the 4 type bytes.
# ================================================================
fn _chunk_is(p, c0, c1, c2, c3): i64 {
    if (load8(p + 0) == c0 && load8(p + 1) == c1 &&
    load8(p + 2) == c2 && load8(p + 3) == c3) { return 1; }
    return 0;
}
fn _chunk_is_ihdr(p): i64 { return _chunk_is(p, 0x49, 0x48, 0x44, 0x52); }
fn _chunk_is_idat(p): i64 { return _chunk_is(p, 0x49, 0x44, 0x41, 0x54); }
fn _chunk_is_iend(p): i64 { return _chunk_is(p, 0x49, 0x45, 0x4E, 0x44); }
fn _chunk_is_plte(p): i64 { return _chunk_is(p, 0x50, 0x4C, 0x54, 0x45); }
fn _chunk_is_trns(p): i64 { return _chunk_is(p, 0x74, 0x52, 0x4E, 0x53); }

# ================================================================
# Color-type -> channels-per-pixel (spec § 11.2.2 Table 11.1):
#   0 greyscale -> 1   2 RGB -> 3   3 palette -> 1
#   4 grey+alpha -> 2  6 RGBA -> 4
# Returns -1 for an unknown color type.
# ================================================================
fn chitra_png_color_channels(color_type): i64 {
    if (color_type == 0) { return 1; }
    if (color_type == 2) { return 3; }
    if (color_type == 3) { return 1; }
    if (color_type == 4) { return 2; }
    if (color_type == 6) { return 4; }
    return 0 - 1;
}

# ================================================================
# Depth/packing helpers (chitra 0.2.1 — sub-byte depths + Adam7).
# A scanline is `channels * bit_depth` bits per pixel, packed MSB-first,
# each row padded up to a whole byte (spec § 7.2). row_bytes is that
# padded byte count; filter_bpp is bytes-per-pixel for the unfilter
# stride, rounded UP to a minimum of 1 (spec § 9: bpp = ceil(bits/8)).
# ================================================================
fn _chitra_row_bytes_for(width, channels, depth): i64 {
    return (width * channels * depth + 7) / 8;
}
fn _chitra_filter_bpp_for(channels, depth): i64 {
    return (channels * depth + 7) / 8;
}

# Read a sub-byte sample (depth ∈ {1,2,4}) at pixel index x within a
# packed row, MSB-first. Samples never cross a byte boundary at these
# depths (1/2/4 all divide 8).
fn _chitra_get_subbyte(row, x, depth): i64 {
    var bit_index = x * depth;
    var byte_index = bit_index / 8;
    var bit_off = bit_index % 8;          # bits from the MSB of that byte
    var shift = 8 - depth - bit_off;
    var b = load8(row + byte_index);
    var mask = (1 << depth) - 1;
    return (b >> shift) & mask;
}

# Write a sub-byte sample (depth ∈ {1,2,4}) at pixel index x into a
# packed row, MSB-first, leaving the other bits of the byte intact
# (used by the Adam7 deinterlace scatter). `mask ^ 255` is the byte-wide
# complement (avoids relying on a full-width bitwise-not).
fn _chitra_set_subbyte(row, x, depth, val): i64 {
    var bit_index = x * depth;
    var byte_index = bit_index / 8;
    var bit_off = bit_index % 8;
    var shift = 8 - depth - bit_off;
    var mask = ((1 << depth) - 1) << shift;
    var b = load8(row + byte_index);
    b = (b & (mask ^ 255)) | ((val << shift) & mask);
    store8(row + byte_index, b);
    return 0;
}

# Scale a sub-byte grayscale sample to 8-bit: value * 255 / (2^depth - 1)
# — exact integer for depths 1/2/4 (×255, ×85, ×17), matching the PNG
# spec's sample-depth scaling so output equals a reference decoder's.
fn _chitra_gray_scale(depth): i64 {
    if (depth == 1) { return 255; }
    if (depth == 2) { return 85; }
    if (depth == 4) { return 17; }
    return 1;
}

# --- png_filter.cyr ---

# @internal — PNG unfilter predictors + the raw-decode driver (AL.P0b).
# png_filter.cyr — the five PNG filter-undo predictors (spec § 9) and
# chitra_png_parse_raw, the top-level byte-buffer framing driver that
# produces a ChitraPngRaw (parsed IHDR + inflated, unfiltered scanlines).
#
# Forked from kii/src/png.cyr's _png_paeth / _png_unfilter_row and
# png_decode_pixels, re-shaped onto the byte-buffer cursor in
# png_chunks.cyr. The canonical-RGBA8 color pass (AL.P0d) consumes the
# ChitraPngRaw this returns; the public chitra_png_decode (AL.P0e) wraps
# both. Everything here returns a ChitraErr ptr on any failure path —
# never an OOB access or crash on untrusted input.

# ================================================================
# Paeth predictor (spec § 9.4) — picks whichever of left (a) / above
# (b) / above-left (c) is closest to the linear estimate a+b-c. Ties
# resolve left -> up -> up-left, matching the spec ordering.
# ================================================================
fn _chitra_paeth(a, b, c): i64 {
    var p = a + b - c;
    var pa = p - a;
    if (pa < 0) { pa = 0 - pa; }
    var pb = p - b;
    if (pb < 0) { pb = 0 - pb; }
    var pc = p - c;
    if (pc < 0) { pc = 0 - pc; }
    if (pa <= pb && pa <= pc) { return a; }
    if (pb <= pc) { return b; }
    return c;
}

# ================================================================
# Undo one scanline's filter (spec § 9). `prev_row` is the previous
# RAW (post-undo) row; pass an all-zero row for row 0. `curr_in` points
# at the filtered data (after the filter-type byte). `out_row` receives
# `row_bytes` reconstructed bytes. `bpp` is bytes-per-pixel (the filter
# corresponds left at a `bpp` stride). Returns 0 on success, -1 for a
# filter type not in {0,1,2,3,4}.
# ================================================================
fn _chitra_unfilter_row(prev_row, curr_in, out_row, row_bytes, bpp, filter_type): i64 {
    var i = 0;
    if (filter_type == 0) {
        # None — passthrough.
        while (i < row_bytes) {
            store8(out_row + i, load8(curr_in + i));
            i = i + 1;
        }
        return 0;
    }
    if (filter_type == 1) {
        # Sub — out[i] = in[i] + (i<bpp ? 0 : out[i-bpp])
        while (i < row_bytes) {
            var left = 0;
            if (i >= bpp) { left = load8(out_row + i - bpp); }
            store8(out_row + i, (load8(curr_in + i) + left) & 0xFF);
            i = i + 1;
        }
        return 0;
    }
    if (filter_type == 2) {
        # Up — out[i] = in[i] + prev[i]
        while (i < row_bytes) {
            var up = load8(prev_row + i);
            store8(out_row + i, (load8(curr_in + i) + up) & 0xFF);
            i = i + 1;
        }
        return 0;
    }
    if (filter_type == 3) {
        # Average — out[i] = in[i] + floor((left + up) / 2)
        while (i < row_bytes) {
            var left = 0;
            if (i >= bpp) { left = load8(out_row + i - bpp); }
            var up = load8(prev_row + i);
            store8(out_row + i, (load8(curr_in + i) + ((left + up) / 2)) & 0xFF);
            i = i + 1;
        }
        return 0;
    }
    if (filter_type == 4) {
        # Paeth — out[i] = in[i] + paeth(left, up, up-left)
        while (i < row_bytes) {
            var left = 0;
            var up_left = 0;
            if (i >= bpp) {
                left = load8(out_row + i - bpp);
                up_left = load8(prev_row + i - bpp);
            }
            var up = load8(prev_row + i);
            store8(out_row + i, (load8(curr_in + i) + _chitra_paeth(left, up, up_left)) & 0xFF);
            i = i + 1;
        }
        return 0;
    }
    return 0 - 1;
}

# ================================================================
# Walk the inflated stream applying filter-undo per row -> raw scanline
# bytes. `inflated` holds height*(1+row_bytes) bytes; `pixels` receives
# height*row_bytes reconstructed bytes (caller-allocated, both sized by
# the validated dimension math). Returns 0 on success, -1 on a bad
# filter byte (caller maps to CHITRA_ERR_FILTER).
# ================================================================
fn _chitra_unfilter_image(inflated, pixels, zero_row, height, row_bytes, bpp): i64 {
    var prev = zero_row;
    var r = 0;
    while (r < height) {
        var row_off = r * (1 + row_bytes);
        var filter_byte = load8(inflated + row_off);
        var curr_in = inflated + row_off + 1;
        var out_row = pixels + r * row_bytes;
        var rc = _chitra_unfilter_row(prev, curr_in, out_row, row_bytes, bpp, filter_byte);
        if (rc != 0) { return 0 - 1; }
        prev = out_row;
        r = r + 1;
    }
    return 0;
}

# ================================================================
# IHDR parse helper. `cur` is positioned at the start of the IHDR chunk
# (its 4-byte length field). Validates length==13, type=="IHDR", CRC,
# and the supported-feature gates, then stores width/height/bit_depth/
# color_type/channels into `raw`. Returns a ChitraErr ptr, or 0 on OK.
# Advances the cursor past the whole IHDR chunk (len+type+data+crc).
# ================================================================
fn _chitra_parse_ihdr(cur, raw): i64 {
    # Need at least 4(len)+4(type)+13(data)+4(crc) = 25 bytes.
    if (_cur_can_read(cur, 25) == 0) { return chitra_err(CHITRA_ERR_TRUNCATED); }
    var chunk_len = _cur_u32_be(cur);
    if (chunk_len != 13) { return chitra_err(CHITRA_ERR_BAD_CHUNK); }

    # CRC covers the 4 type bytes + 13 data bytes (spec § 5.3 — length
    # is excluded). Compute over the 17 bytes at the current position
    # before consuming them.
    var crc_ptr = _cur_ptr(cur);
    var type_ptr = crc_ptr;
    if (_chunk_is_ihdr(type_ptr) == 0) { return chitra_err(CHITRA_ERR_BAD_CHUNK); }

    var computed = crc32(crc_ptr, 17);
    _cur_skip(cur, 4);                     # past type
    var data_ptr = _cur_ptr(cur);
    _cur_skip(cur, 13);                    # past 13 data bytes
    var stored = _cur_u32_be(cur);         # 4-byte CRC
    if ((computed & 4294967295) != (stored & 4294967295)) {
        return chitra_err(CHITRA_ERR_CRC);
    }

    # IHDR data layout (13 bytes):
    #   0..3  width (u32 BE)   4..7  height (u32 BE)
    #   8     bit_depth        9     color_type
    #   10    compression      11    filter      12    interlace
    var width = ((load8(data_ptr + 0) << 24) | (load8(data_ptr + 1) << 16) |
    (load8(data_ptr + 2) << 8) | load8(data_ptr + 3)) & 4294967295;
    var height = ((load8(data_ptr + 4) << 24) | (load8(data_ptr + 5) << 16) |
    (load8(data_ptr + 6) << 8) | load8(data_ptr + 7)) & 4294967295;
    var bit_depth = load8(data_ptr + 8);
    var color_type = load8(data_ptr + 9);
    var comp_method = load8(data_ptr + 10);
    var filter_method = load8(data_ptr + 11);
    var interlace = load8(data_ptr + 12);

    # ---- supported-feature gates (fail loud, never half-decode) ----
    var channels = chitra_png_color_channels(color_type);
    if (channels < 0) { return chitra_err(CHITRA_ERR_UNSUPPORTED); }
    # Compression + filter methods: spec § 11.2.2 defines ONLY method 0 for
    # each. Reject any other loud rather than mis-decoding a spoofed header.
    if (comp_method != 0) { return chitra_err(CHITRA_ERR_UNSUPPORTED); }
    if (filter_method != 0) { return chitra_err(CHITRA_ERR_UNSUPPORTED); }
    # Interlace: 0 = none, 1 = Adam7 — both supported as of chitra 0.2.1.
    if (interlace != 0 && interlace != 1) { return chitra_err(CHITRA_ERR_INTERLACE); }
    # bit-depth × color-type validity (spec § 11.2.2 Table 11.1):
    #   ct0 gray   : 1/2/4/8/16     ct2 RGB    : 8/16
    #   ct3 palette: 1/2/4/8        ct4 gray+a : 8/16     ct6 RGBA: 8/16
    var depth_ok = 0;
    if (color_type == 0) {
        if (bit_depth == 1 || bit_depth == 2 || bit_depth == 4 ||
        bit_depth == 8 || bit_depth == 16) { depth_ok = 1; }
    } else { if (color_type == 3) {
            if (bit_depth == 1 || bit_depth == 2 || bit_depth == 4 ||
            bit_depth == 8) { depth_ok = 1; }
        } else {
            if (bit_depth == 8 || bit_depth == 16) { depth_ok = 1; }
        } }
    if (depth_ok == 0) { return chitra_err(CHITRA_ERR_BIT_DEPTH); }

    # ---- dimension caps (kii audit finding 1) ----
    # width/height are attacker-controlled u32 fields. Cap before the
    # width*height*bpp multiply so a lying IHDR can't wrap i64 / demand
    # a multi-GB alloc.
    if (width <= 0 || height <= 0) { return chitra_err(CHITRA_ERR_DIMENSIONS); }
    if (width > CHITRA_MAX_DIM || height > CHITRA_MAX_DIM) {
        return chitra_err(CHITRA_ERR_DIMENSIONS);
    }
    if (width * height > CHITRA_MAX_PIXELS) {
        return chitra_err(CHITRA_ERR_DIMENSIONS);
    }

    store64(raw + RAW_WIDTH_OFFSET, width);
    store64(raw + RAW_HEIGHT_OFFSET, height);
    store64(raw + RAW_BIT_DEPTH_OFFSET, bit_depth);
    store64(raw + RAW_COLOR_TYPE_OFFSET, color_type);
    store64(raw + RAW_CHANNELS_OFFSET, channels);
    store64(raw + RAW_INTERLACE_OFFSET, interlace);
    return 0;
}

# ================================================================
# Adam7 interlace (spec § 8). Seven passes, each a reduced sub-image
# at a fixed (x_start, y_start) offset and (x_step, y_step) stride.
# ================================================================
fn _adam7_xs(p): i64 {
    if (p == 0) { return 0; }   if (p == 1) { return 4; }
    if (p == 2) { return 0; }   if (p == 3) { return 2; }
    if (p == 4) { return 0; }   if (p == 5) { return 1; }
    return 0;
}
fn _adam7_ys(p): i64 {
    if (p == 0) { return 0; }   if (p == 1) { return 0; }
    if (p == 2) { return 4; }   if (p == 3) { return 0; }
    if (p == 4) { return 2; }   if (p == 5) { return 0; }
    return 1;
}
fn _adam7_xstep(p): i64 {
    if (p == 0) { return 8; }   if (p == 1) { return 8; }
    if (p == 2) { return 4; }   if (p == 3) { return 4; }
    if (p == 4) { return 2; }   if (p == 5) { return 2; }
    return 1;
}
fn _adam7_ystep(p): i64 {
    if (p == 0) { return 8; }   if (p == 1) { return 8; }
    if (p == 2) { return 8; }   if (p == 3) { return 4; }
    if (p == 4) { return 4; }   if (p == 5) { return 2; }
    return 2;
}

# Pixels in a pass row / column for an image of (width|height): the count
# of grid points at (start, step) within the dimension. 0 if start>=dim.
fn _adam7_count(dim, start, step): i64 {
    if (dim <= start) { return 0; }
    return (dim - start + step - 1) / step;
}

# Total inflated (post-DEFLATE, pre-unfilter) byte count for an Adam7
# stream: sum over the 7 passes of pass_h * (1 filter byte + pass_row_bytes).
# Empty passes contribute nothing. Must match the deinterlace walk exactly.
fn _chitra_adam7_inflated_size(width, height, channels, depth): i64 {
    var bpp_bits = channels * depth;
    var total = 0;
    var p = 0;
    while (p < 7) {
        var pw = _adam7_count(width, _adam7_xs(p), _adam7_xstep(p));
        var ph = _adam7_count(height, _adam7_ys(p), _adam7_ystep(p));
        if (pw > 0 && ph > 0) {
            var prow = (pw * bpp_bits + 7) / 8;
            total = total + ph * (1 + prow);
        }
        p = p + 1;
    }
    return total;
}

# Deinterlace an Adam7 inflated stream into the dense, byte-padded
# `pixels` buffer (same layout the non-interlaced path produces, so the
# color pass is interlace-agnostic). Each pass is filtered independently
# (fresh zero prev-row), then its pixels are scattered to their full-image
# positions — byte-copied at depth >= 8, bit-set at sub-byte depths.
# Returns 0; on failure sets *err_out and returns -1.
fn _chitra_deinterlace(inflated, pixels, width, height, channels, depth, err_out): i64 {
    var row_bytes_full = _chitra_row_bytes_for(width, channels, depth);
    var bpp_bits = channels * depth;
    var filter_bpp = _chitra_filter_bpp_for(channels, depth);

    # Zero the dense buffer: sub-byte scatter sets individual samples, and
    # row-end padding bits must read as 0.
    var total = height * row_bytes_full;
    var z = 0;
    while (z < total) { store8(pixels + z, 0); z = z + 1; }

    # Two ping-pong pass-row buffers (reconstructed rows) + a zero prev for
    # each pass's first scanline. Sized to the full row (>= any pass row).
    var buf_a = alloc(row_bytes_full);
    var buf_b = alloc(row_bytes_full);
    var zr = alloc(row_bytes_full);
    if (buf_a == 0 || buf_b == 0 || zr == 0) {
        store64(err_out, chitra_err(CHITRA_ERR_OOM));
        return 0 - 1;
    }
    var zi = 0;
    while (zi < row_bytes_full) { store8(zr + zi, 0); zi = zi + 1; }

    var off = 0;
    var pass = 0;
    while (pass < 7) {
        var xs = _adam7_xs(pass);
        var ys = _adam7_ys(pass);
        var xstep = _adam7_xstep(pass);
        var ystep = _adam7_ystep(pass);
        var pass_w = _adam7_count(width, xs, xstep);
        var pass_h = _adam7_count(height, ys, ystep);
        if (pass_w > 0 && pass_h > 0) {
            var prow_bytes = (pass_w * bpp_bits + 7) / 8;
            var prev = zr;
            var cur = buf_a;
            var py = 0;
            while (py < pass_h) {
                var fb = load8(inflated + off);
                var cin = inflated + off + 1;
                off = off + 1 + prow_bytes;
                var rc = _chitra_unfilter_row(prev, cin, cur, prow_bytes, filter_bpp, fb);
                if (rc != 0) {
                    store64(err_out, chitra_err(CHITRA_ERR_FILTER));
                    return 0 - 1;
                }
                var full_y = ys + py * ystep;
                if (bpp_bits >= 8) {
                    var bytes_pp = bpp_bits / 8;
                    var px = 0;
                    while (px < pass_w) {
                        var full_x = xs + px * xstep;
                        var dstp = pixels + full_y * row_bytes_full + full_x * bytes_pp;
                        var srcp = cur + px * bytes_pp;
                        var k = 0;
                        while (k < bytes_pp) { store8(dstp + k, load8(srcp + k)); k = k + 1; }
                        px = px + 1;
                    }
                } else {
                    var dstrow = pixels + full_y * row_bytes_full;
                    var px2 = 0;
                    while (px2 < pass_w) {
                        var full_x2 = xs + px2 * xstep;
                        var val = _chitra_get_subbyte(cur, px2, depth);
                        _chitra_set_subbyte(dstrow, full_x2, depth, val);
                        px2 = px2 + 1;
                    }
                }
                prev = cur;
                if (cur == buf_a) { cur = buf_b; } else { cur = buf_a; }
                py = py + 1;
            }
        }
        pass = pass + 1;
    }
    return 0;
}

# ================================================================
# chitra_png_parse_raw — the AL.P0b top-level. Turns (src, len) PNG
# bytes into a ChitraPngRaw (parsed IHDR + inflated, unfiltered raw
# scanlines + captured PLTE/tRNS spans). Returns the ChitraPngRaw ptr
# on success, or 0 on failure with the ChitraErr written through
# `err_out` (a >=8-byte slot holding a ChitraErr ptr). On the success
# path *err_out is left at 0.
#
# Pass 1 walks every chunk: validates each CRC, parses IHDR, sums IDAT
# payload lengths, captures PLTE/tRNS spans, stops at IEND. Pass 2
# concatenates the IDAT payloads, inflates (with the bomb caps), and
# unfilters into the scanline buffer.
# ================================================================
fn chitra_png_parse_raw(src, len, err_out): i64 {
    store64(err_out, 0);

    # crc32() needs its slice-by-8 table built first (it does not lazy-
    # init). Idempotent — cheap to call per decode.
    crc32_init_table();

    # ---- signature ----
    if (chitra_png_check_signature(src, len) == 0) {
        store64(err_out, chitra_err(CHITRA_ERR_SIGNATURE));
        return 0;
    }

    var raw = alloc(CHITRA_PNG_RAW_SIZE);
    if (raw == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    var z = 0;
    while (z < CHITRA_PNG_RAW_SIZE) { store8(raw + z, 0); z = z + 1; }

    var cur[24];
    _cur_init(&cur, src, len);
    _cur_skip(&cur, CHITRA_PNG_MAGIC_LEN);    # past the 8-byte signature

    # IHDR must be the first chunk (spec § 11.2.2).
    var ihdr_err = _chitra_parse_ihdr(&cur, raw);
    if (ihdr_err != 0) { store64(err_out, ihdr_err); return 0; }

    # ---- pass 1: chunk walk (CRC every chunk, capture spans) ----
    var idat_total = 0;
    var seen_iend = 0;
    var seen_plte = 0;
    var walking = 1;
    while (walking == 1) {
        # A chunk header is 8 bytes (4 length + 4 type). Fewer remaining
        # bytes with no IEND yet = truncated stream. Exactly 0 left is a
        # clean (if IEND-less) end; spec § 5.3 tolerates a missing IEND,
        # but we treat truncation conservatively.
        var rem = _cur_remaining(&cur);
        if (rem == 0) { walking = 0; }
        else { if (rem < 8) {
                store64(err_out, chitra_err(CHITRA_ERR_TRUNCATED));
                return 0;
            } else {

                var chunk_len = _cur_u32_be(&cur);
                var type_ptr = _cur_ptr(&cur);
                # chunk_len must not exceed the remaining data (after the 4 type
                # bytes) plus the 4 CRC bytes. Validate before any scan.
                if (chunk_len > CHITRA_MAX_RAW_BYTES) {
                    store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
                    return 0;
                }
                # remaining-after-type must hold chunk_len data + 4 CRC.
                if (_cur_remaining(&cur) < 4 + chunk_len + 4) {
                    store64(err_out, chitra_err(CHITRA_ERR_TRUNCATED));
                    return 0;
                }

                var is_idat = _chunk_is_idat(type_ptr);
                var is_iend = _chunk_is_iend(type_ptr);
                var is_plte = _chunk_is_plte(type_ptr);
                var is_trns = _chunk_is_trns(type_ptr);

                # CRC covers type(4) + data(chunk_len). Compute over the
                # contiguous span at type_ptr, then compare against the stored
                # CRC after the data.
                var computed = crc32(type_ptr, 4 + chunk_len);
                _cur_skip(&cur, 4);                  # past type
                var data_off = _cur_pos(&cur);       # byte offset of data within src
                var data_ptr = _cur_ptr(&cur);
                _cur_skip(&cur, chunk_len);          # past data
                var stored = _cur_u32_be(&cur);      # 4-byte CRC
                if ((computed & 4294967295) != (stored & 4294967295)) {
                    store64(err_out, chitra_err(CHITRA_ERR_CRC));
                    return 0;
                }

                if (is_idat == 1) {
                    idat_total = idat_total + chunk_len;
                    if (idat_total > CHITRA_MAX_RAW_BYTES) {
                        store64(err_out, chitra_err(CHITRA_ERR_OOM));
                        return 0;
                    }
                }
                if (is_plte == 1) {
                    # Spec § 5.5 / 5.6: at most one PLTE, must precede IDAT,
                    # length a multiple of 3, <= 768. Capture the span (bytes
                    # processed by the AL.P0d color pass, not here).
                    if (seen_plte == 1)      { store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK)); return 0; }
                    if (idat_total > 0)      { store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK)); return 0; }
                    if (chunk_len > 768)     { store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK)); return 0; }
                    if (chunk_len % 3 != 0)  { store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK)); return 0; }
                    store64(raw + RAW_PLTE_OFF_OFFSET, data_off);
                    store64(raw + RAW_PLTE_LEN_OFFSET, chunk_len);
                    seen_plte = 1;
                }
                if (is_trns == 1) {
                    # tRNS span captured for the color pass; format validation
                    # is color-type-dependent and lands in the AL.P0d color
                    # bite (mabda v3.3 punchlist Phase AL.P0).
                    store64(raw + RAW_TRNS_OFF_OFFSET, data_off);
                    store64(raw + RAW_TRNS_LEN_OFFSET, chunk_len);
                }
                if (is_iend == 1) {
                    # IEND carries no data (spec § 11.2.5) — a non-zero
                    # length is a malformed stream, reject loud.
                    if (chunk_len != 0) {
                        store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
                        return 0;
                    }
                    seen_iend = 1;
                    walking = 0;
                }

            } }
    }

    # Surface whether an IEND closed the stream (vs a tolerated clean
    # IEND-less end) so the public image can carry it to the caller.
    store64(raw + RAW_SEEN_IEND_OFFSET, seen_iend);

    # ---- derive sizes (validated dims from IHDR) ----
    var width = load64(raw + RAW_WIDTH_OFFSET);
    var height = load64(raw + RAW_HEIGHT_OFFSET);
    var channels = load64(raw + RAW_CHANNELS_OFFSET);
    var bit_depth = load64(raw + RAW_BIT_DEPTH_OFFSET);
    var interlace = load64(raw + RAW_INTERLACE_OFFSET);
    # Dense, byte-padded output scanlines (channels*depth bits/pixel, each
    # row padded to a byte). filter_bpp is the unfilter stride: ceil(bits/8),
    # which is 1 for sub-byte depths and channels*bytes for depth >= 8.
    var row_bytes = _chitra_row_bytes_for(width, channels, bit_depth);
    var filter_bpp = _chitra_filter_bpp_for(channels, bit_depth);
    var pixel_size = height * row_bytes;
    # Inflated (post-DEFLATE) size: one filter byte per scanline. For Adam7
    # that is summed across the 7 reduced passes; otherwise it is height rows.
    var inflated_size = 0;
    if (interlace == 1) {
        inflated_size = _chitra_adam7_inflated_size(width, height, channels, bit_depth);
    } else {
        inflated_size = height * (1 + row_bytes);
    }
    if (inflated_size > CHITRA_MAX_RAW_BYTES) {
        store64(err_out, chitra_err(CHITRA_ERR_DIMENSIONS));
        return 0;
    }
    if (pixel_size > CHITRA_MAX_RAW_BYTES) {
        store64(err_out, chitra_err(CHITRA_ERR_DIMENSIONS));
        return 0;
    }

    # No IDAT at all — structurally valid but no pixels. Distinct from a
    # lying-IHDR dimension failure (those trip the caps above) so callers
    # can report "no pixel data" specifically.
    if (idat_total == 0) {
        store64(err_out, chitra_err(CHITRA_ERR_NO_IDAT));
        return 0;
    }
    # Decompression-bomb ratio cap (kii finding 3): inflated/idat above
    # DEFLATE's 1032:1 ceiling is a bomb. idat_total > 0 here, so the
    # divide is safe.
    if ((inflated_size / idat_total) > CHITRA_MAX_INFLATE_RATIO) {
        store64(err_out, chitra_err(CHITRA_ERR_DIMENSIONS));
        return 0;
    }

    # ---- pass 2: concatenate IDAT payloads ----
    var idat_buf = alloc(idat_total);
    if (idat_buf == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    var cur2[24];
    _cur_init(&cur2, src, len);
    _cur_skip(&cur2, CHITRA_PNG_MAGIC_LEN);
    _cur_skip(&cur2, 25);                   # past the validated IHDR chunk
    var copied = 0;
    var walking2 = 1;
    while (walking2 == 1) {
        if (_cur_remaining(&cur2) < 8) { walking2 = 0; }
        else {
            var clen = _cur_u32_be(&cur2);
            var tptr = _cur_ptr(&cur2);
            var is_i = _chunk_is_idat(tptr);
            var is_e = _chunk_is_iend(tptr);
            _cur_skip(&cur2, 4);            # past type
            if (is_i == 1 && clen > 0) {
                memcpy(idat_buf + copied, _cur_ptr(&cur2), clen);
                copied = copied + clen;
            }
            _cur_skip(&cur2, clen);         # past data
            _cur_skip(&cur2, 4);            # past CRC
            if (is_e == 1) { walking2 = 0; }
        }
    }

    # ---- inflate ----
    var inflated = alloc(inflated_size);
    if (inflated == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    var n = zlib_decompress(idat_buf, idat_total, inflated, inflated_size);
    if (n < 0) { store64(err_out, chitra_err(CHITRA_ERR_INFLATE)); return 0; }
    if (n != inflated_size) { store64(err_out, chitra_err(CHITRA_ERR_INFLATE)); return 0; }

    # ---- reconstruct dense packed scanlines: unfilter (non-interlaced)
    # or deinterlace (Adam7). Both produce the same byte-padded layout the
    # color pass consumes, so the color pass is interlace-agnostic. ----
    var pixels = alloc(pixel_size);
    if (pixels == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    if (interlace == 1) {
        var dc = _chitra_deinterlace(inflated, pixels, width, height, channels, bit_depth, err_out);
        if (dc != 0) { return 0; }     # *err_out already set by deinterlace
    } else {
        var zero_row = alloc(row_bytes);
        if (zero_row == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
        var zr = 0;
        while (zr < row_bytes) { store8(zero_row + zr, 0); zr = zr + 1; }
        var fc = _chitra_unfilter_image(inflated, pixels, zero_row, height, row_bytes, filter_bpp);
        if (fc != 0) { store64(err_out, chitra_err(CHITRA_ERR_FILTER)); return 0; }
    }

    store64(raw + RAW_SCANLINES_OFFSET, pixels);
    store64(raw + RAW_SCANLINES_LEN_OFFSET, pixel_size);
    return raw;
}

# --- png_color.cyr ---

# @internal — canonical-RGBA8 color-normalization pass (AL.P0d).
# png_color.cyr — turn a ChitraPngRaw (parsed IHDR + unfiltered raw
# scanlines + captured PLTE/tRNS spans) into an owned RGBA8 pixel
# buffer (width*height*4). This is the genuinely new code over kii:
# kii emits native channels / palette indices for the terminal path;
# chitra normalizes every color type to canonical RGBA8 + synthesizes
# alpha from tRNS.
#
# PLTE/tRNS access wiring (documented choice): the ChitraPngRaw captures
# PLTE/tRNS only as (offset-into-original-src, length) spans — the bytes
# themselves are not retained. chitra_png_parse_raw does NOT copy them
# (no struct widening, no extra allocs on the parse path). The public
# decode entry (png.cyr) still holds the original (src, len), so it
# passes src + len into the color pass, which resolves the spans via
# `src + plte_off` / `src + trns_off`. The parse-time bounds checks
# (every span lies within len; PLTE multiple-of-3 + <=768) already
# validated those offsets, but the color pass re-validates defensively
# against (src, len) so it is safe even if called on a hand-built raw.
#
# Only bit depth 8 is handled here (parse_raw rejects others loud), so
# every sample is one byte and scanline layout is dense channels-per-
# pixel with no bit unpacking.

# ================================================================
# Color-type sample-byte sizes (bit depth 8 => 1 byte per channel).
# These mirror chitra_png_color_channels but name the per-color-type
# byte strides the color pass walks the scanline with.
# ================================================================

# Resolve a PLTE entry count from the captured span (length / 3). A 0
# length means "no PLTE" — callers must reject palette images then.
fn _chitra_plte_entry_count(raw): i64 {
    var plen = chitra_raw_plte_len(raw);
    return plen / 3;
}

# ================================================================
# chitra_png_color_to_rgba8 — the AL.P0d color pass.
#
# Inputs:
#   raw  — a ChitraPngRaw with scanlines populated (parse_raw output).
#   src  — the ORIGINAL PNG byte buffer (PLTE/tRNS offsets index here).
#   len  — byte length of src (for defensive span re-validation).
#   err_out — >=8-byte slot; on failure receives a ChitraErr ptr.
#
# Returns an owned RGBA8 buffer (width*height*4 bytes) on success, or 0
# with *err_out set. *err_out is left 0 on the success path.
#
# New reject paths over AL.P0b:
#   - palette index >= PLTE entry count        -> CHITRA_ERR_BAD_CHUNK
#   - color_type 3 with no/short PLTE          -> CHITRA_ERR_BAD_CHUNK
#   - tRNS span out of (src, len) bounds       -> CHITRA_ERR_BAD_CHUNK
#   - tRNS wrong length for the color type      -> CHITRA_ERR_BAD_CHUNK
#       (gray:2 bytes, RGB:6 bytes, palette:<=entry_count bytes)
# ================================================================
fn chitra_png_color_to_rgba8(raw, src, len, err_out): i64 {
    store64(err_out, 0);

    var width = chitra_raw_width(raw);
    var height = chitra_raw_height(raw);
    var color_type = chitra_raw_color_type(raw);
    var channels = chitra_raw_channels(raw);
    var scan = chitra_raw_scanlines(raw);
    var scan_len = chitra_raw_scanlines_len(raw);

    # Bytes per sample: 1 at depth 8, 2 at depth 16. At depth 16 each
    # big-endian sample is truncated to its HIGH byte (offset +0 of the
    # 2-byte pair) — the same lossy 16->8 reduction kii's terminal path
    # used, keeping rendered output byte-identical. Sub-byte depths never
    # reach here (parse_raw rejects 1/2/4), so bps is always 1 or 2.
    var bit_depth = chitra_raw_bit_depth(raw);
    var bps = bit_depth / 8;

    # width*height was capped <= CHITRA_MAX_PIXELS in parse_raw, so
    # out_size <= 64 Mi*4 = 256 Mi — within CHITRA_MAX_RAW_BYTES and far
    # below the i64-overflow boundary. Re-derive (don't trust a span).
    # Re-assert the IHDR caps before the width/height multiplies — defense
    # in depth so this @internal pass is safe even on a hand-built raw (the
    # per-side cap first guarantees width*height cannot overflow i64).
    if (width <= 0 || height <= 0) { store64(err_out, chitra_err(CHITRA_ERR_DIMENSIONS)); return 0; }
    if (width > CHITRA_MAX_DIM || height > CHITRA_MAX_DIM) {
        store64(err_out, chitra_err(CHITRA_ERR_DIMENSIONS));
        return 0;
    }
    if (width * height > CHITRA_MAX_PIXELS) {
        store64(err_out, chitra_err(CHITRA_ERR_DIMENSIONS));
        return 0;
    }
    var npix = width * height;
    var out_size = npix * 4;

    # The scanline buffer must hold the dense, byte-padded rows parse_raw
    # produced — height * ceil(width*channels*depth/8). (At depth >= 8 this
    # equals npix*channels*bps; the row-padded form also covers sub-byte.)
    var row_bytes = _chitra_row_bytes_for(width, channels, bit_depth);
    if (scan_len < height * row_bytes) {
        store64(err_out, chitra_err(CHITRA_ERR_DIMENSIONS));
        return 0;
    }

    var out = alloc(out_size);
    if (out == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }

    # ---- resolve + validate the tRNS span against (src, len) -------
    var trns_off = chitra_raw_trns_off(raw);
    var trns_len = chitra_raw_trns_len(raw);
    var has_trns = 0;
    var trns_ptr = 0;
    if (trns_len > 0) {
        if (trns_off < 0 || trns_off + trns_len > len) {
            store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
            return 0;
        }
        has_trns = 1;
        trns_ptr = src + trns_off;
    }

    # ---- sub-byte depths 1/2/4 (only color_type 0 grayscale + 3 palette
    # per spec § 11.2.2). Samples are MSB-first packed with rows padded to
    # a byte, so we walk (y, x) and bit-unpack rather than a linear index.
    if (bit_depth < 8) {
        if (color_type == 0) {
            # grayscale: scale the d-bit sample to 8-bit (×255/85/17).
            # tRNS keys on the raw (unscaled) sample value.
            var scale = _chitra_gray_scale(bit_depth);
            var key = 0 - 1;
            if (has_trns == 1) {
                if (trns_len != 2) { store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK)); return 0; }
                key = load8(trns_ptr + 1);    # depth<8: keyed value in the low byte
            }
            var gy = 0;
            while (gy < height) {
                var growp = scan + gy * row_bytes;
                var gx = 0;
                while (gx < width) {
                    var s = _chitra_get_subbyte(growp, gx, bit_depth);
                    var g = s * scale;
                    var ga = 255;
                    if (s == key) { ga = 0; }
                    var go = out + (gy * width + gx) * 4;
                    store8(go + 0, g);
                    store8(go + 1, g);
                    store8(go + 2, g);
                    store8(go + 3, ga);
                    gx = gx + 1;
                }
                gy = gy + 1;
            }
            return out;
        }
        if (color_type == 3) {
            # palette: the d-bit index selects a PLTE entry; per-entry tRNS
            # alpha (same as the depth-8 palette path).
            var plte_off = chitra_raw_plte_off(raw);
            var plte_len = chitra_raw_plte_len(raw);
            var entry_count = plte_len / 3;
            if (entry_count <= 0) { store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK)); return 0; }
            if (plte_off < 0 || plte_off + plte_len > len) {
                store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
                return 0;
            }
            var plte_ptr = src + plte_off;
            if (has_trns == 1 && trns_len > entry_count) {
                store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
                return 0;
            }
            var py2 = 0;
            while (py2 < height) {
                var prowp = scan + py2 * row_bytes;
                var px3 = 0;
                while (px3 < width) {
                    var idx = _chitra_get_subbyte(prowp, px3, bit_depth);
                    if (idx >= entry_count) { store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK)); return 0; }
                    var pe = plte_ptr + idx * 3;
                    var pa = 255;
                    if (has_trns == 1 && idx < trns_len) { pa = load8(trns_ptr + idx); }
                    var po = out + (py2 * width + px3) * 4;
                    store8(po + 0, load8(pe + 0));
                    store8(po + 1, load8(pe + 1));
                    store8(po + 2, load8(pe + 2));
                    store8(po + 3, pa);
                    px3 = px3 + 1;
                }
                py2 = py2 + 1;
            }
            return out;
        }
        # sub-byte is only valid for ct0/ct3 (parse_raw enforces); guard.
        store64(err_out, chitra_err(CHITRA_ERR_UNSUPPORTED));
        return 0;
    }

    # ---- grayscale (0): g -> (g,g,g,255); tRNS = one gray sample ----
    if (color_type == 0) {
        # tRNS for grayscale is a 2-byte big-endian sample. Key on the
        # same 8-bit value the pixel reduces to: the low byte at depth 8
        # (high byte is 0), the high byte at depth 16 (the truncation).
        var key_g = 0 - 1;     # -1 == no key
        if (has_trns == 1) {
            if (trns_len != 2) {
                store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
                return 0;
            }
            if (bps == 2) {
                key_g = load8(trns_ptr + 0);
            } else {
                key_g = load8(trns_ptr + 1);
            }
        }
        var i = 0;
        while (i < npix) {
            var g = load8(scan + i * bps);
            var a = 255;
            if (g == key_g) { a = 0; }
            var o = out + i * 4;
            store8(o + 0, g);
            store8(o + 1, g);
            store8(o + 2, g);
            store8(o + 3, a);
            i = i + 1;
        }
        return out;
    }

    # ---- truecolor RGB (2): (r,g,b) -> (r,g,b,255); tRNS = 1 triple --
    if (color_type == 2) {
        var key_r = 0 - 1;
        var key_g2 = 0;
        var key_b = 0;
        if (has_trns == 1) {
            # tRNS is three 2-byte big-endian samples (R,G,B). Key on the
            # high byte at depth 16, the low byte at depth 8 — matching the
            # per-channel pixel truncation below.
            if (trns_len != 6) {
                store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
                return 0;
            }
            if (bps == 2) {
                key_r = load8(trns_ptr + 0);
                key_g2 = load8(trns_ptr + 2);
                key_b = load8(trns_ptr + 4);
            } else {
                key_r = load8(trns_ptr + 1);
                key_g2 = load8(trns_ptr + 3);
                key_b = load8(trns_ptr + 5);
            }
        }
        var i = 0;
        while (i < npix) {
            var s = scan + i * 3 * bps;
            var r = load8(s + 0);
            var g = load8(s + 1 * bps);
            var b = load8(s + 2 * bps);
            var a = 255;
            if (r == key_r && g == key_g2 && b == key_b) { a = 0; }
            var o = out + i * 4;
            store8(o + 0, r);
            store8(o + 1, g);
            store8(o + 2, b);
            store8(o + 3, a);
            i = i + 1;
        }
        return out;
    }

    # ---- palette (3): index -> PLTE[index]; alpha from tRNS array ---
    if (color_type == 3) {
        var plte_off = chitra_raw_plte_off(raw);
        var plte_len = chitra_raw_plte_len(raw);
        var entry_count = plte_len / 3;
        # Palette images REQUIRE a PLTE chunk (spec § 11.2.3).
        if (entry_count <= 0) {
            store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
            return 0;
        }
        # Defensive: the PLTE span must lie within (src, len).
        if (plte_off < 0 || plte_off + plte_len > len) {
            store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
            return 0;
        }
        var plte_ptr = src + plte_off;
        # tRNS for palette is a per-entry alpha array (1 byte each),
        # length <= entry_count; entries beyond it default to 255.
        if (has_trns == 1 && trns_len > entry_count) {
            store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
            return 0;
        }
        var i = 0;
        while (i < npix) {
            var idx = load8(scan + i);
            # Every index must be a valid palette entry (reject OOB).
            if (idx >= entry_count) {
                store64(err_out, chitra_err(CHITRA_ERR_BAD_CHUNK));
                return 0;
            }
            var pe = plte_ptr + idx * 3;
            var a = 255;
            if (has_trns == 1 && idx < trns_len) { a = load8(trns_ptr + idx); }
            var o = out + i * 4;
            store8(o + 0, load8(pe + 0));
            store8(o + 1, load8(pe + 1));
            store8(o + 2, load8(pe + 2));
            store8(o + 3, a);
            i = i + 1;
        }
        return out;
    }

    # ---- grayscale+alpha (4): (g,a) -> (g,g,g,a) --------------------
    if (color_type == 4) {
        var i = 0;
        while (i < npix) {
            var s = scan + i * 2 * bps;
            var g = load8(s + 0);
            var a = load8(s + 1 * bps);
            var o = out + i * 4;
            store8(o + 0, g);
            store8(o + 1, g);
            store8(o + 2, g);
            store8(o + 3, a);
            i = i + 1;
        }
        return out;
    }

    # ---- truecolor+alpha (6): (r,g,b,a) -> high byte per channel ----
    if (color_type == 6) {
        var i = 0;
        while (i < npix) {
            var s = scan + i * 4 * bps;
            var o = out + i * 4;
            store8(o + 0, load8(s + 0));
            store8(o + 1, load8(s + 1 * bps));
            store8(o + 2, load8(s + 2 * bps));
            store8(o + 3, load8(s + 3 * bps));
            i = i + 1;
        }
        return out;
    }

    # Unknown color type — parse_raw already rejects these, but guard.
    store64(err_out, chitra_err(CHITRA_ERR_UNSUPPORTED));
    return 0;
}

# --- png.cyr ---

# @public — chitra PNG decoder: PNG bytes -> canonical RGBA8.
#
# png.cyr — the public decode API. Wires the AL.P0b parse driver
# (chitra_png_parse_raw: framing + inflate + unfilter) to the AL.P0d
# color pass (chitra_png_color_to_rgba8: canonical-RGBA8 + tRNS) and
# wraps the result in a ChitraImage.
#
# Scope (feature-complete for PNG as of v0.2.1): signature + chunk parse
# (IHDR / IDAT-concat / IEND / PLTE / tRNS), color types 0/2/3/4/6 at every
# spec-legal bit depth (1/2/4/8/16, validated per color_type — § 11.2.2
# Table 11.1), Adam7 interlace, sankoch IDAT inflate, the five unfilter
# predictors, canonical-RGBA8 output (16-bit truncates to the high byte;
# sub-byte scales 255/85/17), and the kii security guards. JPEG is 0.3+.
#
# PLTE/tRNS wiring: chitra_png_parse_raw captures PLTE/tRNS only as
# (offset-into-src, length) spans (no byte copy). The public decode
# entry holds the original (src, len), so it forwards src + len into the
# color pass, which resolves the spans (see png_color.cyr's header).

# ================================================================
# ChitraImage — the public decode result (48 bytes).
#   +0:  width       (i64 — pixels)
#   +8:  height      (i64 — pixels)
#   +16: pixels      (ptr — owned RGBA8, width*height*4 bytes)
#   +24: channels    (i64 — always 4)
#   +32: seen_iend   (i64 — 1 if IEND closed the stream, 0 = clean IEND-less)
#   +40: src_ctype   (i64 — pre-normalization PNG color_type: 0/2/3/4/6)
#
# The +32/+40 fields are ADDITIVE — width/height/pixels/channels keep
# their 0.1.x offsets, so mabda's accessors are unaffected by the widen.
# ================================================================
var IMAGE_WIDTH_OFFSET       = 0;
var IMAGE_HEIGHT_OFFSET      = 8;
var IMAGE_PIXELS_OFFSET      = 16;
var IMAGE_CHANNELS_OFFSET    = 24;
var IMAGE_SEEN_IEND_OFFSET   = 32;
var IMAGE_SRC_CTYPE_OFFSET   = 40;
var CHITRA_IMAGE_SIZE        = 48;

# ---- ChitraImage accessors --------------------------------------
fn chitra_image_width(img): i64    { return load64(img + IMAGE_WIDTH_OFFSET); }
fn chitra_image_height(img): i64   { return load64(img + IMAGE_HEIGHT_OFFSET); }
fn chitra_image_pixels(img): i64   { return load64(img + IMAGE_PIXELS_OFFSET); }
fn chitra_image_channels(img): i64 { return load64(img + IMAGE_CHANNELS_OFFSET); }
# 1 if an IEND chunk closed the stream; 0 if the stream ended cleanly
# without one (spec § 5.3 tolerance) — a consumer can warn yet still use
# the pixels.
fn chitra_image_seen_iend(img): i64 { return load64(img + IMAGE_SEEN_IEND_OFFSET); }
# The source color type before RGBA8 normalization — lets a consumer report the
# original format even though pixels are canonical. For PNG this is the PNG
# color_type (0/2/3/4/6). For JPEG (chitra 0.3.0) it is an out-of-PNG-range
# sentinel `0x100 | num_components` (0x101 grayscale, 0x103 YCbCr) so a consumer
# switching on PNG's 0/2/3/4/6 never aliases a JPEG value (see ADR 0003).
fn chitra_image_source_color_type(img): i64 { return load64(img + IMAGE_SRC_CTYPE_OFFSET); }

# ================================================================
# chitra_png_decode — the top-level public decode. Parse (src, len) PNG
# bytes -> an owned RGBA8 ChitraImage.
#
# Returns the ChitraImage ptr on success, or 0 with *err_out set to a
# ChitraErr ptr. *err_out is left 0 on success. err_out is a >=8-byte
# slot the caller owns (mirrors chitra_png_parse_raw's convention so the
# Ok/Err split is a (ptr, err_out) pair rather than a tagged union).
# ================================================================
# @public
fn chitra_png_decode(src, len, err_out): i64 {
    store64(err_out, 0);

    # ---- parse: framing + inflate + unfilter (AL.P0b) ----
    var raw = chitra_png_parse_raw(src, len, err_out);
    if (raw == 0) { return 0; }      # *err_out already set by parse_raw

    # ---- color pass: canonical RGBA8 + tRNS (AL.P0d) ----
    var rgba = chitra_png_color_to_rgba8(raw, src, len, err_out);
    if (rgba == 0) { return 0; }     # *err_out already set by the color pass

    var img = alloc(CHITRA_IMAGE_SIZE);
    if (img == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    store64(img + IMAGE_WIDTH_OFFSET, chitra_raw_width(raw));
    store64(img + IMAGE_HEIGHT_OFFSET, chitra_raw_height(raw));
    store64(img + IMAGE_PIXELS_OFFSET, rgba);
    store64(img + IMAGE_CHANNELS_OFFSET, 4);
    store64(img + IMAGE_SEEN_IEND_OFFSET, chitra_raw_seen_iend(raw));
    store64(img + IMAGE_SRC_CTYPE_OFFSET, chitra_raw_color_type(raw));
    return img;
}

# ================================================================
# chitra_png_decode_rgba8 — convenience wrapper. Decode (src, len) and
# return the RGBA8 pixel pointer directly, writing width/height through
# w_out / h_out (>=8-byte slots). Returns 0 on any failure (the detailed
# ChitraErr is not surfaced here — callers needing it use chitra_png_decode).
# On the 0 path w_out/h_out are left at 0.
# ================================================================
# @public
fn chitra_png_decode_rgba8(src, len, w_out, h_out): i64 {
    store64(w_out, 0);
    store64(h_out, 0);
    var err = 0;
    var img = chitra_png_decode(src, len, &err);
    if (img == 0) { return 0; }
    store64(w_out, chitra_image_width(img));
    store64(h_out, chitra_image_height(img));
    return chitra_image_pixels(img);
}

# ================================================================
# chitra_image_free — release a ChitraImage. The stdlib `alloc` is a
# bump allocator with no per-block free, so this is a documented no-op
# kept for API symmetry (matches chitra_raw_free) and a future arena-
# backed allocator. Safe on a 0 ptr.
# ================================================================
# @public
fn chitra_image_free(img): i64 {
    return 0;
}

# ================================================================
# Version probe — packed as major*10000 + minor*100 + patch.
# 0.1.0 -> 100, 0.1.1 -> 101, 0.2.0 -> 200, 0.2.1 -> 201, 0.3.0 -> 300.
# ================================================================
# @public
fn chitra_version(): i64 {
    return 300;
}

# --- jpeg_huffman.cyr ---

# @internal — JPEG Huffman decode tables (0.3.0, bite 3).
# jpeg_huffman.cyr — the canonical Huffman decode-table representation and its
# construction from a DHT's BITS (code-length counts) + HUFFVAL (symbols). This
# module is frame-independent table machinery, so it is included BEFORE
# jpeg_markers.cyr (whose DHT parser drives the build into frame-owned storage).
# The entropy bit-reader + the DECODE procedure land in bite 4.
#
# Construction follows ITU-T T.81 Annex C (HUFFSIZE/HUFFCODE generation) folded
# into the Annex F figure F.15 decoder-table derivation (MINCODE/MAXCODE/VALPTR).
# The DECODE procedure (Annex F.2.2.3) the next bite implements:
#   code = nextbit(); L = 1
#   while code > maxcode[L]: L += 1; code = (code << 1) | nextbit()
#   value = huffval[ valptr[L] + code - mincode[L] ]
# maxcode[L] == -1 marks "no codes of length L".

# ================================================================
# HuffTable record (i64 fields). One per table; 8 live in the frame (4 DC,
# 4 AC). Codes are at most 16 bits; symbols at most 256 (T.81 § B.2.4.2).
#   +0    mincode[0..16]   (17 i64) — smallest code of each length L
#   +136  maxcode[0..16]   (17 i64) — largest code of each length L (-1 = none)
#   +272  valptr[0..16]    (17 i64) — huffval index of first symbol of length L
#   +408  count            (1 i64)  — number of symbols (Σ BITS)
#   +416  huffval[0..255]  (256 i64)— symbol values, in DHT order
# ================================================================
var HT_MINCODE = 0;
var HT_MAXCODE = 136;    # 17*8
var HT_VALPTR  = 272;    # 34*8
var HT_COUNT   = 408;    # 51*8
var HT_HUFFVAL = 416;    # 52*8
var HT_SIZE    = 2464;   # (52 + 256) * 8

fn _jpeg_huff_mincode(t, L): i64 { return load64(t + HT_MINCODE + L * 8); }
fn _jpeg_huff_maxcode(t, L): i64 { return load64(t + HT_MAXCODE + L * 8); }
fn _jpeg_huff_valptr(t, L): i64  { return load64(t + HT_VALPTR + L * 8); }
fn _jpeg_huff_count(t): i64      { return load64(t + HT_COUNT); }
fn _jpeg_huff_val(t, i): i64     { return load64(t + HT_HUFFVAL + i * 8); }

# ================================================================
# Build the MINCODE/MAXCODE/VALPTR decode arrays from BITS. `table` already has
# its HUFFVAL[] and COUNT filled by the caller; `bits` is a 17-i64 array with
# bits[L] = number of codes of length L (L in 1..16; index 0 unused).
#
# Canonical codes are consecutive integers per length, the whole space shifting
# left by one bit at each length step. Over-subscription (more codes than the
# length can hold) is rejected — the security-critical check that stops a
# malformed table from producing out-of-range code values. Returns 0 on success
# or CHITRA_ERR_JPEG_DHT.
# ================================================================
fn _jpeg_huff_build(table, bits): i64 {
    var z = 0;
    while (z <= 16) {
        store64(table + HT_MINCODE + z * 8, 0);
        store64(table + HT_MAXCODE + z * 8, 0 - 1);
        store64(table + HT_VALPTR + z * 8, 0);
        z = z + 1;
    }
    var code = 0;
    var j = 0;          # running symbol index into HUFFVAL
    var L = 1;
    var cnt = 0;
    var rc = 0;
    var done = 0;
    while (done == 0) {
        if (L > 16) { done = 1; }
        if (done == 0) {
            cnt = load64(bits + L * 8);
            if (cnt > 0) {
                store64(table + HT_VALPTR + L * 8, j);
                store64(table + HT_MINCODE + L * 8, code);
                code = code + cnt - 1;                    # largest code of length L
                store64(table + HT_MAXCODE + L * 8, code);
                if (code >= (1 << L)) { rc = CHITRA_ERR_JPEG_DHT; done = 1; }
                if (done == 0) {
                    code = code + 1;
                    j = j + cnt;
                }
            }
            if (done == 0) {
                code = code << 1;
                L = L + 1;
            }
        }
    }
    return rc;
}

# ================================================================
# Entropy bit-reader (T.81 § F.2.2 + § B.1.1.5 byte stuffing). MSB-first bit
# pull over the entropy-coded segment after SOS. A 0xFF in the stream is either
# followed by 0x00 (a stuffing byte to discard, the 0xFF is real data) or by a
# marker code (RSTn / EOI / ...), at which point the reader stops and records
# the marker; subsequent bit reads pad with zeros. The 24-byte... actually
# 48-byte record:
#   +0 base  +8 pos  +16 end  +24 buf (current byte)  +32 cnt (bits left in buf)
#   +40 marker (the marker byte after a 0xFF, or 0)
# ================================================================
var BR_BASE   = 0;
var BR_POS    = 8;
var BR_END    = 16;
var BR_BUF    = 24;
var BR_CNT    = 32;
var BR_MARKER = 40;
var BR_SIZE   = 48;

fn _jpeg_br_init(reader, base, len): i64 {
    store64(reader + BR_BASE, base);
    store64(reader + BR_POS, 0);
    store64(reader + BR_END, len);
    store64(reader + BR_BUF, 0);
    store64(reader + BR_CNT, 0);
    store64(reader + BR_MARKER, 0);
    return 0;
}

fn _jpeg_br_marker(reader): i64 { return load64(reader + BR_MARKER); }
fn _jpeg_br_pos(reader): i64    { return load64(reader + BR_POS); }

# Resync at a restart-interval boundary (T.81 § F.2.1.3.1 / E.1.1): discard the
# partial byte (byte-align), then consume the expected RSTn marker (FF D0..D7).
# After decoding `restart_interval` MCUs the stream is byte-aligned at an RSTn;
# BR_POS points at its 0xFF (whether or not the bit-reader auto-detected it).
# Returns 0 on success, -1 if the restart marker is missing/malformed.
fn _jpeg_br_restart(reader): i64 {
    store64(reader + BR_CNT, 0);
    var base = load64(reader + BR_BASE);
    var pos = load64(reader + BR_POS);
    var end = load64(reader + BR_END);
    if (pos + 1 >= end) { return 0 - 1; }
    if (load8(base + pos) != 0xFF) { return 0 - 1; }
    var m = load8(base + pos + 1);
    if (m < 0xD0) { return 0 - 1; }
    if (m > 0xD7) { return 0 - 1; }
    store64(reader + BR_POS, pos + 2);
    store64(reader + BR_MARKER, 0);
    return 0;
}

# Load one data byte (8 bits) into the buffer. Only called when CNT == 0. On a
# stuffing pair (FF 00) the 0xFF is loaded and the 0x00 discarded. On a marker
# (FF xx, xx != 0) or end-of-data, the marker is recorded (xx, or EOI for a
# trailing lone FF) and CNT is left 0 so callers pad with zero bits.
fn _jpeg_br_load_byte(reader): i64 {
    if (load64(reader + BR_MARKER) != 0) { return 0; }
    var base = load64(reader + BR_BASE);
    var pos = load64(reader + BR_POS);
    var end = load64(reader + BR_END);
    var b = 0;
    var b2 = 0;
    if (pos >= end) { return 0; }
    b = load8(base + pos);
    pos = pos + 1;
    if (b == 0xFF) {
        if (pos >= end) {
            store64(reader + BR_MARKER, 0xD9);
            store64(reader + BR_POS, pos - 1);
            return 0;
        }
        b2 = load8(base + pos);
        if (b2 == 0x00) { pos = pos + 1; }     # stuffing — discard, keep 0xFF
        if (b2 != 0x00) {
            store64(reader + BR_MARKER, b2);
            store64(reader + BR_POS, pos - 1);  # leave pos at the 0xFF for resync
            return 0;
        }
    }
    store64(reader + BR_BUF, b);
    store64(reader + BR_CNT, 8);
    store64(reader + BR_POS, pos);
    return 0;
}

# Read one bit MSB-first. Returns 0 past end / after a marker (zero padding).
fn _jpeg_br_bit(reader): i64 {
    var cnt = load64(reader + BR_CNT);
    if (cnt == 0) {
        _jpeg_br_load_byte(reader);
        cnt = load64(reader + BR_CNT);
    }
    if (cnt == 0) { return 0; }
    cnt = cnt - 1;
    store64(reader + BR_CNT, cnt);
    return (load64(reader + BR_BUF) >> cnt) & 1;
}

# RECEIVE: read n bits as an unsigned value (T.81 § F.2.2.4).
fn _jpeg_br_bits(reader, n): i64 {
    var v = 0;
    var i = 0;
    while (i < n) {
        v = (v << 1) | _jpeg_br_bit(reader);
        i = i + 1;
    }
    return v;
}

# EXTEND a value received with n bits to its signed coefficient (T.81 § F.2.2.1,
# figure F.12): values below 2^(n-1) are negative.
fn _jpeg_extend(v, n): i64 {
    if (n == 0) { return 0; }
    if (v < (1 << (n - 1))) {
        return v - (1 << n) + 1;
    }
    return v;
}

# DECODE a single Huffman-coded symbol (T.81 § F.2.2.3, figure F.16). Walks the
# maxcode table, extending the code one bit per length until it fits. Returns
# the symbol (0..255), or -1 on an undecodable code (no length matched, or an
# index outside the table's symbol list — incomplete-table defense).
fn _jpeg_decode(reader, table): i64 {
    var code = _jpeg_br_bit(reader);
    var L = 1;
    var maxc = _jpeg_huff_maxcode(table, 1);
    var done = 0;
    var bad = 0;
    while (done == 0) {
        if (code <= maxc) { done = 1; }
        if (done == 0) {
            L = L + 1;
            if (L > 16) { done = 1; bad = 1; }
            if (done == 0) {
                code = (code << 1) | _jpeg_br_bit(reader);
                maxc = _jpeg_huff_maxcode(table, L);
            }
        }
    }
    if (bad == 1) { return 0 - 1; }
    var idx = _jpeg_huff_valptr(table, L) + code - _jpeg_huff_mincode(table, L);
    if (idx < 0) { return 0 - 1; }
    if (idx >= _jpeg_huff_count(table)) { return 0 - 1; }
    return _jpeg_huff_val(table, idx);
}

# Decode one 8x8 block's 64 coefficients in zig-zag order into zz_out (64 i64,
# de-zig-zag deferred to dequant). DC is differential against `pred`; AC uses
# run/size (RRRR/SSSS) coding with ZRL (16-zero run) and EOB (T.81 § F.2.2.2).
# Returns the new DC predictor value; on a corrupt stream sets *err_out to a
# CHITRA_ERR_JPEG_ENTROPY ChitraErr and returns 0.
fn _jpeg_decode_block(reader, dct, act, pred, zz_out, err_out): i64 {
    store64(err_out, 0);
    var i = 0;
    while (i < 64) { store64(zz_out + i * 8, 0); i = i + 1; }

    var t = _jpeg_decode(reader, dct);
    if (t < 0) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_ENTROPY)); return 0; }
    # DC magnitude category: 0..11 for 8-bit baseline (T.81 Table F.1).
    if (t > 11) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_ENTROPY)); return 0; }
    var diff = 0;
    if (t > 0) { diff = _jpeg_extend(_jpeg_br_bits(reader, t), t); }
    var dc = pred + diff;
    store64(zz_out + 0, dc);

    var k = 1;
    var rs = 0;
    var r = 0;
    var s = 0;
    var done = 0;
    while (done == 0) {
        if (k > 63) { done = 1; }
        if (done == 0) {
            rs = _jpeg_decode(reader, act);
            if (rs < 0) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_ENTROPY)); done = 1; }
            if (done == 0) {
                r = (rs >> 4) & 15;
                s = rs & 15;
                # AC magnitude category: 0..10 for 8-bit baseline (T.81 Table F.2);
                # s==0 is EOB (r==0) or ZRL (r==15). s in 11..15 is out of spec.
                if (s > 10) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_ENTROPY)); done = 1; }
            }
            if (done == 0) {
                if (s == 0) {
                    if (r == 15) { k = k + 16; }   # ZRL: a run of 16 zeros
                    if (r != 15) { done = 1; }     # EOB: remaining coeffs are zero
                }
                if (s != 0) {
                    k = k + r;
                    if (k > 63) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_ENTROPY)); done = 1; }
                    if (done == 0) {
                        store64(zz_out + k * 8, _jpeg_extend(_jpeg_br_bits(reader, s), s));
                        k = k + 1;
                    }
                }
            }
        }
    }
    if (load64(err_out) != 0) { return 0; }
    return dc;
}

# --- jpeg_idct.cyr ---

# @internal — JPEG dequantization + zig-zag + inverse DCT (0.3.0, bite 5).
# jpeg_idct.cyr — turn a block of 64 zig-zag-order DCT coefficients (from
# jpeg_huffman's _jpeg_decode_block) plus its quantization table into 64
# natural-order 8-bit samples. Frame-independent: operates on caller buffers.
#
# IDCT: the libjpeg `jpeg_idct_islow` integer fixed-point separable algorithm
# (Loeffler-Ligtenberg-Moschytz factorization), committed in
# docs/adr/0004-jpeg-decode-model.md; constants per ITU-T T.81 + libjpeg jidctint.c.
#   Source: Loeffler, C., Ligtenberg, A., Moschytz, G. (1989), "Practical fast
#   1-D DCT algorithms with 11 multiplications," IEEE ICASSP, pp. 988-991.
#   Implementation reference: libjpeg jidctint.c (jpeg_idct_islow). See docs/sources.md.
#
# CONST_BITS = 13 (fixed-point scale of the FIX_* constants). PASS1_BITS = 2.
# Pass 1 (columns) descales by CONST_BITS - PASS1_BITS = 11; pass 2 (rows) by
# CONST_BITS + PASS1_BITS + 3 = 18, where +3 is the IDCT 1/8 normalization.
#
# NOTE (Cyrius): `>>` is a LOGICAL shift here, so it is wrong for the negative
# intermediates the IDCT produces. DESCALE therefore uses signed division with
# round-to-nearest (symmetric about 0) — deterministic, and a valid rounding of
# the same value. The even-part CONST_BITS scaling uses `* 8192` (= 1<<13) rather
# than a left shift so negative coefficients scale correctly.

var FIX_0_298631336 = 2446;
var FIX_0_390180644 = 3196;
var FIX_0_541196100 = 4433;
var FIX_0_765366865 = 6270;
var FIX_0_899976223 = 7373;
var FIX_1_175875602 = 9633;
var FIX_1_501321110 = 12299;
var FIX_1_847759065 = 15137;
var FIX_1_961570560 = 16069;
var FIX_2_053119869 = 16819;
var FIX_2_562915447 = 20995;
var FIX_3_072711026 = 25172;

# ================================================================
# Zig-zag → natural (row-major 8x8) index map (T.81 figure A.6). Lazily built
# once into a 64-i64 table. Coefficients and quant tables arrive in zig-zag
# order; dequant scatters them into natural order via this map.
# ================================================================
var _jpeg_zz_ptr = 0;
fn _jpeg_zigzag_table(): i64 {
    if (_jpeg_zz_ptr != 0) { return _jpeg_zz_ptr; }
    var t = alloc(64 * 8);
    store64(t + 0 * 8, 0);
    store64(t + 1 * 8, 1);
    store64(t + 2 * 8, 8);
    store64(t + 3 * 8, 16);
    store64(t + 4 * 8, 9);
    store64(t + 5 * 8, 2);
    store64(t + 6 * 8, 3);
    store64(t + 7 * 8, 10);
    store64(t + 8 * 8, 17);
    store64(t + 9 * 8, 24);
    store64(t + 10 * 8, 32);
    store64(t + 11 * 8, 25);
    store64(t + 12 * 8, 18);
    store64(t + 13 * 8, 11);
    store64(t + 14 * 8, 4);
    store64(t + 15 * 8, 5);
    store64(t + 16 * 8, 12);
    store64(t + 17 * 8, 19);
    store64(t + 18 * 8, 26);
    store64(t + 19 * 8, 33);
    store64(t + 20 * 8, 40);
    store64(t + 21 * 8, 48);
    store64(t + 22 * 8, 41);
    store64(t + 23 * 8, 34);
    store64(t + 24 * 8, 27);
    store64(t + 25 * 8, 20);
    store64(t + 26 * 8, 13);
    store64(t + 27 * 8, 6);
    store64(t + 28 * 8, 7);
    store64(t + 29 * 8, 14);
    store64(t + 30 * 8, 21);
    store64(t + 31 * 8, 28);
    store64(t + 32 * 8, 35);
    store64(t + 33 * 8, 42);
    store64(t + 34 * 8, 49);
    store64(t + 35 * 8, 56);
    store64(t + 36 * 8, 57);
    store64(t + 37 * 8, 50);
    store64(t + 38 * 8, 43);
    store64(t + 39 * 8, 36);
    store64(t + 40 * 8, 29);
    store64(t + 41 * 8, 22);
    store64(t + 42 * 8, 15);
    store64(t + 43 * 8, 23);
    store64(t + 44 * 8, 30);
    store64(t + 45 * 8, 37);
    store64(t + 46 * 8, 44);
    store64(t + 47 * 8, 51);
    store64(t + 48 * 8, 58);
    store64(t + 49 * 8, 59);
    store64(t + 50 * 8, 52);
    store64(t + 51 * 8, 45);
    store64(t + 52 * 8, 38);
    store64(t + 53 * 8, 31);
    store64(t + 54 * 8, 39);
    store64(t + 55 * 8, 46);
    store64(t + 56 * 8, 53);
    store64(t + 57 * 8, 60);
    store64(t + 58 * 8, 61);
    store64(t + 59 * 8, 54);
    store64(t + 60 * 8, 47);
    store64(t + 61 * 8, 55);
    store64(t + 62 * 8, 62);
    store64(t + 63 * 8, 63);
    _jpeg_zz_ptr = t;
    return t;
}

# DESCALE: round-to-nearest division by 2^n, symmetric about zero (works for
# negatives despite the logical `>>`). n >= 1.
fn _jpeg_descale(x, n): i64 {
    var half = 1 << (n - 1);
    var div = 1 << n;
    if (x >= 0) { return (x + half) / div; }
    return 0 - ((0 - x + half) / div);
}

# Final per-output store: descale, and (pass 2 only) level-shift +128 + clamp.
fn _jpeg_idct_out(addr, val, shift, do_ls): i64 {
    var d = _jpeg_descale(val, shift);
    if (do_ls == 1) {
        d = d + 128;
        if (d < 0) { d = 0; }
        if (d > 255) { d = 255; }
    }
    store64(addr, d);
    return 0;
}

# One 1-D inverse DCT stage over 8 values at inp + i*istep, writing 8 results to
# outp + j*ostep (steps in bytes). `shift` is the descale; `do_ls` enables the
# pass-2 level-shift + clamp. Identical butterfly for both passes (the islow form).
fn _jpeg_idct_1d(inp, istep, outp, ostep, shift, do_ls): i64 {
    var s0 = load64(inp + 0 * istep);
    var s1 = load64(inp + 1 * istep);
    var s2 = load64(inp + 2 * istep);
    var s3 = load64(inp + 3 * istep);
    var s4 = load64(inp + 4 * istep);
    var s5 = load64(inp + 5 * istep);
    var s6 = load64(inp + 6 * istep);
    var s7 = load64(inp + 7 * istep);

    # even part
    var z1 = (s2 + s6) * FIX_0_541196100;
    var tmp2 = z1 - s6 * FIX_1_847759065;
    var tmp3 = z1 + s2 * FIX_0_765366865;
    var tmp0 = (s0 + s4) * 8192;
    var tmp1 = (s0 - s4) * 8192;
    var tmp10 = tmp0 + tmp3;
    var tmp13 = tmp0 - tmp3;
    var tmp11 = tmp1 + tmp2;
    var tmp12 = tmp1 - tmp2;

    # odd part
    var o0 = s7;
    var o1 = s5;
    var o2 = s3;
    var o3 = s1;
    var oz1 = o0 + o3;
    var oz2 = o1 + o2;
    var oz3 = o0 + o2;
    var oz4 = o1 + o3;
    var oz5 = (oz3 + oz4) * FIX_1_175875602;
    o0 = o0 * FIX_0_298631336;
    o1 = o1 * FIX_2_053119869;
    o2 = o2 * FIX_3_072711026;
    o3 = o3 * FIX_1_501321110;
    oz1 = 0 - (oz1 * FIX_0_899976223);
    oz2 = 0 - (oz2 * FIX_2_562915447);
    oz3 = 0 - (oz3 * FIX_1_961570560);
    oz4 = 0 - (oz4 * FIX_0_390180644);
    oz3 = oz3 + oz5;
    oz4 = oz4 + oz5;
    o0 = o0 + oz1 + oz3;
    o1 = o1 + oz2 + oz4;
    o2 = o2 + oz2 + oz3;
    o3 = o3 + oz1 + oz4;

    _jpeg_idct_out(outp + 0 * ostep, tmp10 + o3, shift, do_ls);
    _jpeg_idct_out(outp + 7 * ostep, tmp10 - o3, shift, do_ls);
    _jpeg_idct_out(outp + 1 * ostep, tmp11 + o2, shift, do_ls);
    _jpeg_idct_out(outp + 6 * ostep, tmp11 - o2, shift, do_ls);
    _jpeg_idct_out(outp + 2 * ostep, tmp12 + o1, shift, do_ls);
    _jpeg_idct_out(outp + 5 * ostep, tmp12 - o1, shift, do_ls);
    _jpeg_idct_out(outp + 3 * ostep, tmp13 + o0, shift, do_ls);
    _jpeg_idct_out(outp + 4 * ostep, tmp13 - o0, shift, do_ls);
    return 0;
}

# ================================================================
# _jpeg_idct_block — dequantize + de-zig-zag `zz` (64 i64, zig-zag order) with
# `quant` (64 i64, zig-zag order) into a natural-order block, run the 2-D IDCT,
# and write 64 level-shifted clamped samples (0..255) to `out` (64 i64,
# row-major). The arrays `zz`/`quant`/`out` are caller-owned.
# ================================================================
fn _jpeg_idct_block(zz, quant, out): i64 {
    var zztab = _jpeg_zigzag_table();
    var coef[512];   # 64 i64, natural order
    var ws[512];     # 64 i64, pass-1 workspace
    var k = 0;
    var nat = 0;
    while (k < 64) {
        nat = load64(zztab + k * 8);
        store64(&coef + nat * 8, load64(zz + k * 8) * load64(quant + k * 8));
        k = k + 1;
    }
    var c = 0;
    while (c < 8) {
        _jpeg_idct_1d(&coef + c * 8, 64, &ws + c * 8, 64, 11, 0);
        c = c + 1;
    }
    var r = 0;
    while (r < 8) {
        _jpeg_idct_1d(&ws + r * 64, 8, out + r * 64, 8, 18, 1);
        r = r + 1;
    }
    return 0;
}

# --- jpeg_markers.cyr ---

# @internal — JPEG (JFIF/EXIF) baseline marker + segment framing (0.3.0).
# jpeg_markers.cyr — turn untrusted JPEG bytes into a validated marker walk and
# a parsed ChitraJpegFrame. This is the JPEG analog of png_chunks.cyr: it reuses
# the bounds-checked byte cursor (_cur_* in png_chunks.cyr, incl. _cur_u16_be for
# JPEG's 2-byte big-endian segment lengths, ITU-T T.81 § B.1). Every read is
# validated against len BEFORE the access.
#
# Scope so far:
#   bite 1 — signature (SOI 0xFFD8), the marker/segment walk up to SOS, reject
#            every non-baseline mode with a distinct error.
#   bite 2 — parse SOF0 component specs (id / H / V / quant-selector, max H/V)
#            and DQT quantization tables, with the sampling-factor security
#            guards (Hi,Vi in 1..4 — reject 0 per CVE-2018-11212; reject
#            duplicate component ids; ΣHi·Vi ≤ 10).
#   bite 3 — parse DHT and build canonical Huffman decode tables (via
#            jpeg_huffman.cyr) into frame storage (4 DC + 4 AC).
# APPn / COM / DNL payloads are skipped here; DRI sets the restart interval.
# See docs/adr/0004-jpeg-decode-model.md + docs/proposals/jpeg-baseline-decoder.md.
#
# JPEG marker legend (the byte after a 0xFF; ITU-T T.81 Table B.1):
#   D8 SOI  D9 EOI  DA SOS  DB DQT  DC DNL  DD DRI  FE COM  E0..EF APPn
#   C0 SOF0(baseline)  C1 SOF1(ext-seq)  C2 SOF2(progressive)  C3 SOF3(lossless)
#   C4 DHT  C5..C7 differential  C9..CB arithmetic SOF  CC DAC
#   CD..CF differential arithmetic  D0..D7 RSTn  01 TEM (all standalone)

# ================================================================
# Baseline ceilings (validated before any allocation depends on them).
# ================================================================
var CHITRA_MAX_COMPONENTS     = 4;    # baseline accepts 1 or 3; this caps the field
var CHITRA_MAX_SAMP_FACTOR    = 4;    # Hi, Vi each in 1..4 (T.81 § B.2.2)
var CHITRA_MAX_BLOCKS_PER_MCU = 10;   # ΣHi·Vi ≤ 10 data units per MCU (T.81 § A.2.2)
var CHITRA_MAX_QUANT_TABLES   = 4;    # Tq in 0..3
var CHITRA_MAX_HUFF_TABLES    = 4;    # Th in 0..3 (per class)

# ================================================================
# ChitraJpegFrame — the marker-walk handoff record (internal). Filled by the
# scan; later bites (restart interval, scan selectors) extend it.
# CHITRA_JPEG_FRAME_SIZE reserves room so the alloc size is stable as fields
# are added across the 0.3.0 arc.
#   +0   width            (i64 — pixels)
#   +8   height           (i64 — pixels)
#   +16  precision        (i64 — sample bits; 8 only in 0.3.0)
#   +24  num_components    (i64 — 1 grayscale or 3 YCbCr)
#   +32  seen_sof          (i64 — 1 once a valid SOF0 has been parsed)
#   +40  max_h            (i64 — max horizontal sampling factor across components)
#   +48  max_v            (i64 — max vertical sampling factor)
#   +56  restart_interval (i64 — DRI MCUs between RSTn; 0 = none; bite 7)
#   +64  quant            (ptr — 4*64 i64 quant-table storage, zig-zag order)
#   +72  quant_present    (i64 — bitmask of quant tables seen, bit Tq)
#   +80  sos_offset       (i64 — byte offset of the SOS length field)
#   +88  huff             (ptr — 8 HuffTable records: slots 0..3 DC, 4..7 AC)
#   +96  huff_present     (i64 — bitmask of Huffman tables seen, bit Tc*4+Th)
#   +104 components       (4 × 48-byte specs: +0 id, +8 H, +16 V, +24 Tq,
#                          +32 Td, +40 Ta [Td/Ta filled at SOS])
# ================================================================
var JF_WIDTH            = 0;
var JF_HEIGHT           = 8;
var JF_PRECISION        = 16;
var JF_NCOMP            = 24;
var JF_SEEN_SOF         = 32;
var JF_MAX_H            = 40;
var JF_MAX_V            = 48;
var JF_RESTART_INTERVAL = 56;
var JF_QUANT            = 64;
var JF_QUANT_PRESENT    = 72;
var JF_SOS_OFFSET       = 80;    # byte offset of the SOS length field (set at SOS)
var JF_HUFF             = 88;    # ptr to 8 HuffTable records (slots 0..3 DC, 4..7 AC)
var JF_HUFF_PRESENT     = 96;    # bitmask of Huffman tables seen (bit = class*4 + id)
var JF_COMP             = 104;   # 4 × 48-byte component specs
var JF_COMP_STRIDE      = 48;
var JF_COMP_ID          = 0;     # SOF fields
var JF_COMP_H           = 8;
var JF_COMP_V           = 16;
var JF_COMP_TQ          = 24;
var JF_COMP_TD          = 32;    # SOS scan fields: DC Huffman table selector
var JF_COMP_TA          = 40;    #                  AC Huffman table selector
var CHITRA_JPEG_FRAME_SIZE = 320;

fn chitra_jpeg_frame_width(f): i64          { return load64(f + JF_WIDTH); }
fn chitra_jpeg_frame_height(f): i64         { return load64(f + JF_HEIGHT); }
fn chitra_jpeg_frame_precision(f): i64      { return load64(f + JF_PRECISION); }
fn chitra_jpeg_frame_num_components(f): i64 { return load64(f + JF_NCOMP); }
fn chitra_jpeg_frame_seen_sof(f): i64       { return load64(f + JF_SEEN_SOF); }
fn chitra_jpeg_frame_max_h(f): i64          { return load64(f + JF_MAX_H); }
fn chitra_jpeg_frame_max_v(f): i64          { return load64(f + JF_MAX_V); }
fn chitra_jpeg_frame_restart_interval(f): i64 { return load64(f + JF_RESTART_INTERVAL); }
fn chitra_jpeg_frame_quant_present(f): i64  { return load64(f + JF_QUANT_PRESENT); }
fn chitra_jpeg_frame_huff_present(f): i64   { return load64(f + JF_HUFF_PRESENT); }

# Per-component accessors. `i` is the component index (0..num_components-1).
fn chitra_jpeg_frame_comp_id(f, i): i64 { return load64(f + JF_COMP + i * JF_COMP_STRIDE + JF_COMP_ID); }
fn chitra_jpeg_frame_comp_h(f, i): i64  { return load64(f + JF_COMP + i * JF_COMP_STRIDE + JF_COMP_H); }
fn chitra_jpeg_frame_comp_v(f, i): i64  { return load64(f + JF_COMP + i * JF_COMP_STRIDE + JF_COMP_V); }
fn chitra_jpeg_frame_comp_tq(f, i): i64 { return load64(f + JF_COMP + i * JF_COMP_STRIDE + JF_COMP_TQ); }
# Scan (SOS) table selectors, filled by _jpeg_parse_sos.
fn chitra_jpeg_frame_comp_td(f, i): i64 { return load64(f + JF_COMP + i * JF_COMP_STRIDE + JF_COMP_TD); }
fn chitra_jpeg_frame_comp_ta(f, i): i64 { return load64(f + JF_COMP + i * JF_COMP_STRIDE + JF_COMP_TA); }
fn chitra_jpeg_frame_sos_offset(f): i64  { return load64(f + JF_SOS_OFFSET); }

# Quant-table entry t (0..3), zig-zag position k (0..63). De-zig-zag happens at
# dequant time (bite 5); this stores the raw spec order.
fn chitra_jpeg_frame_quant(f, t, k): i64 {
    return load64(load64(f + JF_QUANT) + (t * 64 + k) * 8);
}

# HuffTable ptr for class (0=DC, 1=AC) and id (0..3). The HuffTable layout +
# accessors (_jpeg_huff_*) live in jpeg_huffman.cyr.
fn chitra_jpeg_frame_huff(f, class, id): i64 {
    return load64(f + JF_HUFF) + (class * 4 + id) * HT_SIZE;
}

# Bump-allocator no-op (matches chitra_raw_free / chitra_image_free). Safe on 0.
fn chitra_jpeg_frame_free(f): i64 { return 0; }

# ================================================================
# Signature — every JPEG starts with SOI = 0xFF 0xD8 (T.81 § B.2.1).
# ================================================================
fn chitra_jpeg_check_signature(src, len): i64 {
    if (len < 2) { return 0; }
    if (load8(src) != 0xFF) { return 0; }
    if (load8(src + 1) != 0xD8) { return 0; }
    return 1;
}

# ================================================================
# Marker classifier. Returns an ACTION (1=SOF0/parse, 2=SOS/stop,
# 3=standalone/no-length, 4=length-bearing/skip, 5=DQT/parse, 6=DHT/parse,
# 7=DRI/parse) or a CHITRA_ERR_* reject code (>=13) for any non-baseline mode.
# Action values 1..7 never collide with the JPEG error codes (13..23).
# ================================================================
fn _jpeg_marker_action(m): i64 {
    if (m == 0xC0) { return 1; }                          # SOF0 baseline — parse
    if (m == 0xDA) { return 2; }                          # SOS — end of header scan
    if (m == 0xDB) { return 5; }                          # DQT — parse
    if (m == 0xC4) { return 6; }                          # DHT — parse
    if (m == 0xDD) { return 7; }                          # DRI — parse restart interval
    if (m == 0xC2) { return CHITRA_ERR_JPEG_PROGRESSIVE; }
    if (m == 0xC9) { return CHITRA_ERR_JPEG_ARITHMETIC; } # SOF9 ext-seq arithmetic
    if (m == 0xCA) { return CHITRA_ERR_JPEG_ARITHMETIC; } # SOF10 progressive arithmetic
    if (m == 0xCB) { return CHITRA_ERR_JPEG_ARITHMETIC; } # SOF11 lossless arithmetic
    if (m == 0xCC) { return CHITRA_ERR_JPEG_ARITHMETIC; } # DAC
    if (m == 0xC1) { return CHITRA_ERR_JPEG_MODE; }       # SOF1 extended sequential
    if (m == 0xC3) { return CHITRA_ERR_JPEG_MODE; }       # SOF3 lossless
    if (m == 0xC5) { return CHITRA_ERR_JPEG_MODE; }       # SOF5 differential sequential
    if (m == 0xC6) { return CHITRA_ERR_JPEG_MODE; }       # SOF6 differential progressive
    if (m == 0xC7) { return CHITRA_ERR_JPEG_MODE; }       # SOF7 differential lossless
    if (m == 0xCD) { return CHITRA_ERR_JPEG_MODE; }       # SOF13 differential seq arithmetic
    if (m == 0xCE) { return CHITRA_ERR_JPEG_MODE; }       # SOF14 differential prog arithmetic
    if (m == 0xCF) { return CHITRA_ERR_JPEG_MODE; }       # SOF15 differential lossless arithmetic
    if (m == 0xD9) { return CHITRA_ERR_JPEG_MARKER; }     # EOI before SOS — no scan present
    if (m >= 0xD0 && m <= 0xD7) { return 3; }             # RSTn standalone
    if (m == 0x01) { return 3; }                          # TEM standalone
    return 4;   # APPn / COM / DNL / ... — length-bearing, skipped (not decoded)
}

# ================================================================
# Parse a DQT segment (T.81 § B.2.4). Cursor is at the 2-byte length field.
# A DQT may carry multiple tables. Baseline allows 8-bit precision only (Pq=0).
# Values are stored in spec (zig-zag) order; de-zig-zag is deferred to dequant.
# Returns 0 on success, or a CHITRA_ERR_* code.
# ================================================================
fn _jpeg_parse_dqt(cur, frame): i64 {
    if (_cur_can_read(cur, 2) == 0) { return CHITRA_ERR_TRUNCATED; }
    var seglen = _cur_u16_be(cur);
    if (seglen < 2) { return CHITRA_ERR_JPEG_DQT; }
    var remaining = seglen - 2;
    if (_cur_can_read(cur, remaining) == 0) { return CHITRA_ERR_TRUNCATED; }
    var quant = load64(frame + JF_QUANT);
    var rc = 0;
    var done = 0;
    var pqtq = 0;
    var pq = 0;
    var tq = 0;
    var k = 0;
    var v = 0;
    var present = 0;
    while (done == 0) {
        if (remaining <= 0) { done = 1; }
        if (done == 0) {
            pqtq = _cur_u8(cur);
            remaining = remaining - 1;
            pq = (pqtq >> 4) & 15;
            tq = pqtq & 15;
            if (pq != 0) { rc = CHITRA_ERR_JPEG_DQT; done = 1; }     # 8-bit only (baseline)
            if (done == 0) {
                if (tq >= CHITRA_MAX_QUANT_TABLES) { rc = CHITRA_ERR_JPEG_DQT; done = 1; }
            }
            if (done == 0) {
                if (remaining < 64) { rc = CHITRA_ERR_JPEG_DQT; done = 1; }
            }
            if (done == 0) {
                k = 0;
                while (k < 64) {
                    v = _cur_u8(cur);
                    store64(quant + (tq * 64 + k) * 8, v);
                    k = k + 1;
                }
                remaining = remaining - 64;
                present = load64(frame + JF_QUANT_PRESENT);
                present = present | (1 << tq);
                store64(frame + JF_QUANT_PRESENT, present);
            }
        }
    }
    return rc;
}

# ================================================================
# Parse a DHT segment (T.81 § B.2.4.2). Cursor is at the 2-byte length field.
# A DHT may carry multiple tables; each is Tc/Th (class/id) + 16 BITS counts +
# Σcounts symbol bytes. Validates Tc in {0,1}, Th < 4, Σcounts ≤ 256 and
# in-bounds, then builds the canonical decode table (jpeg_huffman.cyr) into the
# frame's storage (slot = Tc*4 + Th). Returns 0 on success or a CHITRA_ERR_* code.
# ================================================================
fn _jpeg_parse_dht(cur, frame): i64 {
    if (_cur_can_read(cur, 2) == 0) { return CHITRA_ERR_TRUNCATED; }
    var seglen = _cur_u16_be(cur);
    if (seglen < 2) { return CHITRA_ERR_JPEG_DHT; }
    var remaining = seglen - 2;
    if (_cur_can_read(cur, remaining) == 0) { return CHITRA_ERR_TRUNCATED; }
    var huff = load64(frame + JF_HUFF);
    var bits[136];           # 17 i64 (index 1..16 = BITS counts)
    var rc = 0;
    var done = 0;
    var tcth = 0;
    var tc = 0;
    var th = 0;
    var total = 0;
    var L = 0;
    var cnt = 0;
    var slot = 0;
    var table = 0;
    var i = 0;
    var v = 0;
    var present = 0;
    while (done == 0) {
        if (remaining <= 0) { done = 1; }
        if (done == 0) {
            # each table header is 1 (Tc/Th) + 16 (BITS) bytes minimum
            if (remaining < 17) { rc = CHITRA_ERR_JPEG_DHT; done = 1; }
        }
        if (done == 0) {
            tcth = _cur_u8(cur);
            remaining = remaining - 1;
            tc = (tcth >> 4) & 15;
            th = tcth & 15;
            if (tc > 1) { rc = CHITRA_ERR_JPEG_DHT; done = 1; }      # class 0=DC, 1=AC
            if (done == 0) {
                if (th >= CHITRA_MAX_HUFF_TABLES) { rc = CHITRA_ERR_JPEG_DHT; done = 1; }
            }
        }
        if (done == 0) {
            total = 0;
            L = 1;
            while (L <= 16) {
                cnt = _cur_u8(cur);
                store64(&bits + L * 8, cnt);
                total = total + cnt;
                L = L + 1;
            }
            remaining = remaining - 16;
            if (total > 256) { rc = CHITRA_ERR_JPEG_DHT; done = 1; }
        }
        if (done == 0) {
            if (remaining < total) { rc = CHITRA_ERR_JPEG_DHT; done = 1; }
        }
        if (done == 0) {
            slot = tc * 4 + th;
            table = huff + slot * HT_SIZE;
            store64(table + HT_COUNT, total);
            i = 0;
            while (i < total) {
                v = _cur_u8(cur);
                store64(table + HT_HUFFVAL + i * 8, v);
                i = i + 1;
            }
            remaining = remaining - total;
            rc = _jpeg_huff_build(table, &bits);
            if (rc != 0) { done = 1; }
            if (done == 0) {
                present = load64(frame + JF_HUFF_PRESENT);
                present = present | (1 << slot);
                store64(frame + JF_HUFF_PRESENT, present);
            }
        }
    }
    return rc;
}

# ================================================================
# Parse a DRI segment (T.81 § B.2.4.4): Lr(2) Ri(2). Sets the restart interval
# (number of MCUs between RSTn markers; 0 disables). Returns 0 or a CHITRA_ERR_*.
# ================================================================
fn _jpeg_parse_dri(cur, frame): i64 {
    if (_cur_can_read(cur, 2) == 0) { return CHITRA_ERR_TRUNCATED; }
    var seglen = _cur_u16_be(cur);
    if (seglen != 4) { return CHITRA_ERR_JPEG_MARKER; }
    if (_cur_can_read(cur, 2) == 0) { return CHITRA_ERR_TRUNCATED; }
    store64(frame + JF_RESTART_INTERVAL, _cur_u16_be(cur));
    return 0;
}

# ================================================================
# Parse a SOF0 segment (T.81 § B.2.2): Lf(2) P(1) Y(2) X(2) Nf(1) then Nf*3
# component specs (Ci, Hi/Vi packed, Tqi). Cursor is at the 2-byte length.
# Validates precision, component count, dimensions, sampling factors (1..4,
# reject 0 → CVE-2018-11212 div-by-zero), duplicate component ids, and
# ΣHi·Vi ≤ 10. Returns 0 on success (frame filled) or a CHITRA_ERR_* code.
# ================================================================
fn _jpeg_parse_sof0(cur, frame): i64 {
    if (_cur_can_read(cur, 2) == 0) { return CHITRA_ERR_TRUNCATED; }
    var seglen = _cur_u16_be(cur);
    if (seglen < 11) { return CHITRA_ERR_JPEG_SOF; }      # 8 + 3*1 minimum
    if (_cur_can_read(cur, seglen - 2) == 0) { return CHITRA_ERR_TRUNCATED; }
    var precision = _cur_u8(cur);
    var height = _cur_u16_be(cur);
    var width = _cur_u16_be(cur);
    var ncomp = _cur_u8(cur);
    if (precision != 8) { return CHITRA_ERR_JPEG_PRECISION; }
    if (ncomp != 1 && ncomp != 3) { return CHITRA_ERR_JPEG_COMPONENTS; }
    # Y==0 (DNL-deferred height) is rejected, never decoded with a 0-height
    # buffer — see docs/adr/0004 scope.
    if (width == 0 || height == 0) { return CHITRA_ERR_DIMENSIONS; }
    if (width > CHITRA_MAX_DIM || height > CHITRA_MAX_DIM) { return CHITRA_ERR_DIMENSIONS; }
    if (width * height > CHITRA_MAX_PIXELS) { return CHITRA_ERR_DIMENSIONS; }
    if (seglen != 8 + 3 * ncomp) { return CHITRA_ERR_JPEG_SOF; }

    var rc = 0;
    var done = 0;
    var i = 0;
    var cid = 0;
    var hv = 0;
    var ch = 0;
    var cv = 0;
    var ctq = 0;
    var max_h = 1;
    var max_v = 1;
    var blocks = 0;
    var j = 0;
    var dup = 0;
    var base = 0;
    while (done == 0) {
        if (i >= ncomp) { done = 1; }
        if (done == 0) {
            cid = _cur_u8(cur);
            hv = _cur_u8(cur);
            ctq = _cur_u8(cur);
            ch = (hv >> 4) & 15;
            cv = hv & 15;
            if (ch < 1 || ch > CHITRA_MAX_SAMP_FACTOR) { rc = CHITRA_ERR_JPEG_SOF; done = 1; }
            if (done == 0) {
                if (cv < 1 || cv > CHITRA_MAX_SAMP_FACTOR) { rc = CHITRA_ERR_JPEG_SOF; done = 1; }
            }
            if (done == 0) {
                if (ctq >= CHITRA_MAX_QUANT_TABLES) { rc = CHITRA_ERR_JPEG_SOF; done = 1; }
            }
            if (done == 0) {
                # duplicate component id check against prior components
                dup = 0;
                j = 0;
                while (j < i) {
                    if (load64(frame + JF_COMP + j * JF_COMP_STRIDE + JF_COMP_ID) == cid) { dup = 1; }
                    j = j + 1;
                }
                if (dup == 1) { rc = CHITRA_ERR_JPEG_SOF; done = 1; }
            }
            if (done == 0) {
                base = JF_COMP + i * JF_COMP_STRIDE;
                store64(frame + base + JF_COMP_ID, cid);
                store64(frame + base + JF_COMP_H, ch);
                store64(frame + base + JF_COMP_V, cv);
                store64(frame + base + JF_COMP_TQ, ctq);
                if (ch > max_h) { max_h = ch; }
                if (cv > max_v) { max_v = cv; }
                blocks = blocks + ch * cv;
                i = i + 1;
            }
        }
    }
    if (rc != 0) { return rc; }
    if (blocks > CHITRA_MAX_BLOCKS_PER_MCU) { return CHITRA_ERR_JPEG_SOF; }
    store64(frame + JF_WIDTH, width);
    store64(frame + JF_HEIGHT, height);
    store64(frame + JF_PRECISION, precision);
    store64(frame + JF_NCOMP, ncomp);
    store64(frame + JF_MAX_H, max_h);
    store64(frame + JF_MAX_V, max_v);
    store64(frame + JF_SEEN_SOF, 1);
    return 0;
}

# ================================================================
# chitra_jpeg_scan_markers — validate the JPEG marker structure from SOI up to
# SOS, parsing DQT/DHT tables and the SOF0 frame header and rejecting
# non-baseline modes. Returns a ChitraJpegFrame ptr (caller-owned) on success,
# or 0 with *err_out set to a ChitraErr. Mirrors the (ptr, err_out) split.
#
# The walk always advances >= 2 bytes per iteration (the FF + marker code) or
# terminates on the can_read(2) gate, so it cannot loop forever on bad input.
# ================================================================
fn chitra_jpeg_scan_markers(src, len, err_out): i64 {
    store64(err_out, 0);
    if (chitra_jpeg_check_signature(src, len) == 0) {
        store64(err_out, chitra_err(CHITRA_ERR_SIGNATURE));
        return 0;
    }
    var frame = alloc(CHITRA_JPEG_FRAME_SIZE);
    if (frame == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    store64(frame + JF_WIDTH, 0);
    store64(frame + JF_HEIGHT, 0);
    store64(frame + JF_PRECISION, 0);
    store64(frame + JF_NCOMP, 0);
    store64(frame + JF_SEEN_SOF, 0);
    store64(frame + JF_MAX_H, 0);
    store64(frame + JF_MAX_V, 0);
    store64(frame + JF_RESTART_INTERVAL, 0);
    store64(frame + JF_QUANT_PRESENT, 0);
    store64(frame + JF_HUFF_PRESENT, 0);
    store64(frame + JF_SOS_OFFSET, 0);
    var quant = alloc(CHITRA_MAX_QUANT_TABLES * 64 * 8);
    if (quant == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    store64(frame + JF_QUANT, quant);
    var z = 0;
    while (z < CHITRA_MAX_QUANT_TABLES * 64) {
        store64(quant + z * 8, 0);
        z = z + 1;
    }
    var huff = alloc(8 * HT_SIZE);
    if (huff == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    store64(frame + JF_HUFF, huff);

    var cur[24];
    _cur_init(&cur, src, len);
    _cur_skip(&cur, 2);   # past SOI

    var done = 0;
    var rc = 0;
    var b = 0;
    var m = 0;
    var act = 0;
    var seglen = 0;
    var fill_done = 0;

    while (done == 0) {
        if (_cur_can_read(&cur, 2) == 0) { rc = CHITRA_ERR_JPEG_MARKER; done = 1; }
        if (done == 0) {
            b = _cur_u8(&cur);
            if (b != 0xFF) { rc = CHITRA_ERR_JPEG_MARKER; done = 1; }
        }
        if (done == 0) {
            m = _cur_u8(&cur);
            # collapse a run of fill 0xFF bytes before the marker code
            fill_done = 0;
            while (fill_done == 0) {
                if (m != 0xFF) { fill_done = 1; }
                if (m == 0xFF) {
                    if (_cur_can_read(&cur, 1) == 0) { fill_done = 1; }
                    if (_cur_can_read(&cur, 1) == 1) { m = _cur_u8(&cur); }
                }
            }
            if (m == 0xFF) { rc = CHITRA_ERR_JPEG_MARKER; done = 1; }
        }
        if (done == 0) {
            act = _jpeg_marker_action(m);
            if (act >= 13) { rc = act; done = 1; }
            if (act == 1) {
                if (load64(frame + JF_SEEN_SOF) == 1) { rc = CHITRA_ERR_JPEG_SOF; done = 1; }
                if (done == 0) {
                    rc = _jpeg_parse_sof0(&cur, frame);
                    if (rc != 0) { done = 1; }
                }
            }
            if (act == 5) {
                rc = _jpeg_parse_dqt(&cur, frame);
                if (rc != 0) { done = 1; }
            }
            if (act == 6) {
                rc = _jpeg_parse_dht(&cur, frame);
                if (rc != 0) { done = 1; }
            }
            if (act == 7) {
                rc = _jpeg_parse_dri(&cur, frame);
                if (rc != 0) { done = 1; }
            }
            if (act == 2) {
                if (load64(frame + JF_SEEN_SOF) == 0) { rc = CHITRA_ERR_JPEG_SOF; }
                if (rc == 0) { store64(frame + JF_SOS_OFFSET, _cur_pos(&cur)); }
                done = 1;   # SOS reached; entropy data follows (decoded by jpeg.cyr)
            }
            if (act == 4) {
                if (_cur_can_read(&cur, 2) == 0) { rc = CHITRA_ERR_TRUNCATED; done = 1; }
                if (done == 0) {
                    seglen = _cur_u16_be(&cur);
                    if (seglen < 2) { rc = CHITRA_ERR_JPEG_MARKER; done = 1; }
                }
                if (done == 0) {
                    if (_cur_can_read(&cur, seglen - 2) == 0) { rc = CHITRA_ERR_TRUNCATED; done = 1; }
                }
                if (done == 0) { _cur_skip(&cur, seglen - 2); }
            }
            # act == 3 (standalone marker): nothing to skip, loop continues
        }
    }

    if (rc != 0) {
        store64(err_out, chitra_err(rc));
        return 0;
    }
    return frame;
}

# --- jpeg.cyr ---

# @public — chitra JPEG decoder: JPEG bytes -> canonical RGBA8 (0.3.0).
# jpeg.cyr — the public decode entry. Wires the marker scan (jpeg_markers),
# the SOS scan header, the entropy/IDCT block pipeline (jpeg_huffman + jpeg_idct),
# and the color pass into a ChitraImage (the same 48-byte result PNG produces).
#
# Scope (bite 7): baseline JFIF — grayscale (1 component) and YCbCr (3) with
# arbitrary chroma subsampling (4:4:4 / 4:2:2 / 4:2:0 / general Hi,Vi), box
# upsampling, and DRI/RSTn restart markers. The result is the shared ChitraImage
# (offsets from png.cyr); source_color_type carries a JPEG sentinel
# (0x100 | num_components) so a consumer's PNG 0/2/3/4/6 switch never aliases it
# (ADR 0003 / review).

# ================================================================
# YCbCr -> RGB color conversion (JFIF full-range, ITU-R BT.601). Fixed-point
# with SCALEBITS=16, the libjpeg jdcolor constants:
#   R = Y                         + 1.40200*(Cr-128)
#   G = Y - 0.34414*(Cb-128)      - 0.71414*(Cr-128)
#   B = Y + 1.77200*(Cb-128)
# Descale uses the IDCT's signed round-to-nearest _jpeg_descale (Cyrius `>>` is
# logical). Source: libjpeg jdcolor.c; ITU-R BT.601. See docs/sources.md.
# ================================================================
var JCC_CR_R = 91881;    # FIX(1.40200)
var JCC_CB_B = 116130;   # FIX(1.77200)
var JCC_CB_G = 22554;    # FIX(0.34414)
var JCC_CR_G = 46802;    # FIX(0.71414)

fn _jpeg_clamp8(v): i64 {
    if (v < 0) { return 0; }
    if (v > 255) { return 255; }
    return v;
}

# Convert one YCbCr triple to RGB, writing 3 bytes (R, G, B) at dst.
fn _jpeg_ycc_to_rgb(y, cb, cr, dst): i64 {
    var crr = cr - 128;
    var cbb = cb - 128;
    var r = y + _jpeg_descale(JCC_CR_R * crr, 16);
    var g = y - _jpeg_descale(JCC_CB_G * cbb + JCC_CR_G * crr, 16);
    var b = y + _jpeg_descale(JCC_CB_B * cbb, 16);
    store8(dst + 0, _jpeg_clamp8(r));
    store8(dst + 1, _jpeg_clamp8(g));
    store8(dst + 2, _jpeg_clamp8(b));
    return 0;
}

# ================================================================
# Parse the SOS scan header (T.81 § B.2.3) at frame.sos_offset (the 2-byte Ls
# field). Validates the scan against the frame, records each component's DC/AC
# Huffman selectors (Td/Ta), and enforces the baseline spectral selection
# (Ss=0, Se=63, Ah=Al=0). Returns the byte offset where the entropy-coded data
# begins, or 0 with *err_out set.
# ================================================================
fn _jpeg_parse_sos(frame, src, len, err_out): i64 {
    store64(err_out, 0);
    var cur[24];
    _cur_init(&cur, src, len);
    _cur_skip(&cur, chitra_jpeg_frame_sos_offset(frame));
    if (_cur_can_read(&cur, 3) == 0) { store64(err_out, chitra_err(CHITRA_ERR_TRUNCATED)); return 0; }
    var ls = _cur_u16_be(&cur);
    var ns = _cur_u8(&cur);
    var ncomp = chitra_jpeg_frame_num_components(frame);
    if (ns != ncomp) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_SOS)); return 0; }
    if (ls != 6 + 2 * ns) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_SOS)); return 0; }
    if (_cur_can_read(&cur, 2 * ns + 3) == 0) { store64(err_out, chitra_err(CHITRA_ERR_TRUNCATED)); return 0; }

    var rc = 0;
    var done = 0;
    var i = 0;
    var cs = 0;
    var tdta = 0;
    var td = 0;
    var ta = 0;
    var j = 0;
    var found = 0;
    var dupcs = 0;
    var seencs[32];
    while (done == 0) {
        if (i >= ns) { done = 1; }
        if (done == 0) {
            cs = _cur_u8(&cur);
            tdta = _cur_u8(&cur);
            td = (tdta >> 4) & 15;
            ta = tdta & 15;
            # duplicate component selector (Cs): each scan Cs must be distinct
            # (T.81 § B.2.3).
            dupcs = 0;
            j = 0;
            while (j < i) {
                if (load64(&seencs + j * 8) == cs) { dupcs = 1; }
                j = j + 1;
            }
            if (dupcs == 1) { rc = CHITRA_ERR_JPEG_SOS; done = 1; }
            if (done == 0) { store64(&seencs + i * 8, cs); }
            if (done == 0) {
                if (td >= CHITRA_MAX_HUFF_TABLES) { rc = CHITRA_ERR_JPEG_SOS; done = 1; }
            }
            if (done == 0) {
                if (ta >= CHITRA_MAX_HUFF_TABLES) { rc = CHITRA_ERR_JPEG_SOS; done = 1; }
            }
            if (done == 0) {
                found = 0;
                j = 0;
                while (j < ncomp) {
                    if (chitra_jpeg_frame_comp_id(frame, j) == cs) {
                        store64(frame + JF_COMP + j * JF_COMP_STRIDE + JF_COMP_TD, td);
                        store64(frame + JF_COMP + j * JF_COMP_STRIDE + JF_COMP_TA, ta);
                        found = 1;
                    }
                    j = j + 1;
                }
                if (found == 0) { rc = CHITRA_ERR_JPEG_SOS; done = 1; }
            }
            if (done == 0) { i = i + 1; }
        }
    }
    if (rc != 0) { store64(err_out, chitra_err(rc)); return 0; }

    var ss = _cur_u8(&cur);
    var se = _cur_u8(&cur);
    var ahal = _cur_u8(&cur);
    if (ss != 0) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_SOS)); return 0; }
    if (se != 63) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_SOS)); return 0; }
    if (ahal != 0) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_SOS)); return 0; }
    return _cur_pos(&cur);
}

# ================================================================
# Decode a baseline scan (1 or 3 components, any chroma subsampling) into a
# ChitraImage. The MCU is max_h x max_v data units wide/tall; each component i
# contributes Hi x Vi 8x8 blocks per MCU at its own (subsampled) plane
# resolution. After decode, each component plane is box-upsampled to full
# resolution and (for 3 components) converted YCbCr -> RGB. DRI/RSTn restart
# intervals reset the DC predictors and byte-align the entropy stream.
# Returns the ChitraImage ptr, or 0 with *err_out set.
# ================================================================
fn _jpeg_decode_scan(frame, src, len, entropy_start, err_out): i64 {
    var ncomp = chitra_jpeg_frame_num_components(frame);
    var w = chitra_jpeg_frame_width(frame);
    var h = chitra_jpeg_frame_height(frame);
    var max_h = chitra_jpeg_frame_max_h(frame);
    var max_v = chitra_jpeg_frame_max_v(frame);
    var mcu_w = 8 * max_h;
    var mcu_h = 8 * max_v;
    var mcu_cols = (w + mcu_w - 1) / mcu_w;
    var mcu_rows = (h + mcu_h - 1) / mcu_h;

    # per-component arrays (<= 3 components)
    var planes[32];
    var preds[32];
    var dctabs[32];
    var actabs[32];
    var quants[32];
    var comph[32];
    var compv[32];
    var comppw[32];

    var ci = 0;
    var td = 0;
    var ta = 0;
    var tq = 0;
    var chh = 0;
    var cvv = 0;
    var cpw = 0;
    var cph = 0;
    var pl = 0;
    var rc = 0;
    var done = 0;
    while (done == 0) {
        if (ci >= ncomp) { done = 1; }
        if (done == 0) {
            td = chitra_jpeg_frame_comp_td(frame, ci);
            ta = chitra_jpeg_frame_comp_ta(frame, ci);
            tq = chitra_jpeg_frame_comp_tq(frame, ci);
            chh = chitra_jpeg_frame_comp_h(frame, ci);
            cvv = chitra_jpeg_frame_comp_v(frame, ci);
            if ((chitra_jpeg_frame_huff_present(frame) & (1 << td)) == 0) { rc = CHITRA_ERR_JPEG_SOS; done = 1; }
            if (done == 0) {
                if ((chitra_jpeg_frame_huff_present(frame) & (1 << (4 + ta))) == 0) {
                    rc = CHITRA_ERR_JPEG_SOS;
                    done = 1;
                }
            }
            if (done == 0) {
                if ((chitra_jpeg_frame_quant_present(frame) & (1 << tq)) == 0) {
                    rc = CHITRA_ERR_JPEG_SOF;
                    done = 1;
                }
            }
            if (done == 0) {
                cpw = mcu_cols * chh * 8;
                cph = mcu_rows * cvv * 8;
                if (cpw * cph > CHITRA_MAX_RAW_BYTES) { rc = CHITRA_ERR_DIMENSIONS; done = 1; }
            }
            if (done == 0) {
                pl = alloc(cpw * cph);
                if (pl == 0) { rc = CHITRA_ERR_OOM; done = 1; }
            }
            if (done == 0) {
                store64(&planes + ci * 8, pl);
                store64(&preds + ci * 8, 0);
                store64(&dctabs + ci * 8, chitra_jpeg_frame_huff(frame, 0, td));
                store64(&actabs + ci * 8, chitra_jpeg_frame_huff(frame, 1, ta));
                store64(&quants + ci * 8, load64(frame + JF_QUANT) + tq * 64 * 8);
                store64(&comph + ci * 8, chh);
                store64(&compv + ci * 8, cvv);
                store64(&comppw + ci * 8, cpw);
                ci = ci + 1;
            }
        }
    }
    if (rc != 0) { store64(err_out, chitra_err(rc)); return 0; }
    done = 0;

    var ri = chitra_jpeg_frame_restart_interval(frame);
    var reader[48];
    _jpeg_br_init(&reader, src + entropy_start, len - entropy_start);
    var zz = alloc(512);
    var out = alloc(512);
    if (zz == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    if (out == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }

    var mcu_count = mcu_cols * mcu_rows;
    var mi = 0;
    var mcu_x = 0;
    var mcu_y = 0;
    var comp = 0;
    var by = 0;
    var bx = 0;
    var ch2 = 0;
    var cv2 = 0;
    var cpw2 = 0;
    var dctab = 0;
    var actab = 0;
    var quant = 0;
    var plane = 0;
    var pr = 0;
    var berr = 0;
    var px = 0;
    var py = 0;
    var r = 0;
    var c = 0;
    var rrc = 0;
    var k = 0;
    while (done == 0) {
        if (mi >= mcu_count) { done = 1; }
        if (done == 0) {
            if (ri > 0) {
                if (mi > 0) {
                    if ((mi % ri) == 0) {
                        rrc = _jpeg_br_restart(&reader);
                        if (rrc != 0) { store64(err_out, chitra_err(CHITRA_ERR_JPEG_ENTROPY)); done = 1; }
                        if (done == 0) {
                            k = 0;
                            while (k < ncomp) { store64(&preds + k * 8, 0); k = k + 1; }
                        }
                    }
                }
            }
        }
        if (done == 0) {
            mcu_x = mi % mcu_cols;
            mcu_y = mi / mcu_cols;
            comp = 0;
            while (comp < ncomp) {
                ch2 = load64(&comph + comp * 8);
                cv2 = load64(&compv + comp * 8);
                cpw2 = load64(&comppw + comp * 8);
                dctab = load64(&dctabs + comp * 8);
                actab = load64(&actabs + comp * 8);
                quant = load64(&quants + comp * 8);
                plane = load64(&planes + comp * 8);
                by = 0;
                while (by < cv2) {
                    bx = 0;
                    while (bx < ch2) {
                        pr = load64(&preds + comp * 8);
                        pr = _jpeg_decode_block(&reader, dctab, actab, pr, zz, &berr);
                        store64(&preds + comp * 8, pr);
                        if (load64(&berr) != 0) {
                            store64(err_out, load64(&berr));
                            done = 1;
                            bx = ch2;
                            by = cv2;
                            comp = ncomp;
                            mi = mcu_count;
                        }
                        if (done == 0) {
                            _jpeg_idct_block(zz, quant, out);
                            px = (mcu_x * ch2 + bx) * 8;
                            py = (mcu_y * cv2 + by) * 8;
                            r = 0;
                            while (r < 8) {
                                c = 0;
                                while (c < 8) {
                                    store8(plane + (py + r) * cpw2 + (px + c), load64(out + (r * 8 + c) * 8));
                                    c = c + 1;
                                }
                                r = r + 1;
                            }
                            bx = bx + 1;
                        }
                    }
                    if (done == 0) { by = by + 1; }
                }
                if (done == 0) { comp = comp + 1; }
            }
            if (done == 0) { mi = mi + 1; }
        }
    }
    if (load64(err_out) != 0) { return 0; }

    # ---- box upsample + color convert -> RGBA8 ----
    if (w * h * 4 > CHITRA_MAX_RAW_BYTES) { store64(err_out, chitra_err(CHITRA_ERR_DIMENSIONS)); return 0; }
    var rgba = alloc(w * h * 4);
    if (rgba == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    var p0 = load64(&planes + 0);
    var h0 = load64(&comph + 0);
    var v0 = load64(&compv + 0);
    var pw0 = load64(&comppw + 0);
    var p1 = 0;
    var p2 = 0;
    var h1 = 0;
    var v1 = 0;
    var pw1 = 0;
    var h2 = 0;
    var v2 = 0;
    var pw2 = 0;
    var y = 0;
    var x = 0;
    var o = 0;
    var yy = 0;
    var cb = 0;
    var cr = 0;
    if (ncomp == 1) {
        while (y < h) {
            x = 0;
            while (x < w) {
                yy = load8(p0 + (y * v0 / max_v) * pw0 + (x * h0 / max_h));
                o = (y * w + x) * 4;
                store8(rgba + o + 0, yy);
                store8(rgba + o + 1, yy);
                store8(rgba + o + 2, yy);
                store8(rgba + o + 3, 255);
                x = x + 1;
            }
            y = y + 1;
        }
    }
    if (ncomp == 3) {
        p1 = load64(&planes + 8);
        p2 = load64(&planes + 16);
        h1 = load64(&comph + 8);
        v1 = load64(&compv + 8);
        pw1 = load64(&comppw + 8);
        h2 = load64(&comph + 16);
        v2 = load64(&compv + 16);
        pw2 = load64(&comppw + 16);
        y = 0;
        while (y < h) {
            x = 0;
            while (x < w) {
                yy = load8(p0 + (y * v0 / max_v) * pw0 + (x * h0 / max_h));
                cb = load8(p1 + (y * v1 / max_v) * pw1 + (x * h1 / max_h));
                cr = load8(p2 + (y * v2 / max_v) * pw2 + (x * h2 / max_h));
                o = (y * w + x) * 4;
                _jpeg_ycc_to_rgb(yy, cb, cr, rgba + o);
                store8(rgba + o + 3, 255);
                x = x + 1;
            }
            y = y + 1;
        }
    }

    var img = alloc(CHITRA_IMAGE_SIZE);
    if (img == 0) { store64(err_out, chitra_err(CHITRA_ERR_OOM)); return 0; }
    store64(img + IMAGE_WIDTH_OFFSET, w);
    store64(img + IMAGE_HEIGHT_OFFSET, h);
    store64(img + IMAGE_PIXELS_OFFSET, rgba);
    store64(img + IMAGE_CHANNELS_OFFSET, 4);
    store64(img + IMAGE_SEEN_IEND_OFFSET, 1);
    store64(img + IMAGE_SRC_CTYPE_OFFSET, 256 + ncomp);   # JPEG sentinel: 0x101 gray / 0x103 YCbCr
    return img;
}

# ================================================================
# chitra_jpeg_decode — the top-level public decode. Parse (src, len) JPEG bytes
# -> an owned RGBA8 ChitraImage. Returns the ChitraImage ptr on success, or 0
# with *err_out set to a ChitraErr (left 0 on success). Mirrors chitra_png_decode.
# ================================================================
# @public
fn chitra_jpeg_decode(src, len, err_out): i64 {
    store64(err_out, 0);
    var frame = chitra_jpeg_scan_markers(src, len, err_out);
    if (frame == 0) { return 0; }
    var entropy_start = _jpeg_parse_sos(frame, src, len, err_out);
    if (load64(err_out) != 0) { return 0; }
    return _jpeg_decode_scan(frame, src, len, entropy_start, err_out);
}

# ================================================================
# chitra_jpeg_decode_rgba8 — convenience wrapper. Decode (src, len) and return
# the RGBA8 pixel pointer directly, writing width/height through w_out / h_out
# (>=8-byte slots). Returns 0 on any failure. Mirrors chitra_png_decode_rgba8.
# ================================================================
# @public
fn chitra_jpeg_decode_rgba8(src, len, w_out, h_out): i64 {
    store64(w_out, 0);
    store64(h_out, 0);
    var err = 0;
    var img = chitra_jpeg_decode(src, len, &err);
    if (img == 0) { return 0; }
    store64(w_out, chitra_image_width(img));
    store64(h_out, chitra_image_height(img));
    return chitra_image_pixels(img);
}

# ================================================================
# chitra_image_decode — format-sniffing top-level decode. Routes to the PNG or
# JPEG decoder by signature (PNG 8-byte magic, or JPEG SOI 0xFFD8) — the
# format-agnostic entry the "chitra" name was chosen for. Returns a ChitraImage
# ptr, or 0 with *err_out set (CHITRA_ERR_SIGNATURE for an unrecognized format).
# ================================================================
# @public
fn chitra_image_decode(src, len, err_out): i64 {
    store64(err_out, 0);
    if (chitra_png_check_signature(src, len) == 1) {
        return chitra_png_decode(src, len, err_out);
    }
    if (chitra_jpeg_check_signature(src, len) == 1) {
        return chitra_jpeg_decode(src, len, err_out);
    }
    store64(err_out, chitra_err(CHITRA_ERR_SIGNATURE));
    return 0;
}
