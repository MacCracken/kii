# ascii.cyr — character-glyph ("ASCII art") rendering mode.
#
# v1.3.0 introduced this lane with a luminance density ramp; v1.3.1
# UPGRADES it to SHAPE-VECTOR glyph matching. Each output cell is sampled
# in a 2x3 sub-grid, and the glyph whose ink-coverage vector is nearest
# (squared-Euclidean over the 6 regions) is chosen — so the matcher tracks
# glyph ORIENTATION (/, \, |, -, _, ...), not just density.
#
# ATTRIBUTION: the shape-vector technique (per-cell N-region coverage
# vectors + nearest-glyph match) is from Alex Harri, "ASCII Art Rendering"
# — https://alexharri.com/blog/ascii-rendering. kii uses a 6-region (2x3)
# variant of his idea; the per-glyph coverage table is computed offline
# from the Liberation-Mono font (scratch gen_shape.py) and normalized to
# the 0..255 cell-luminance scale. The Euclidean nearest-neighbour and the
# Rec.709 luma are standard (no attribution needed). Deferred refinements
# from the blog (directional contrast enhancement, k-d-tree lookup) are
# tracked — see docs/development/roadmap.md and ADR 0007.
#
# Still a SECOND lane beside the half-block default (ADR 0007). One char =
# one cell, so main.cyr downscales to (cols*2)x(rows*3) for this mode — the
# 2x3 sub-samples per character cell. Foreground is the cell's mean color
# quantized to the 16-color palette.
#
# Stdlib (alloc/syscalls) + darshana (tty_*) auto-resolve; png.cyr gives
# the pstruct contract; quant.cyr gives quantize_nearest_rgb (per-cell fg).

include "src/png.cyr"
include "src/quant.cyr"

# Rec.709 relative luminance, integer-scaled 54/183/19 (sum 256, exact /256
# via >>8). Returns 0..255. W3C/Wikipedia standard coefficients.
fn _ascii_luma(r, g, b): i64 {
    return (54 * r + 183 * g + 19 * b) >> 8;
}

# === GENERATED (gen_shape.py, Liberation-Mono 24x48) — do not hand-edit ===
