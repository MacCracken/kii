# _ascii_match — given a 6-byte region-luminance vector `v` (row-major:
# r0c0 r0c1 r1c0 r1c1 r2c0 r2c1, each 0..255), return the glyph byte whose
# coverage vector is nearest in squared-Euclidean distance. Ties resolve to
# the lower index (strict `<`), so glyph 0 (space) wins an all-dark cell.
# Max distance 6*255^2 ~= 390k — well within i64.
fn _ascii_match(v): i64 {
    _ascii_shape_init();
    var best_g = 0;
    var best_d = 0 - 1;
    var g = 0;
    while (g < ASCII_SHAPE_COUNT) {
        var d = 0;
        var r = 0;
        while (r < 6) {
            var diff = load8(v + r) - load64(&ASCII_SHAPE_COV + (g * 6 + r) * 8);
            d = d + diff * diff;
            r = r + 1;
        }
        if (best_d < 0 || d < best_d) {
            best_d = d;
            best_g = g;
        }
        g = g + 1;
    }
    return load64(&ASCII_SHAPE_GLYPHS + best_g * 8);
}

# emit_ascii_shape_row_buf — render ONE character row (cell row `cy`) into
# `buf` at `pos`. `rgb` is the finer (sub_w x sub_h) downscaled RGB buffer
# where sub_w = cols*2; each cell pulls its 2x3 sub-samples, builds the
# 6-region luminance vector, matches a glyph, and colors it with the cell's
# mean quantized color. Returns the new pos, or -1. (Buffer-targeting so
# tests can assert the exact bytes — same split as emit_halfblock_row_buf.)
fn emit_ascii_shape_row_buf(rgb, sub_w, cy, cols, buf, pos): i64 {
    var cx = 0;
    while (cx < cols) {
        var vec[6];
        var sumr = 0;
        var sumg = 0;
        var sumb = 0;
        var rr = 0;
        while (rr < 3) {
            var cc = 0;
            while (cc < 2) {
                var sx = cx * 2 + cc;
                var sy = cy * 3 + rr;
                var o = rgb + (sy * sub_w + sx) * 3;
                var pr = load8(o + 0);
                var pg = load8(o + 1);
                var pb = load8(o + 2);
                store8(&vec + (rr * 2 + cc), _ascii_luma(pr, pg, pb));
                sumr = sumr + pr;
                sumg = sumg + pg;
                sumb = sumb + pb;
                cc = cc + 1;
            }
            rr = rr + 1;
        }
        var glyph = _ascii_match(&vec);
        var fg = quantize_nearest_rgb(sumr / 6, sumg / 6, sumb / 6);
        pos = tty_fg_256_buf(buf, pos, fg);
        if (pos < 0) { return 0 - 1; }
        store8(buf + pos, glyph);
        pos = pos + 1;
        cx = cx + 1;
    }
    # Per-row SGR reset + newline (SIGPIPE-clean, like emit_halfblock).
    pos = tty_sgr_reset_buf(buf, pos);
    store8(buf + pos, 10);
    pos = pos + 1;
    return pos;
}

# emit_ascii_shape — render the full frame to fd 1 (stdout). Reads
# STRUCT_DOWNSCALED_* (the finer (cols*2 x rows*3) RGB buffer main.cyr
# produces for ASCII mode). Returns 0, or -1 if downscale wasn't run / dims
# invalid. Per-row heap buffer sized from cols (no fixed-stack overflow —
# the v1.2.1 lesson): each cell is <=11 B fg + 1 glyph, + per-row reset/LF.
fn emit_ascii_shape(pstruct): i64 {
    var rgb = load64(pstruct + STRUCT_DOWNSCALED_BUF_OFFSET);
    var sub_w = load64(pstruct + STRUCT_DOWNSCALED_W_OFFSET);
    var sub_h = load64(pstruct + STRUCT_DOWNSCALED_H_OFFSET);
    if (rgb == 0) { return 0 - 1; }
    if (sub_w < 2 || sub_h < 3) { return 0 - 1; }
    var cols = sub_w / 2;
    var rows = sub_h / 3;
    var line_cap = cols * 14 + 16;
    var line_buf = alloc(line_cap);
    if (line_buf == 0) { return 0 - 1; }
    var cy = 0;
    while (cy < rows) {
        var pos = emit_ascii_shape_row_buf(rgb, sub_w, cy, cols, line_buf, 0);
        if (pos < 0) { return 0 - 1; }
        syscall(1, 1, line_buf, pos);
        cy = cy + 1;
    }
    return 0;
}
