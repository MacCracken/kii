# downscale.cyr — nearest-neighbor RGB resampler.
#
# v0.6.0 / M5(b). Reads the decoded source pixel buffer at
# STRUCT_PIXELS_BUF_OFFSET (W_src × H_src × bpp bytes in the source
# color_type's native layout) and produces a packed RGB-triple buffer
# at STRUCT_DOWNSCALED_BUF_OFFSET sized to (dst_w × dst_h × 3) bytes.
#
# **Why "to RGB"** (not preserving source color_type):
# Normalizing during downscale means every downstream consumer (the
# M5 quantizer, the M5 emit layer) sees a uniform layout — 3 bytes
# per pixel, R G B in order — regardless of whether the source was
# greyscale / RGB / palette / RGBA / grey+alpha. The per-color_type
# dispatch lives here once, and the quantizer stays focused on
# RGB → palette-index.
#
# **Why nearest-neighbor** (not bilinear / Lanczos):
# Smallest correct algorithm. Tier-1 floor per CLAUDE.md color-tier
# discipline — perceptually-better filters live in tier-2 / post-v1
# scope alongside dithering. For the half-block aesthetic at 80×48
# source resolution, nearest-neighbor downscale of a multi-megapixel
# image looks indistinguishable from bilinear once quantized into a
# 16-color palette.
#
# **Algorithm** (per scanline):
#   For each dst pixel (dx, dy) in [0, dst_w) × [0, dst_h):
#     sx = (dx × W_src) / dst_w       # integer truncation toward 0
#     sy = (dy × H_src) / dst_h
#     (r, g, b) = extract_rgb(pixels, sx, sy, color_type, ...)
#     store at dst_buf + (dy × dst_w + dx) × 3
#
# Multi-source convergent port: shape drawn from chafa's
# `chafa-canvas.c` resample (nearest variant), libcaca's color
# picker, and the canonical nearest-neighbor reference in Foley/
# van Dam § 17.4.1. Not single-source.

include "src/png.cyr"

# Per-color_type RGB extraction for ONE source pixel at (sx, sy).
# Writes the R/G/B byte values into out_buf[0..3]. Returns 0 on
# success, -1 on bad color_type / missing PLTE. Mirrors quant.cyr's
# inline dispatch but writes RGB instead of a palette index.
#
# bit_depth handling: bps = bit_depth / 8 (1 or 2 bytes per sample);
# we always read the HIGH byte at depth=16 (truncation — full-
# precision 16-bit is post-v1 per CLAUDE.md color-tier discipline).
fn _extract_rgb(pixels, sx, sy, width, color_type, bps, plte_buf, plte_size, out_buf): i64 {
    var channels = _png_color_channels(color_type);
    if (channels < 0) { return 0 - 1; }
    var bpp = channels * bps;
    var pix_off = (sy * width + sx) * bpp;

    if (color_type == 0) {
        # Greyscale: 1 sample × bps bytes.
        var v = load8(pixels + pix_off);
        store8(out_buf + 0, v);
        store8(out_buf + 1, v);
        store8(out_buf + 2, v);
        return 0;
    }
    if (color_type == 2) {
        store8(out_buf + 0, load8(pixels + pix_off + 0 * bps));
        store8(out_buf + 1, load8(pixels + pix_off + 1 * bps));
        store8(out_buf + 2, load8(pixels + pix_off + 2 * bps));
        return 0;
    }
    if (color_type == 3) {
        # Palette index → PLTE lookup.
        if (plte_buf == 0 || plte_size == 0) { return 0 - 1; }
        var pi = load8(pixels + pix_off);
        var po = pi * 3;
        # Defensive bounds — OOB indices map to black (entry 0 would
        # also work; black is the safer "did not match" sentinel).
        if (po + 2 < plte_size) {
            store8(out_buf + 0, load8(plte_buf + po + 0));
            store8(out_buf + 1, load8(plte_buf + po + 1));
            store8(out_buf + 2, load8(plte_buf + po + 2));
        } else {
            store8(out_buf + 0, 0);
            store8(out_buf + 1, 0);
            store8(out_buf + 2, 0);
        }
        return 0;
    }
    if (color_type == 4) {
        # Greyscale + alpha: grey sample (drop alpha).
        var v = load8(pixels + pix_off);
        store8(out_buf + 0, v);
        store8(out_buf + 1, v);
        store8(out_buf + 2, v);
        return 0;
    }
    if (color_type == 6) {
        # RGBA: take R, G, B and drop alpha.
        store8(out_buf + 0, load8(pixels + pix_off + 0 * bps));
        store8(out_buf + 1, load8(pixels + pix_off + 1 * bps));
        store8(out_buf + 2, load8(pixels + pix_off + 2 * bps));
        return 0;
    }
    return 0 - 1;
}

# Downscale the decoded source pixel buffer to a packed RGB-triple
# buffer of size dst_w × dst_h × 3 bytes. Stores ptr + dimensions
# into pstruct's STRUCT_DOWNSCALED_*_OFFSET slots. Returns 0 on
# success, -1 on:
#   - png_decode_pixels not yet run (STRUCT_PIXELS_BUF_OFFSET == 0)
#   - bad color_type
#   - PLTE missing for color_type=3
#   - dst_w / dst_h <= 0
#   - alloc failure
#
# **Source-larger-than-dst is the common case** (e.g. RAMGON.png
# 1152×925 → 80×48). Source-smaller is also valid — nearest-neighbor
# happily upscales by repeating source pixels, which preserves the
# tier-1 pixel-art aesthetic for small input images.
#
# Time complexity: O(dst_w × dst_h) — independent of source size.
# RAMGON-to-80×48 is 3840 _extract_rgb calls + 3840 stores, sub-
# millisecond on warm cache. The quantizer (per quant.cyr bench)
# is 274 ns/op so 80×48 quantize is ~1 ms. Emit dwarfs both.
fn downscale_to_rgb(pstruct, dst_w, dst_h): i64 {
    if (dst_w <= 0 || dst_h <= 0) { return 0 - 1; }

    var src_w     = load64(pstruct + STRUCT_WIDTH_OFFSET);
    var src_h     = load64(pstruct + STRUCT_HEIGHT_OFFSET);
    var bit_depth = load64(pstruct + STRUCT_BIT_DEPTH_OFFSET);
    var color_type= load64(pstruct + STRUCT_COLOR_TYPE_OFFSET);
    var pixels    = load64(pstruct + STRUCT_PIXELS_BUF_OFFSET);
    var pix_size  = load64(pstruct + STRUCT_PIXELS_SIZE_OFFSET);
    var plte_buf  = load64(pstruct + STRUCT_PLTE_BUF_OFFSET);
    var plte_size = load64(pstruct + STRUCT_PLTE_SIZE_OFFSET);

    if (pixels == 0)    { return 0 - 1; }
    if (pix_size <= 0)  { return 0 - 1; }
    if (src_w <= 0 || src_h <= 0) { return 0 - 1; }
    var channels = _png_color_channels(color_type);
    if (channels < 0) { return 0 - 1; }
    if (color_type == 3) {
        if (plte_buf == 0 || plte_size == 0) { return 0 - 1; }
    }

    var bps = bit_depth / 8;
    if (bps <= 0) { return 0 - 1; }

    var out_bytes = dst_w * dst_h * 3;
    var out_buf = alloc(out_bytes);
    if (out_buf == 0) { return 0 - 1; }

    var dy = 0;
    while (dy < dst_h) {
        # sy is constant across a scanline; hoist out of the inner
        # loop. Integer-truncation: (dy * src_h) / dst_h. For dy=0
        # this is 0; for dy=(dst_h-1) it's ((dst_h-1) × src_h)/dst_h,
        # which is < src_h by at least one (so we never read past
        # the source-buffer end). dst_h > 0 is enforced above so
        # divide-by-zero can't happen.
        var sy = (dy * src_h) / dst_h;
        var dx = 0;
        while (dx < dst_w) {
            var sx = (dx * src_w) / dst_w;
            var dst_off = (dy * dst_w + dx) * 3;
            var rc = _extract_rgb(pixels, sx, sy, src_w, color_type, bps,
                                  plte_buf, plte_size, out_buf + dst_off);
            if (rc != 0) {
                # Should never fire — color_type + PLTE are validated
                # at function entry. If it does, abort the operation
                # rather than leaving a half-filled buffer.
                return 0 - 1;
            }
            dx = dx + 1;
        }
        dy = dy + 1;
    }

    store64(pstruct + STRUCT_DOWNSCALED_BUF_OFFSET, out_buf);
    store64(pstruct + STRUCT_DOWNSCALED_W_OFFSET,   dst_w);
    store64(pstruct + STRUCT_DOWNSCALED_H_OFFSET,   dst_h);
    return 0;
}
