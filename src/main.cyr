# kii — main entry point.
# Stdlib (incl. args, flags) auto-included via cyrius.cyml.
#
# Milestone path to v1.0 (see docs/development/roadmap.md):
#   M1 v0.2.0  CLI arg parsing (--help / --version / positional path / --width / --color)
#   M2 v0.3.0  PNG structural decoder (signature + IHDR + IDAT extraction + CRC)
#   M3 v0.4.0  PNG decode through sankoch DEFLATE → raw RGB pixels
#   M4 v0.5.0  16-color ANSI palette + RGB→nearest quantization
#   M5 v0.6.0  half-block (▀) glyph emit + per-row ANSI color escapes
#   M6 v0.7.0  terminal-size auto-detect (ioctl TIOCGWINSZ) + --width override
#   M7 v1.0.0  CLI surface frozen; soak + docs + audit
#
# Status: M2 SHIPPED at v0.3.0 — full PNG structural decoder
# (signature + IHDR + CRC32 + chunk walker through IEND) at the
# entry hop. Valid + CRC-clean PNGs print
# `<path>: <W>x<H> bit_depth=<N> color_type=<T>` to STDOUT + exit 0;
# missing IEND emits a stderr warning but still succeeds. Malformed
# signature / IHDR / CRC / truncated post-IHDR chunk → distinct
# path-keyed errors on stderr + exit 1. M3 (sankoch DEFLATE) lands
# the actual pixel decode + replaces the structural-summary stdout
# with a `<path>: <W>x<H> decoded <N> pixels` line.
#
# Domain rules (see CLAUDE.md § Domain-specific rules):
#   - Half-block (▀ / ▄) is the FLOOR glyph; alternates opt-in
#   - CRC + signature validation on every input image
#   - No file writes (stdin/args → stdout only)
#   - Tier 1 = 8/16-color ANSI + half-block; tier 2 (256/truecolor) is post-v1

include "src/cli.cyr"
include "src/png.cyr"

# argv cap. kii takes one positional path arg at most; 256 is
# absurdly more than any plausible invocation but matches the
# anuenue cap so every AGNOS userland binary lands on the same
# stack-buffer shape.
var KII_ARGV_MAX = 256;

# Write a null-terminated string to fd 2 (stderr). Usage / help
# text rides this so the happy-path stdout pipe stays pure once
# M5 lands ANSI emit — `kii image.png | tee out.ansi` mustn't get
# help text mixed into the captured frame.
fn _eprint(s): i64 {
    var len = strlen(s);
    syscall(1, 2, s, len);
    return 0;
}

# Print "<path>: <msg>\n" to stderr. Path-keyed diagnostic format
# matches chafa's `chafa: foo.png: image load failed` shape. All
# M2-error and intermediate "ok but not yet implemented" lines
# ride this. M2(d) will route the success line to stdout via a
# parallel `_print_path_msg` (no leading `kii:` prefix, no error
# semantic) once the full structural-decode output lands.
fn _eprint_path_msg(path, msg): i64 {
    _eprint(path);
    _eprint(": ");
    _eprint(msg);
    _eprint("\n");
    return 0;
}

# Print "<path>: <W>x<H> bit_depth=<N> color_type=<N>\n" to STDOUT.
# This is the M2 acceptance success shape. Goes to fd 1 (not fd 2)
# so consumers can `kii image.png | grep '^path:'`; missing-IEND
# warnings ride stderr separately (pipe purity).
fn _print_ihdr_summary(path, ihdr): i64 {
    var plen = strlen(path);
    syscall(1, 1, path, plen);
    syscall(1, 1, ": ", 2);
    var wbuf[16]; var wlen = fmt_int_buf(load64(ihdr + IHDR_WIDTH_OFFSET), &wbuf);
    syscall(1, 1, &wbuf, wlen);
    syscall(1, 1, "x", 1);
    var hbuf[16]; var hlen = fmt_int_buf(load64(ihdr + IHDR_HEIGHT_OFFSET), &hbuf);
    syscall(1, 1, &hbuf, hlen);
    syscall(1, 1, " bit_depth=", 11);
    var dbuf[8];  var dlen = fmt_int_buf(load64(ihdr + IHDR_BIT_DEPTH_OFFSET), &dbuf);
    syscall(1, 1, &dbuf, dlen);
    syscall(1, 1, " color_type=", 12);
    var cbuf[8];  var clen = fmt_int_buf(load64(ihdr + IHDR_COLOR_TYPE_OFFSET), &cbuf);
    syscall(1, 1, &cbuf, clen);
    syscall(1, 1, "\n", 1);
    return 0;
}

# --version → stdout. POSIX-conventional: machine-readable
# version line first, etymology second. Scripts that grep for
# the version line see exactly `kii X.Y.Z` on stdout's first
# line; humans get the Hawaiian gloss on the second.
fn print_version(): i64 {
    println("kii 0.3.0");
    println("kiʻi (Hawaiian: image / picture / likeness) — image → ANSI/ASCII-art converter");
    return 0;
}

fn print_usage(fs): i64 {
    _eprint("kii — kiʻi (Hawaiian: image / picture / likeness). Image → ANSI art.\n\n");
    _eprint("Usage:\n  kii [OPTIONS] <image.png>\n\n");
    _eprint("Options:\n");
    flags_print_help(fs);
    _eprint("\nExamples:\n");
    _eprint("  kii --version                              # version + etymology\n");
    _eprint("  kii --help                                 # this text\n");
    _eprint("  kii image.png                              # render to terminal (M5+)\n");
    return 0;
}

# Pack argc()/argv(i) into a contiguous cstr* array. flags_parse
# wants a raw pointer-array (it does `load64(argv + i*8)`), not
# lib/args.cyr's byte-stream walker.
fn build_argv_array(arr): i64 {
    var ac = argc();
    var i = 0;
    while (i < ac) {
        store64(arr + i * 8, argv(i));
        i = i + 1;
    }
    return ac;
}

fn main(): i64 {
    args_init();
    alloc_init();

    var ac = argc();
    if (ac > KII_ARGV_MAX) {
        _eprint("kii: too many arguments\n");
        return KII_EXIT_USAGE;
    }
    var argv_arr[2048];                     # 256 slots × 8 bytes
    build_argv_array(&argv_arr);

    # Flag registration lives in src/cli.cyr so kii.tcyr + kii.fcyr
    # can wire the same flag set without including main.cyr.
    var fs = flags_new();
    kii_register_flags(fs);

    if (flags_parse(fs, ac, &argv_arr) != 0) {
        var err = flags_error(fs);
        if (err == FLAG_ERR_UNKNOWN) {
            _eprint("kii: unknown flag\n");
        } else { if (err == FLAG_ERR_MISSING_VALUE) {
            _eprint("kii: flag missing value\n");
        } else { if (err == FLAG_ERR_BAD_INT) {
            _eprint("kii: bad integer value\n");
        } else { if (err == FLAG_ERR_BUNDLED) {
            _eprint("kii: bundled short flags not supported (use -x -y, not -xy)\n");
        } else {
            _eprint("kii: argument parse error\n");
        } } } }
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    if (flags_get_bool(fs, KII_F_HELP) == 1) {
        print_usage(fs);
        return KII_EXIT_OK;
    }
    if (flags_get_bool(fs, KII_F_VERSION) == 1) {
        return print_version();
    }

    # --color validation. Run BEFORE the positional check so
    # `kii --color 7` fails fast on the flag without first nagging
    # about the missing path. --width is parsed but unused until
    # M5; we don't extract it yet (no dead code per CLAUDE.md —
    # M5 adds the extraction back when actually consumed).
    var color = flags_get_int(fs, KII_F_COLOR);
    if (kii_validate_color(color) == 0) {
        _eprint("kii: --color must be 8 or 16\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    # Positional path arg. kii takes exactly one image path per
    # CLAUDE.md domain rule ("kii takes ONE file path. No glob, no
    # recursive directory scan."). Zero = usage error; two-plus =
    # usage error.
    var pc = flags_positional_count(fs);
    if (pc == 0) {
        _eprint("kii: missing image path\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }
    if (pc > 1) {
        _eprint("kii: too many arguments (expected one image path)\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    # M2(a)+(b)+(c): PNG signature + IHDR + CRC32 + chunk walker.
    # Distinct error paths so users see *what* went wrong (open
    # vs not-PNG vs truncated vs malformed header vs CRC failure
    # vs truncated mid-chunk) rather than a generic "decode
    # failed". Full structural output flips to stdout/exit-0 at
    # M2(d); until then exit 1 with a parenthetical WIP marker.
    #
    # png_decode_structure handles png_crc_init internally; no
    # need to call it here.
    var path = flags_positional(fs, 0);
    var pstruct[64];
    var rc = png_decode_structure(path, &pstruct);
    if (rc == PNG_ERR_OPEN) {
        _eprint_path_msg(path, "cannot open file");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_TRUNCATED) {
        _eprint_path_msg(path, "not a PNG (file shorter than 8 bytes)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_NOT_PNG) {
        _eprint_path_msg(path, "not a PNG");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_HEADER) {
        _eprint_path_msg(path, "malformed PNG header");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_CRC) {
        _eprint_path_msg(path, "CRC check failed");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_CHUNK) {
        _eprint_path_msg(path, "malformed PNG (chunk truncated after IHDR)");
        return KII_EXIT_RUN;
    }

    # PNG_OK. STRUCT_*_OFFSET aligns with IHDR_*_OFFSET for the
    # first four slots, so _print_ihdr_summary works directly on
    # the pstruct buffer. Summary goes to stdout + exit 0 per M2
    # acceptance contract. If IEND was missing, append a warning
    # line on STDERR per spec § 5.3 tolerance ("continues with
    # what was read") — keeps stdout pipe-pure so consumers can
    # pipe the structural summary into other tools.
    _print_ihdr_summary(path, &pstruct);
    if (load64(&pstruct + STRUCT_SEEN_IEND_OFFSET) == 0) {
        _eprint_path_msg(path, "warning: incomplete PNG (no IEND chunk seen)");
    }
    return KII_EXIT_OK;
}

var r = main();
syscall(SYS_EXIT, r);
