# kii — main entry point.
# Stdlib (incl. args, flags) auto-included via cyrius.cyml.
#
# Milestone path to v1.0 (see docs/development/roadmap.md):
#   M1 v0.2.0  CLI arg parsing (--help / --version / positional path / --width / --color)
#   M2 v0.3.0  PNG structural decoder (signature + IHDR + IDAT extraction + CRC)
#   M3 v0.4.0  PNG decode through sankoch DEFLATE → raw RGB pixels
#   M4 v0.5.0  16-color ANSI palette + RGB→nearest quantization
#   M5 v0.6.0  half-block (▀) glyph emit + per-row ANSI color escapes
#   M6 v0.7.0  terminal-size auto-detect (ioctl TIOCGWINSZ) + --width override
#   M7 v1.0.0  CLI surface frozen; soak + docs + audit
#
# Status: M1 sub-bites (a)–(d) in progress — full M1 flag surface
# (`--help`, `--version`, `--width N`, `--color N`, positional path)
# parses + dispatches; flag registration + --color validation are
# split into src/cli.cyr so tests + fuzz can drive them in-process;
# values are captured + echoed by the placeholder but no decoder
# runs yet. VERSION + CHANGELOG bump to 0.2.0 lands at end of M1.
#
# Domain rules (see CLAUDE.md § Domain-specific rules):
#   - Half-block (▀ / ▄) is the FLOOR glyph; alternates opt-in
#   - CRC + signature validation on every input image
#   - No file writes (stdin/args → stdout only)
#   - Tier 1 = 8/16-color ANSI + half-block; tier 2 (256/truecolor) is post-v1

include "src/cli.cyr"

# argv cap. kii takes one positional path arg at most; 256 is
# absurdly more than any plausible invocation but matches the
# anuenue cap so every AGNOS userland binary lands on the same
# stack-buffer shape.
var KII_ARGV_MAX = 256;

# Write a null-terminated string to fd 2 (stderr). Usage / help
# text rides this so the happy-path stdout pipe stays pure once
# M5 lands ANSI emit — `kii image.png | tee out.ansi` mustn't get
# help text mixed into the captured frame.
fn _eprint(s): i64 {
    var len = strlen(s);
    syscall(1, 2, s, len);
    return 0;
}

# Throwaway M1 placeholder. Writes
#   <path>: decoder not yet implemented (width=N color=N)\n
# to stderr. The width/color echo proves the flag values were
# captured into module state — the only observable smoke for the
# sub-bite (c) acceptance criteria short of a debugger. M2 replaces
# this entire path with the structural-decode success line
# (`image.png: <W>x<H> bit_depth=<N> color_type=<T>` on stdout).
fn _eprint_placeholder(path, width, color): i64 {
    _eprint(path);
    _eprint(": decoder not yet implemented (width=");
    var wbuf[32];
    var wlen = fmt_int_buf(width, &wbuf);
    syscall(1, 2, &wbuf, wlen);
    _eprint(" color=");
    var cbuf[32];
    var clen = fmt_int_buf(color, &cbuf);
    syscall(1, 2, &cbuf, clen);
    _eprint(")\n");
    return 0;
}

# --version → stdout. POSIX-conventional: machine-readable
# version line first, etymology second. Scripts that grep for
# the version line see exactly `kii X.Y.Z` on stdout's first
# line; humans get the Hawaiian gloss on the second.
fn print_version(): i64 {
    println("kii 0.1.0");
    println("kiʻi (Hawaiian: image / picture / likeness) — image → ANSI/ASCII-art converter");
    return 0;
}

fn print_usage(fs): i64 {
    _eprint("kii — kiʻi (Hawaiian: image / picture / likeness). Image → ANSI art.\n\n");
    _eprint("Usage:\n  kii [OPTIONS] <image.png>\n\n");
    _eprint("Options:\n");
    flags_print_help(fs);
    _eprint("\nExamples:\n");
    _eprint("  kii --version                              # version + etymology\n");
    _eprint("  kii --help                                 # this text\n");
    _eprint("  kii image.png                              # render to terminal (M5+)\n");
    return 0;
}

# Pack argc()/argv(i) into a contiguous cstr* array. flags_parse
# wants a raw pointer-array (it does `load64(argv + i*8)`), not
# lib/args.cyr's byte-stream walker.
fn build_argv_array(arr): i64 {
    var ac = argc();
    var i = 0;
    while (i < ac) {
        store64(arr + i * 8, argv(i));
        i = i + 1;
    }
    return ac;
}

fn main(): i64 {
    args_init();
    alloc_init();

    var ac = argc();
    if (ac > KII_ARGV_MAX) {
        _eprint("kii: too many arguments\n");
        return KII_EXIT_USAGE;
    }
    var argv_arr[2048];                     # 256 slots × 8 bytes
    build_argv_array(&argv_arr);

    # Flag registration lives in src/cli.cyr so kii.tcyr + kii.fcyr
    # can wire the same flag set without including main.cyr.
    var fs = flags_new();
    kii_register_flags(fs);

    if (flags_parse(fs, ac, &argv_arr) != 0) {
        var err = flags_error(fs);
        if (err == FLAG_ERR_UNKNOWN) {
            _eprint("kii: unknown flag\n");
        } else { if (err == FLAG_ERR_MISSING_VALUE) {
            _eprint("kii: flag missing value\n");
        } else { if (err == FLAG_ERR_BAD_INT) {
            _eprint("kii: bad integer value\n");
        } else { if (err == FLAG_ERR_BUNDLED) {
            _eprint("kii: bundled short flags not supported (use -x -y, not -xy)\n");
        } else {
            _eprint("kii: argument parse error\n");
        } } } }
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    if (flags_get_bool(fs, KII_F_HELP) == 1) {
        print_usage(fs);
        return KII_EXIT_OK;
    }
    if (flags_get_bool(fs, KII_F_VERSION) == 1) {
        return print_version();
    }

    # --color validation. Run BEFORE the positional check so
    # `kii --color 7` fails fast on the flag without first nagging
    # about the missing path.
    var color = flags_get_int(fs, KII_F_COLOR);
    if (kii_validate_color(color) == 0) {
        _eprint("kii: --color must be 8 or 16\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }
    var width = flags_get_int(fs, KII_F_WIDTH);

    # Positional path arg. kii takes exactly one image path per
    # CLAUDE.md domain rule ("kii takes ONE file path. No glob, no
    # recursive directory scan."). Zero = usage error; two-plus =
    # usage error; exactly one = M1 placeholder until M2 wires the
    # structural decoder.
    var pc = flags_positional_count(fs);
    if (pc == 0) {
        _eprint("kii: missing image path\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }
    if (pc > 1) {
        _eprint("kii: too many arguments (expected one image path)\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    var path = flags_positional(fs, 0);
    _eprint_placeholder(path, width, color);
    return KII_EXIT_RUN;
}

var r = main();
syscall(SYS_EXIT, r);
