# kii — main entry point.
# Stdlib (incl. args, flags) auto-included via cyrius.cyml.
#
# Milestone path to v1.0 (see docs/development/roadmap.md):
#   M1 v0.2.0  CLI arg parsing (--help / --version / positional path / --width / --color)
#   M2 v0.3.0  PNG structural decoder (signature + IHDR + IDAT extraction + CRC)
#   M3 v0.4.0  PNG decode through sankoch DEFLATE → raw RGB pixels
#   M4 v0.5.0  16-color ANSI palette + RGB→nearest quantization
#   M5 v0.6.0  half-block (▀) glyph emit + per-row ANSI color escapes
#   M6 v0.7.0  terminal-size auto-detect (ioctl TIOCGWINSZ) + --width override
#   M7 v1.0.0  CLI surface frozen; soak + docs + audit
#
# Status: M4 SHIPPED at v0.5.0 — full PNG → 16-color ANSI palette
# quantization. Pipeline: signature + IHDR + CRC32 + chunk walker
# (incl. PLTE) → sankoch zlib_decompress → filter undo (spec § 9
# filter types 0–4) → per-color_type RGB extraction → nearest-
# neighbor in Euclidean RGB space against the Linux-console 16-
# color palette. Success line:
#   `<path>: <W>x<H> <N> pixels (<color_type_name>) → 16-color`
# on STDOUT + exit 0. M5 emits actual ANSI half-block glyphs to
# stdout using darshana, replacing this summary line with visible
# terminal art.
#
# Domain rules (see CLAUDE.md § Domain-specific rules):
#   - Half-block (▀ / ▄) is the FLOOR glyph; alternates opt-in
#   - CRC + signature validation on every input image
#   - No file writes (stdin/args → stdout only)
#   - Tier 1 = 8/16-color ANSI + half-block; tier 2 (256/truecolor) is post-v1

include "src/cli.cyr"
include "src/png.cyr"
include "src/quant.cyr"
include "src/downscale.cyr"
include "src/emit.cyr"
include "src/ascii.cyr"

# Write a null-terminated string to fd 2 (stderr). Usage / help
# text rides this so the happy-path stdout pipe stays pure once
# M5 lands ANSI emit — `kii image.png | tee out.ansi` mustn't get
# help text mixed into the captured frame.
fn _eprint(s): i64 {
    var len = strlen(s);
    syscall(1, 2, s, len);
    return 0;
}

# ANSI-injection-safe path-echo. Routes through kii_path_has_control_bytes
# (src/cli.cyr) and emits either the path verbatim or a fixed
# substitute. See that helper's docstring + docs/audit/2026-05-22-audit.md
# § Finding 6 for the threat model.
fn _eprint_path_safe(path): i64 {
    if (kii_path_has_control_bytes(path) == 1) {
        _eprint("<path containing control bytes — suppressed>");
        return 0;
    }
    _eprint(path);
    return 0;
}

# Print "<path>: <msg>\n" to stderr. Path-keyed diagnostic format
# matches chafa's `chafa: foo.png: image load failed` shape. All
# M2-error and intermediate "ok but not yet implemented" lines
# ride this. Path bytes route through _eprint_path_safe (M7(c)
# hardening) so attacker-controlled filenames can't escape-inject
# into the user's terminal.
fn _eprint_path_msg(path, msg): i64 {
    _eprint_path_safe(path);
    _eprint(": ");
    _eprint(msg);
    _eprint("\n");
    return 0;
}

# Stdout-equivalent of _eprint: write a null-terminated string to
# fd 1, using runtime strlen so non-ASCII literals (the M4 arrow
# in particular) don't require hand-counted byte widths.
fn _print(s): i64 {
    var len = strlen(s);
    syscall(1, 1, s, len);
    return 0;
}

# Print "<path>: <W>x<H> <N> pixels (<color_type_name>) → 16-color\n"
# to STDERR. M5 routes this to fd 2 since the ANSI frame now owns
# stdout (pipe-purity for `kii img.png > frame.ansi`). M4 emitted
# the same shape to stdout as the success line; the bytes are
# identical, the destination is the only change.
fn _eprint_quant_summary(path, pstruct): i64 {
    _eprint_path_safe(path);
    _eprint(": ");
    var w = load64(pstruct + STRUCT_WIDTH_OFFSET);
    var h = load64(pstruct + STRUCT_HEIGHT_OFFSET);
    var wbuf[16]; var wlen = fmt_int_buf(w, &wbuf);
    syscall(1, 2, &wbuf, wlen);
    _eprint("x");
    var hbuf[16]; var hlen = fmt_int_buf(h, &hbuf);
    syscall(1, 2, &hbuf, hlen);
    _eprint(" ");
    var pix_count = w * h;
    var pbuf[24]; var pblen = fmt_int_buf(pix_count, &pbuf);
    syscall(1, 2, &pbuf, pblen);
    _eprint(" pixels (");
    _eprint(png_color_type_name(load64(pstruct + STRUCT_SRC_COLOR_TYPE_OFFSET)));
    _eprint(") → 16-color\n");
    return 0;
}

# --version → stdout. POSIX-conventional: machine-readable
# version line first, etymology second. Scripts that grep for
# the version line see exactly `kii X.Y.Z` on stdout's first
# line; humans get the Hawaiian gloss on the second.
fn print_version(): i64 {
    println("kii 1.4.0");
    println("kiʻi (Hawaiian: image / picture / likeness) — image → ANSI/ASCII-art converter");
    return 0;
}

fn print_usage(fs): i64 {
    _eprint("kii — kiʻi (Hawaiian: image / picture / likeness). Image → ANSI art.\n\n");
    cmdit_help(fs);                       # generated Usage + flag list (from the cmdit table)
    _eprint("\nExamples:\n");
    _eprint("  kii --version                              # version + etymology\n");
    _eprint("  kii --help                                 # this text\n");
    _eprint("  kii image.png                              # render to terminal (80x24)\n");
    _eprint("  kii photo.jpg                              # baseline JPEG works too (chitra 0.3.0)\n");
    _eprint("  kii --verbose image.png                    # frame + dimensions/format on stderr\n");
    _eprint("  kii --mode ascii image.png                 # text-glyph art (luminance ramp, colored)\n");
    _eprint("  kii image.png > frame.ansi                 # capture pure ANSI bytes\n");
    return 0;
}

fn main(): i64 {
    alloc_init();

    # CLI parsing via cmdit (the [deps.cmdit] distlib). cmdit_new auto-registers
    # --help/-h + --version/-V; kii_register_flags adds width/color/verbose.
    # cmdit_parse reads the process argv itself (args_init + the materialize
    # bridge), so kii no longer hand-packs an argv array or self-caps argc.
    var fs = cmdit_new("kii");
    kii_register_flags(fs);

    var pr = cmdit_parse(fs);
    if (pr == CMDIT_RESULT_ERR) {
        var err = cmdit_error(fs);
        if (err == CMDIT_ERR_UNKNOWN) {
            _eprint("kii: unknown flag\n");
        } else { if (err == CMDIT_ERR_MISSING_VALUE) {
                _eprint("kii: flag missing value\n");
            } else { if (err == CMDIT_ERR_BAD_INT) {
                    _eprint("kii: bad integer value\n");
                } else { if (err == CMDIT_ERR_BUNDLED) {
                        _eprint("kii: bundled short flags not supported (use -x -y, not -xy)\n");
                    } else {
                        _eprint("kii: argument parse error\n");
                    } } } }
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    if (pr == CMDIT_HELP) {
        print_usage(fs);
        return KII_EXIT_OK;
    }
    if (pr == CMDIT_VERSION) {
        return print_version();
    }

    # --color validation. Run BEFORE the positional check so
    # `kii --color 7` fails fast on the flag without first nagging
    # about the missing path. --width is parsed but unused until
    # M5; we don't extract it yet (no dead code per CLAUDE.md —
    # M5 adds the extraction back when actually consumed).
    var color = cmdit_get_int(fs, KII_F_COLOR);
    if (kii_validate_color(color) == 0) {
        _eprint("kii: --color must be 8 or 16\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    # --mode validation (halfblock | ascii). Same fail-fast placement as
    # --color so a bad mode reports before the missing-path nag.
    var mode = cmdit_get_str(fs, KII_F_MODE);
    if (kii_validate_mode(mode) == 0) {
        _eprint("kii: --mode must be halfblock or ascii\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    # Positional path arg. kii takes exactly one image path per
    # CLAUDE.md domain rule ("kii takes ONE file path. No glob, no
    # recursive directory scan."). Zero = usage error; two-plus =
    # usage error.
    var pc = cmdit_positional_count(fs);
    if (pc == 0) {
        _eprint("kii: missing image path\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }
    if (pc > 1) {
        _eprint("kii: too many arguments (expected one image path)\n");
        print_usage(fs);
        return KII_EXIT_USAGE;
    }

    # Image decode via the chitra distlib (v1.2.0 PNG re-fold + v1.4.0 JPEG
    # wiring; see src/png.cyr's header + ADR 0006 / ADR 0008). kii_decode_png
    # slurps the file (size-capped), sniffs the signature, calls
    # chitra_image_decode (PNG or baseline JPEG → canonical RGBA8), and adapts
    # the result into pstruct as a depth-8 color_type=6 image — so the
    # downscale → quantize → emit pipeline below is byte-for-byte unchanged
    # for both formats. The detected format lands in STRUCT_FORMAT_OFFSET so
    # the diagnostics below read per-format. ChitraErr codes are mapped onto
    # kii's PNG_ERR_* so the distinct per-error stderr diagnostics persist.
    #
    # pstruct is 160 bytes (20 i64 slots): the M5(b) layout + the re-fold's
    # SRC_COLOR_TYPE slot (the source color_type, for --verbose fidelity).
    var path = cmdit_positional(fs, 0);
    var pstruct[160];
    var rc = kii_decode_png(path, &pstruct);
    if (rc == PNG_ERR_OPEN) {
        _eprint_path_msg(path, "cannot open file");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_FILE_TOO_LARGE) {
        _eprint_path_msg(path, "file exceeds size ceiling (max 256 MB)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_NOT_PNG) {
        _eprint_path_msg(path, "unrecognized image format (expected PNG or JPEG)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_HEADER) {
        # Phrased per detected format — chitra routes by signature, so a JPEG
        # never raises the PNG chunk/ordering/palette errors and vice versa.
        if (load64(&pstruct + STRUCT_FORMAT_OFFSET) == KII_FMT_JPEG) {
            _eprint_path_msg(path, "malformed JPEG (bad marker, segment, or entropy data)");
        } else {
            _eprint_path_msg(path, "malformed PNG (bad chunk, ordering, or palette)");
        }
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_CRC) {
        _eprint_path_msg(path, "CRC check failed");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_CHUNK) {
        if (load64(&pstruct + STRUCT_FORMAT_OFFSET) == KII_FMT_JPEG) {
            _eprint_path_msg(path, "truncated JPEG (unexpected end of data)");
        } else {
            _eprint_path_msg(path, "malformed PNG (truncated chunk stream)");
        }
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_INTERLACE) {
        _eprint_path_msg(path, "unsupported interlace method (only 0=none / 1=Adam7 are valid)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_BITDEPTH) {
        _eprint_path_msg(path, "unsupported bit depth for this color type (PNG § 11.2.2)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_UNSUPPORTED) {
        # Valid but unsupported feature — only the JPEG path reaches this
        # (chitra 0.3.0 is baseline-only): progressive / arithmetic / 12-bit
        # / non-baseline SOF mode / CMYK 4-component.
        _eprint_path_msg(path, "unsupported JPEG feature (progressive, arithmetic, 12-bit, non-baseline, or CMYK/4-component)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_NO_IDAT) {
        _eprint_path_msg(path, "no IDAT chunks (nothing to decode)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_INFLATE) {
        _eprint_path_msg(path, "DEFLATE decompression failed (corrupt IDAT)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_FILTER) {
        _eprint_path_msg(path, "invalid PNG filter type (spec § 9 allows 0–4)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_DIMENSIONS) {
        _eprint_path_msg(path, "image dimensions exceed policy ceiling (max 16.7M px / 65535 per side / 256 MB)");
        return KII_EXIT_RUN;
    }
    if (rc == PNG_ERR_IDAT_TOO_LARGE) {
        _eprint_path_msg(path, "out of memory or image too large (possible decompression bomb)");
        return KII_EXIT_RUN;
    }
    if (rc != PNG_OK) {
        _eprint_path_msg(path, "image decode failed");
        return KII_EXIT_RUN;
    }

    # M5 pipeline: downscale → quantize → emit. The M4 single-shot
    # quantize_nearest_image is bypassed in production but kept for
    # backward compat with M4's per-color_type extraction tests
    # (downscale.cyr's _extract_rgb mirrors that logic in the new
    # flow).
    #
    # Target dimension resolution. Two paths:
    #
    # **--width N (explicit)**: M6(a) `_kii_compute_target_geometry`
    # — width-driven, aspect-true height regardless of terminal rows.
    # Lets `kii --width 200 img.png > big.ansi` capture a large frame
    # without auto-cropping. Implies the user knows what they're doing.
    #
    # **--width 0 (default)**: M6(b) fit-within-detected-terminal.
    # `tty_winsize(fd=1)` returns cols + rows when stdout is a TTY;
    # we cap rows to (rows - 1) so the shell prompt has somewhere to
    # land after the frame. Non-TTY → 80×24 fallback (BBS-default
    # frame survives a pipe through `kii img.png | tee out.ansi`).
    var width_flag = cmdit_get_int(fs, KII_F_WIDTH);
    var src_w = load64(&pstruct + STRUCT_WIDTH_OFFSET);
    var src_h = load64(&pstruct + STRUCT_HEIGHT_OFFSET);
    var target_w = 0;
    var target_src_rows = 0;
    if (width_flag > 0) {
        if (_kii_compute_target_geometry(src_w, src_h, width_flag,
        &target_w, &target_src_rows) != 0) {
            _eprint_path_msg(path, "could not compute output geometry");
            return KII_EXIT_RUN;
        }
    } else {
        var fit_cols = 0;
        var fit_rows = 0;
        # Detection. tty_winsize is darshana surface: on Linux it's the ioctl
        # TIOCGWINSZ; on agnos (darshana 0.8.0+) it's the winsize#60 syscall
        # reading the framebuffer console grid. Both return 0 + set the out slots
        # on success, -1 on failure (non-TTY / FB-not-up). On failure
        # fit_cols/fit_rows stay 0 → _kii_compute_fit_geometry uses the
        # EMIT_DEFAULT_* (80×24) fallback. (The pre-0.8.0 agnos gate is gone:
        # darshana's agnos branch no longer collides with `kill`#16 — it calls
        # winsize#60 directly, so kii now sizes to the real console on agnos.)
        var term_rows = 0;
        var term_cols = 0;
        var detect_rc = tty_winsize(1, &term_rows, &term_cols);
        if (detect_rc == 0 && term_cols > 0 && term_rows > 1) {
            fit_cols = term_cols;
            # Leave one row for the shell prompt; the visible frame
            # therefore tops out at (term_rows - 1) terminal rows.
            fit_rows = term_rows - 1;
        }
        # fit_cols / fit_rows == 0 here means "non-TTY or pathological
        # ioctl result" — `_kii_compute_fit_geometry` substitutes the
        # EMIT_DEFAULT_* fallback values (80 × 24).
        if (_kii_compute_fit_geometry(src_w, src_h, fit_cols, fit_rows,
        &target_w, &target_src_rows) != 0) {
            _eprint_path_msg(path, "could not compute output geometry");
            return KII_EXIT_RUN;
        }
    }
    # The two render lanes fork the back of the pipeline:
    #   half-block — downscale to (target_w × target_src_rows) [2 source
    #     rows per ▀ cell], quantize to palette indices, emit_halfblock.
    #   ascii (v1.3.1 shape-vector) — one char = one cell sampled in a 2×3
    #     sub-grid, so downscale to (target_w·2 × ascii_rows·3) where
    #     ascii_rows = target_src_rows/2 (half-block's char-row count). The
    #     shape emit does its own per-cell mean-color quantize, so no
    #     separate quantize_downscaled pass. Keeps aspect right in ~2:1 cells.
    if (kii_mode_is_ascii(mode) == 1) {
        var ascii_rows = target_src_rows / 2;
        if (ascii_rows < 1) { ascii_rows = 1; }
        var adrc = downscale_to_rgb(&pstruct, target_w * 2, ascii_rows * 3);
        if (adrc != 0) {
            _eprint_path_msg(path, "downscale failed (out of memory)");
            return KII_EXIT_RUN;
        }
        var aerc = emit_ascii_shape(&pstruct);
        if (aerc != 0) {
            _eprint_path_msg(path, "ANSI emit failed (downscale not run)");
            return KII_EXIT_RUN;
        }
    } else {
        var drc = downscale_to_rgb(&pstruct, target_w, target_src_rows);
        if (drc != 0) {
            _eprint_path_msg(path, "downscale failed (out of memory)");
            return KII_EXIT_RUN;
        }
        var qrc = quantize_downscaled(&pstruct);
        if (qrc != 0) {
            _eprint_path_msg(path, "quantization failed (OOM)");
            return KII_EXIT_RUN;
        }
        var erc = emit_halfblock(&pstruct);
        if (erc != 0) {
            _eprint_path_msg(path, "ANSI emit failed (downscale or quantize not run)");
            return KII_EXIT_RUN;
        }
    }

    # --verbose: write the M4-shaped summary to stderr AFTER the
    # frame so a TTY reader sees `kii img.png` paint the image, then
    # see the dimensions/format line on the next stderr-routed line.
    # Pure-pipe consumers (`kii img.png | feh -`) don't pay for it.
    if (cmdit_get_bool(fs, KII_F_VERBOSE) == 1) {
        _eprint_quant_summary(path, &pstruct);
    }
    # IEND is a PNG-only trailer; chitra always reports seen_iend=1 for a
    # JPEG, but gate on the format too so this PNG-specific warning can never
    # surface for a JPEG render.
    if (load64(&pstruct + STRUCT_FORMAT_OFFSET) == KII_FMT_PNG) {
        if (load64(&pstruct + STRUCT_SEEN_IEND_OFFSET) == 0) {
            _eprint_path_msg(path, "warning: incomplete PNG (no IEND chunk seen)");
        }
    }
    return KII_EXIT_OK;
}

# Bare-call entry (NOT `var r = main();`): on the agnos target a module-scope
# `var = main()` makes main a gvar-initializer that runs BEFORE cycc's init-rsp
# capture (placed after gvar-inits), so argc()/argv() would read 0/null and kii
# would see no image path. A bare top-level statement runs in PARSE_PROG, after
# the capture, so args resolve correctly. SYS_EXIT (not literal 60) is correct on
# both targets — agnos renumbers exit to 0. Matches anuenue/owl/bnrmr.
fn _agnos_entry(): i64 {
    var r = main();
    syscall(SYS_EXIT, r);
    return 0;
}
_agnos_entry();
