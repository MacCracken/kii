# png.cyr — kii's in-repo PNG decoder.
#
# Multi-source convergent port per CLAUDE.md hard rule: the
# decoder shape comes from the W3C PNG Specification (1.3) +
# `libpng` as reference impl + `stb_image.h` and `lodepng` as
# minimal-port references. Not single-source from any one of
# them — each contributes a different angle (spec = ground truth,
# libpng = canonical impl, stb/lodepng = "what does this look
# like as ~1k lines").
#
# v0.3.0 / M2 lands the structural layer (signature → IHDR →
# chunk walk → CRC32 → IEND). Pixel decode (IDAT DEFLATE +
# filter undo) is M3 (v0.4.0) once `sankoch` dep is wired.
# Stdlib (incl. io, result) auto-included via cyrius.cyml.
#
# Sub-bite (a) — this file: signature validation only. The 8-byte
# magic at file start is the cheapest possible "is this a PNG"
# test; everything downstream gates on it.

# ---- PNG signature (W3C PNG § 5.2) ---------------------------------
# Bytes 0-7 of every PNG file. Designed to detect common file-
# transfer corruption modes:
#   0x89  — high-bit-set byte: detects 7-bit-stripping gateways
#   P,N,G — ASCII identifier
#   \r\n  — CRLF: detects DOS↔Unix line-ending mangling
#   0x1A  — DOS EOF marker: stops a naive `type` cmd dead
#   \n    — final LF: detects \r\n→\r conversion
# String-literal storage because Cyrius cstrings are null-terminated
# and byte 8 (the NUL) is never inspected — the loop bounds on
# PNG_MAGIC_LEN.
var PNG_MAGIC     = "\x89PNG\r\n\x1a\n";
var PNG_MAGIC_LEN = 8;

# ---- error codes ---------------------------------------------------
# kii-namespaced rather than leaking IoError variants up to main.cyr.
# Main dispatch translates these into user-facing `<path>: <msg>`
# diagnostics; tests assert on the codes directly.
var PNG_OK            = 0;
var PNG_ERR_OPEN      = 1;  # File could not be opened (not found, perms, etc.)
var PNG_ERR_TRUNCATED = 2;  # File read returned fewer than 8 bytes
var PNG_ERR_NOT_PNG   = 3;  # First 8 bytes did not match PNG_MAGIC
var PNG_ERR_HEADER    = 4;  # IHDR chunk truncated, wrong length, or wrong type
var PNG_ERR_CRC       = 5;  # IHDR or post-IHDR chunk CRC32 mismatch
var PNG_ERR_CHUNK     = 6;  # Non-IHDR chunk truncated mid-read (started but EOF before completing)
var PNG_ERR_INTERLACE = 7;  # interlace == 1 (Adam7) — explicit M3 rejection per roadmap
var PNG_ERR_BITDEPTH  = 8;  # bit_depth ∈ {1,2,4} or unsupported color_type — explicit M3 rejection
var PNG_ERR_NO_IDAT   = 9;  # PNG had zero IDAT chunks (structurally valid but no pixel data)
var PNG_ERR_INFLATE   = 10; # zlib_decompress failed or produced wrong size
var PNG_ERR_FILTER    = 11; # Unknown filter byte (per-row filter ∈ {0,1,2,3,4} per spec § 9)

# ---- IHDR struct layout (sub-bite (b)) -----------------------------
# Caller passes a ≥32-byte buffer; png_decode_header populates four
# i64 slots:
#   +0   width
#   +8   height
#   +16  bit_depth
#   +24  color_type
# Compression / filter / interlace bytes per PNG spec § 11.2.2 are
# always 0 for v0.4.0 scope (Adam7 + sub-byte depths rejected at
# M3 per the roadmap); deferred until they actually mean something.
var IHDR_WIDTH_OFFSET      = 0;
var IHDR_HEIGHT_OFFSET     = 8;
var IHDR_BIT_DEPTH_OFFSET  = 16;
var IHDR_COLOR_TYPE_OFFSET = 24;

# IHDR chunk on disk: 4 (length) + 4 (type "IHDR") + 13 (data) +
# 4 (CRC32) = 25 bytes immediately after the 8-byte signature.
var PNG_IHDR_CHUNK_LEN = 25;

# ---- structural-decode struct (sub-bite (c)+) ----------------------
# Caller passes a ≥80-byte buffer to png_decode_structure; on
# PNG_OK we populate ten i64 slots:
#   +0   width             ┐
#   +8   height            │ same layout as IHDR_*_OFFSET so
#   +16  bit_depth         │ _print_ihdr_summary works on both
#   +24  color_type        ┘
#   +32  idat_count        — number of IDAT chunks seen
#   +40  idat_total_size   — sum of IDAT data-section lengths (sankoch fodder at M3)
#   +48  seen_iend         — 0/1; 0 means EOF before IEND (warning, not error)
#   +56  interlace         — PNG spec § 11.2.2 byte 12 of IHDR data (0 = none, 1 = Adam7)
#   +64  idat_buf          — alloc'd ptr (size = idat_total_size); concat'd IDAT data
#                            for sankoch zlib_decompress at M3(c). 0 if no IDATs.
#   +72  (reserved for future M3 fields)
var STRUCT_WIDTH_OFFSET           = 0;
var STRUCT_HEIGHT_OFFSET          = 8;
var STRUCT_BIT_DEPTH_OFFSET       = 16;
var STRUCT_COLOR_TYPE_OFFSET      = 24;
var STRUCT_IDAT_COUNT_OFFSET      = 32;
var STRUCT_IDAT_TOTAL_SIZE_OFFSET = 40;
var STRUCT_SEEN_IEND_OFFSET       = 48;
var STRUCT_INTERLACE_OFFSET       = 56;
var STRUCT_IDAT_BUF_OFFSET        = 64;
var STRUCT_PIXELS_BUF_OFFSET      = 72;   # alloc'd, populated by png_decode_pixels (M3(c)+)
var STRUCT_PIXELS_SIZE_OFFSET     = 80;   # decoded pixel-buf byte count (= height × width × bpp)
var STRUCT_PLTE_BUF_OFFSET        = 88;   # alloc'd, populated by phase-1 walker on PLTE chunk (M4(c)+)
var STRUCT_PLTE_SIZE_OFFSET       = 96;   # PLTE chunk data length (multiple of 3, max 768 per spec § 11.2.3)

# ---- CRC32 (PNG spec § 5.3) ----------------------------------------
# Standard "Ethernet" CRC-32 reversed polynomial 0xEDB88320 (same
# as zlib / gzip / Ethernet). Implementation: 256-entry lookup
# table, built once at startup. Module-scope `var arr[256]` =
# 256 × u64 slots per CLAUDE.md var-array convention; we use the
# low 32 bits of each slot. Table is the first first-party CRC32
# in the AGNOS ecosystem (grep showed no stdlib consumer) — if a
# second consumer surfaces it extracts to stdlib per the
# extract-on-2nd-consumer pattern.
var _PNG_CRC_TABLE[256];
var _png_crc_table_inited = 0;

# Idempotent table builder. Cheap to over-call (first guard
# returns immediately). Called from png_decode_*/png_crc32 so
# callers never need to remember; main.cyr also calls it once at
# startup for cache warmth.
fn png_crc_init(): i64 {
    if (_png_crc_table_inited == 1) { return 0; }
    var i = 0;
    while (i < 256) {
        var c = i;
        var k = 0;
        while (k < 8) {
            if ((c & 1) == 1) {
                c = (c >> 1) ^ 0xEDB88320;
            } else {
                c = c >> 1;
            }
            k = k + 1;
        }
        store64(&_PNG_CRC_TABLE + i * 8, c);
        i = i + 1;
    }
    _png_crc_table_inited = 1;
    return 0;
}

# Streaming CRC update primitive. `crc` is the running register
# (init to 0xFFFFFFFF for a fresh CRC). Returns the new register
# value. Callers fold pieces of a chunk in sequence (type, data
# stream), then xor-with-0xFFFFFFFF at the end to get the final.
# Used by both png_crc32 (one-shot) and the chunk walker (which
# streams chunk data through a 4 KB scratch buffer to bound
# memory regardless of chunk size).
fn _png_crc_update(crc, buf, len): i64 {
    var c = crc;
    var i = 0;
    while (i < len) {
        var idx = (c ^ load8(buf + i)) & 0xFF;
        c = load64(&_PNG_CRC_TABLE + idx * 8) ^ (c >> 8);
        i = i + 1;
    }
    return c;
}

# One-shot CRC32 over `len` bytes at `buf`. Lazy-inits the table
# (defensive — png_decode_* also calls png_crc_init eagerly).
fn png_crc32(buf, len): i64 {
    if (_png_crc_table_inited == 0) { png_crc_init(); }
    return _png_crc_update(0xFFFFFFFF, buf, len) ^ 0xFFFFFFFF;
}

# ---- chunk-type predicates -----------------------------------------
# 4-byte chunk type comparison. Chunk types are case-sensitive ASCII
# per spec § 5.4 (case bit also carries ancillary/private/safe-to-copy
# semantics; for IDAT/IEND the case is fixed). Helpers used by both
# walker passes (phase 1 validates, phase 2 copies).
fn _png_is_idat(type_buf): i64 {
    if (load8(type_buf + 0) == 0x49 &&
        load8(type_buf + 1) == 0x44 &&
        load8(type_buf + 2) == 0x41 &&
        load8(type_buf + 3) == 0x54) { return 1; }
    return 0;
}

fn _png_is_iend(type_buf): i64 {
    if (load8(type_buf + 0) == 0x49 &&
        load8(type_buf + 1) == 0x45 &&
        load8(type_buf + 2) == 0x4E &&
        load8(type_buf + 3) == 0x44) { return 1; }
    return 0;
}

# PLTE chunk type ("PLTE" = 0x50 0x4C 0x54 0x45). Mandatory for
# color_type=3 (palette PNGs) and must precede the first IDAT
# per spec § 5.5; M4(c) captures the bytes during phase 1 so
# M4(d)'s quantizer can do RGB lookup for color_type=3 inputs.
fn _png_is_plte(type_buf): i64 {
    if (load8(type_buf + 0) == 0x50 &&
        load8(type_buf + 1) == 0x4C &&
        load8(type_buf + 2) == 0x54 &&
        load8(type_buf + 3) == 0x45) { return 1; }
    return 0;
}

# Phase-2 IDAT copier. Called after png_decode_structure's phase 1
# walker has validated the file and computed idat_total_size.
# Re-opens the file (no lseek to keep things portable), skips past
# signature + IHDR, walks chunks again, copies IDAT data into
# `idat_buf` at offset `bytes_copied`. Non-IDAT chunk data is
# streamed past via a 4 KB scratch buf — we don't re-validate CRC
# in phase 2 (phase 1 already did that).
#
# Returns bytes copied (should equal expected_total) or -1 on
# I/O failure.
fn _png_copy_idat(path, idat_buf, expected_total): i64 {
    var fd_res = file_open_r(path, O_RDONLY, 0);
    if (is_err_result(fd_res) == 1) { return 0 - 1; }
    var fd = result_unwrap(fd_res);

    # Skip 8-byte signature + 25-byte IHDR chunk in one read.
    var skip[64];
    var skip_res = file_read_r(fd, &skip, 33);
    if (is_err_result(skip_res) == 1)         { file_close(fd); return 0 - 1; }
    if (result_unwrap(skip_res) < 33)         { file_close(fd); return 0 - 1; }

    var bytes_copied = 0;
    var walking = 1;
    while (walking == 1) {
        var hdr[16];
        var hdr_res = file_read_r(fd, &hdr, 8);
        if (is_err_result(hdr_res) == 1) { file_close(fd); return 0 - 1; }
        var n_hdr = result_unwrap(hdr_res);
        if (n_hdr == 0) { walking = 0; }
        else { if (n_hdr < 8)             { file_close(fd); return 0 - 1; }
        else {

        var chunk_len = png_read_u32_be(&hdr, 0);
        var is_idat   = _png_is_idat(&hdr + 4);
        var is_iend   = _png_is_iend(&hdr + 4);

        if (is_idat == 1) {
            # Read directly into idat_buf at the running offset.
            # chunk_len can be 0 (degenerate but spec-legal); guard
            # against negative dst pointer arithmetic.
            if (chunk_len > 0) {
                var rd = file_read_r(fd, idat_buf + bytes_copied, chunk_len);
                if (is_err_result(rd) == 1)             { file_close(fd); return 0 - 1; }
                if (result_unwrap(rd) < chunk_len)      { file_close(fd); return 0 - 1; }
                bytes_copied = bytes_copied + chunk_len;
            }
        } else {
            # Stream past non-IDAT chunk via scratch buf.
            var scratch[4096];
            var remaining = chunk_len;
            while (remaining > 0) {
                var to_read = remaining;
                if (to_read > 4096) { to_read = 4096; }
                var rd = file_read_r(fd, &scratch, to_read);
                if (is_err_result(rd) == 1)         { file_close(fd); return 0 - 1; }
                if (result_unwrap(rd) < to_read)    { file_close(fd); return 0 - 1; }
                remaining = remaining - to_read;
            }
        }

        # Skip 4-byte CRC (validated in phase 1). Read-and-discard
        # to advance the fd position.
        var crc_skip[8];
        file_read_r(fd, &crc_skip, 4);

        if (is_iend == 1) { walking = 0; }

        } }
    }
    file_close(fd);
    return bytes_copied;
}

# Pure in-memory signature check. Caller guarantees `buf` has at
# least PNG_MAGIC_LEN bytes. Returns 1 if those bytes match the
# magic, 0 otherwise. Leans on lib/string.cyr's `memeq` rather
# than rolling a byte-by-byte loop (same primitive, but memeq is
# the shared idiom across the ecosystem — see anuenue/_compat,
# bannermanor/font_block).
fn png_check_signature(buf): i64 {
    return memeq(buf, PNG_MAGIC, PNG_MAGIC_LEN);
}

# Big-endian u32 read at byte offset `off` within `buf`. PNG is
# big-endian throughout per spec § 7. Same pattern as
# lib/sha1.cyr line 92 — keeps the ecosystem on one idiom rather
# than scattering ad-hoc byte-reassembly across decoders.
fn png_read_u32_be(buf, off): i64 {
    var b0 = load8(buf + off + 0);
    var b1 = load8(buf + off + 1);
    var b2 = load8(buf + off + 2);
    var b3 = load8(buf + off + 3);
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;
}

# File-level signature validator. Opens `path`, reads 8 bytes,
# closes, checks magic. Returns one of the PNG_* codes above.
# Uses the Result-returning *_r io variants so each failure mode
# (open vs read) is distinguishable; we collapse them into kii's
# coarser error space at the boundary. Used by M2(a) tests +
# kept as a stable API surface; main.cyr's dispatch path went
# through png_decode_header (which reads signature + IHDR in
# one fd open) starting at M2(b).
fn png_validate_file_signature(path): i64 {
    var fd_res = file_open_r(path, O_RDONLY, 0);
    if (is_err_result(fd_res) == 1) {
        return PNG_ERR_OPEN;
    }
    var fd = result_unwrap(fd_res);

    var buf[16];                              # 16 ≥ PNG_MAGIC_LEN; rounded to nice multiple
    var n_res = file_read_r(fd, &buf, PNG_MAGIC_LEN);
    file_close(fd);                           # close even on partial read

    if (is_err_result(n_res) == 1) {
        return PNG_ERR_OPEN;
    }
    var n = result_unwrap(n_res);
    if (n < PNG_MAGIC_LEN) {
        return PNG_ERR_TRUNCATED;
    }
    if (png_check_signature(&buf) == 0) {
        return PNG_ERR_NOT_PNG;
    }
    return PNG_OK;
}

# Read + validate signature, then read + parse IHDR. Caller
# stack-allocates `out_ihdr` (≥32 bytes); on PNG_OK it holds
# width / height / bit_depth / color_type at the IHDR_*_OFFSET
# slots. Single fd open across both reads — sub-bite (c)'s chunk
# walker extends this same fd lifetime past IHDR through IDAT/
# IEND. CRC32 validation lands at sub-bite (c); (b) skips it.
fn png_decode_header(path, out_ihdr): i64 {
    var fd_res = file_open_r(path, O_RDONLY, 0);
    if (is_err_result(fd_res) == 1) { return PNG_ERR_OPEN; }
    var fd = result_unwrap(fd_res);

    # Signature read. Identical logic to png_validate_file_signature
    # but inlined to keep the fd lifetime intact.
    var sig[16];
    var sig_res = file_read_r(fd, &sig, PNG_MAGIC_LEN);
    if (is_err_result(sig_res) == 1) { file_close(fd); return PNG_ERR_OPEN; }
    if (result_unwrap(sig_res) < PNG_MAGIC_LEN) { file_close(fd); return PNG_ERR_TRUNCATED; }
    if (png_check_signature(&sig) == 0)         { file_close(fd); return PNG_ERR_NOT_PNG; }

    # IHDR chunk read. 25 bytes total: 4-byte length, 4-byte type,
    # 13-byte data, 4-byte CRC. Short read = truncated = malformed.
    var ihdr[32];
    var ihdr_res = file_read_r(fd, &ihdr, PNG_IHDR_CHUNK_LEN);
    file_close(fd);
    if (is_err_result(ihdr_res) == 1)                  { return PNG_ERR_HEADER; }
    if (result_unwrap(ihdr_res) < PNG_IHDR_CHUNK_LEN)  { return PNG_ERR_HEADER; }

    # Length field must be exactly 13 per spec § 11.2.2.
    var chunk_len = png_read_u32_be(&ihdr, 0);
    if (chunk_len != 13) { return PNG_ERR_HEADER; }

    # Type field must be "IHDR" — bytes 'I' 'H' 'D' 'R' = 0x49 48 44 52.
    if (load8(&ihdr + 4) != 0x49) { return PNG_ERR_HEADER; }
    if (load8(&ihdr + 5) != 0x48) { return PNG_ERR_HEADER; }
    if (load8(&ihdr + 6) != 0x44) { return PNG_ERR_HEADER; }
    if (load8(&ihdr + 7) != 0x52) { return PNG_ERR_HEADER; }

    # CRC32 (sub-bite (c)). Validates bytes 4..20 (type + data, 17
    # bytes) against the stored CRC at bytes 21..24. PNG spec § 5.3
    # — the length field is NOT included in the CRC.
    png_crc_init();
    var ihdr_crc = png_crc32(&ihdr + 4, 17);
    var stored_crc = png_read_u32_be(&ihdr, 21);
    if (ihdr_crc != stored_crc) { return PNG_ERR_CRC; }

    # Data region starts at offset 8 within the chunk buffer.
    #   bytes 8..11   width  (u32 BE)
    #   bytes 12..15  height (u32 BE)
    #   byte  16      bit_depth
    #   byte  17      color_type
    #   bytes 18..20  compression / filter / interlace  (deferred)
    store64(out_ihdr + IHDR_WIDTH_OFFSET,      png_read_u32_be(&ihdr, 8));
    store64(out_ihdr + IHDR_HEIGHT_OFFSET,     png_read_u32_be(&ihdr, 12));
    store64(out_ihdr + IHDR_BIT_DEPTH_OFFSET,  load8(&ihdr + 16));
    store64(out_ihdr + IHDR_COLOR_TYPE_OFFSET, load8(&ihdr + 17));
    return PNG_OK;
}

# Full structural decode: signature + IHDR + chunk walk through
# IEND. Validates CRC on every chunk. Caller stack-allocates
# `out_struct` (≥64 bytes); on PNG_OK we populate STRUCT_*
# slots. Missing IEND is NOT an error per spec § 5.3
# tolerance — we set seen_iend=0 and return PNG_OK so the
# caller can warn but still emit the IHDR summary.
#
# Chunk data is streamed through a 4 KB scratch buffer (not
# buffered whole) so the worst-case memory cost is bounded
# regardless of input size. IDAT data isn't kept at M2; we
# accumulate count + total size for M3's sankoch DEFLATE
# consumer to allocate against.
fn png_decode_structure(path, out_struct): i64 {
    png_crc_init();

    var fd_res = file_open_r(path, O_RDONLY, 0);
    if (is_err_result(fd_res) == 1) { return PNG_ERR_OPEN; }
    var fd = result_unwrap(fd_res);

    # ---- signature (same logic as png_validate_file_signature) ----
    var sig[16];
    var sig_res = file_read_r(fd, &sig, PNG_MAGIC_LEN);
    if (is_err_result(sig_res) == 1)                 { file_close(fd); return PNG_ERR_OPEN; }
    if (result_unwrap(sig_res) < PNG_MAGIC_LEN)      { file_close(fd); return PNG_ERR_TRUNCATED; }
    if (png_check_signature(&sig) == 0)              { file_close(fd); return PNG_ERR_NOT_PNG; }

    # ---- IHDR chunk (same shape as png_decode_header) -------------
    var ihdr[32];
    var ihdr_res = file_read_r(fd, &ihdr, PNG_IHDR_CHUNK_LEN);
    if (is_err_result(ihdr_res) == 1)                { file_close(fd); return PNG_ERR_HEADER; }
    if (result_unwrap(ihdr_res) < PNG_IHDR_CHUNK_LEN){ file_close(fd); return PNG_ERR_HEADER; }
    if (png_read_u32_be(&ihdr, 0) != 13)             { file_close(fd); return PNG_ERR_HEADER; }
    if (load8(&ihdr + 4) != 0x49)                    { file_close(fd); return PNG_ERR_HEADER; }
    if (load8(&ihdr + 5) != 0x48)                    { file_close(fd); return PNG_ERR_HEADER; }
    if (load8(&ihdr + 6) != 0x44)                    { file_close(fd); return PNG_ERR_HEADER; }
    if (load8(&ihdr + 7) != 0x52)                    { file_close(fd); return PNG_ERR_HEADER; }
    var ihdr_crc   = png_crc32(&ihdr + 4, 17);
    var stored_crc = png_read_u32_be(&ihdr, 21);
    if (ihdr_crc != stored_crc)                      { file_close(fd); return PNG_ERR_CRC; }

    store64(out_struct + STRUCT_WIDTH_OFFSET,      png_read_u32_be(&ihdr, 8));
    store64(out_struct + STRUCT_HEIGHT_OFFSET,     png_read_u32_be(&ihdr, 12));
    store64(out_struct + STRUCT_BIT_DEPTH_OFFSET,  load8(&ihdr + 16));
    store64(out_struct + STRUCT_COLOR_TYPE_OFFSET, load8(&ihdr + 17));
    # Interlace byte: IHDR data offset 12 within the chunk's 13-
    # byte data region, which is offset 20 in the 25-byte ihdr buf
    # (4 length + 4 type + 12 = 20). 0 = no interlace, 1 = Adam7.
    # M3(c) rejects interlace=1; (b) just captures.
    store64(out_struct + STRUCT_INTERLACE_OFFSET,  load8(&ihdr + 20));

    # ---- chunk walk through IEND ----------------------------------
    var idat_count = 0;
    var idat_total = 0;
    var seen_iend  = 0;
    var walking    = 1;

    while (walking == 1) {
        # Try to read the 8-byte chunk header (length + type).
        # Zero bytes = clean EOF without IEND (warning, not error).
        var hdr_buf[16];
        var hdr_rd = file_read_r(fd, &hdr_buf, 8);
        if (is_err_result(hdr_rd) == 1) { file_close(fd); return PNG_ERR_CHUNK; }
        var n_hdr = result_unwrap(hdr_rd);
        if (n_hdr == 0) { walking = 0; }
        else { if (n_hdr < 8) { file_close(fd); return PNG_ERR_CHUNK; }
        else {

        var chunk_len = png_read_u32_be(&hdr_buf, 0);
        var is_idat   = _png_is_idat(&hdr_buf + 4);
        var is_iend   = _png_is_iend(&hdr_buf + 4);
        var is_plte   = _png_is_plte(&hdr_buf + 4);

        # PLTE pre-alloc (M4(c)): the spec § 11.2.3 caps PLTE at
        # 768 bytes (256 entries × 3) and requires length to be a
        # multiple of 3. Reject malformed PLTE at the structural
        # layer — quantizer downstream relies on the invariant.
        var plte_chunk_buf = 0;
        if (is_plte == 1) {
            if (chunk_len > 768)    { file_close(fd); return PNG_ERR_HEADER; }
            if (chunk_len % 3 != 0) { file_close(fd); return PNG_ERR_HEADER; }
            if (chunk_len > 0) {
                plte_chunk_buf = alloc(chunk_len);
                if (plte_chunk_buf == 0) { file_close(fd); return PNG_ERR_CHUNK; }
            }
        }

        # Initialize streaming CRC; fold in type bytes.
        var crc = 0xFFFFFFFF;
        crc = _png_crc_update(crc, &hdr_buf + 4, 4);

        # Stream data through a 4 KB scratch buffer. Bounded
        # memory regardless of chunk_len. For PLTE chunks (max
        # 768 B) we ALSO memcpy each scratch read into the pre-
        # allocated plte_chunk_buf so the bytes survive past the
        # walker; the loop body runs once for PLTE in practice.
        var scratch[4096];
        var remaining = chunk_len;
        var plte_off  = 0;
        while (remaining > 0) {
            var to_read = remaining;
            if (to_read > 4096) { to_read = 4096; }
            var rd = file_read_r(fd, &scratch, to_read);
            if (is_err_result(rd) == 1) { file_close(fd); return PNG_ERR_CHUNK; }
            var n = result_unwrap(rd);
            if (n < to_read) { file_close(fd); return PNG_ERR_CHUNK; }
            crc = _png_crc_update(crc, &scratch, n);
            if (is_plte == 1) {
                memcpy(plte_chunk_buf + plte_off, &scratch, n);
                plte_off = plte_off + n;
            }
            remaining = remaining - n;
        }
        crc = crc ^ 0xFFFFFFFF;

        # Read 4-byte stored CRC; compare against streamed.
        var crc_buf[8];
        var crc_rd = file_read_r(fd, &crc_buf, 4);
        if (is_err_result(crc_rd) == 1) { file_close(fd); return PNG_ERR_CHUNK; }
        if (result_unwrap(crc_rd) < 4)  { file_close(fd); return PNG_ERR_CHUNK; }
        var stored = png_read_u32_be(&crc_buf, 0);
        if (crc != stored) { file_close(fd); return PNG_ERR_CRC; }

        if (is_idat == 1) {
            idat_count = idat_count + 1;
            idat_total = idat_total + chunk_len;
        }
        if (is_iend == 1) {
            seen_iend = 1;
            walking = 0;
        }
        if (is_plte == 1) {
            # Only commit to the struct after CRC validates —
            # otherwise corrupt PLTE could leak un-validated
            # bytes to the quantizer.
            store64(out_struct + STRUCT_PLTE_BUF_OFFSET,  plte_chunk_buf);
            store64(out_struct + STRUCT_PLTE_SIZE_OFFSET, chunk_len);
        }

        } }
    }

    file_close(fd);
    store64(out_struct + STRUCT_IDAT_COUNT_OFFSET,      idat_count);
    store64(out_struct + STRUCT_IDAT_TOTAL_SIZE_OFFSET, idat_total);
    store64(out_struct + STRUCT_SEEN_IEND_OFFSET,       seen_iend);

    # ---- phase 2: alloc + copy IDAT data --------------------------
    # Only allocate if there are IDATs. Phase 1 already validated
    # CRCs and chunk structure; phase 2 trusts that and just
    # streams bytes. Re-open the file (no lseek dependency) —
    # cost is one extra open syscall per PNG decode, well under
    # 100µs on a warm-cache tmpfs path.
    var idat_buf = 0;
    if (idat_total > 0) {
        idat_buf = alloc(idat_total);
        if (idat_buf == 0) { return PNG_ERR_CHUNK; }   # OOM repurposes ERR_CHUNK; rare in practice
        var copied = _png_copy_idat(path, idat_buf, idat_total);
        if (copied != idat_total) { return PNG_ERR_CHUNK; }
    }
    store64(out_struct + STRUCT_IDAT_BUF_OFFSET, idat_buf);
    return PNG_OK;
}

# ---- pixel decode (sub-bite (c)) -----------------------------------
# Color-type → human-readable name. Used by the M3 success line
# (`<path>: <W>x<H> decoded <N> pixels (<name>)`). Names are the
# short forms used in the PNG spec § 11.2.2 prose; `?` is the
# defensive fallback for unknown color types (png_decode_pixels
# rejects those via PNG_ERR_BITDEPTH, so this branch shouldn't
# normally fire in practice).
fn png_color_type_name(color_type): i64 {
    if (color_type == 0) { return "greyscale"; }
    if (color_type == 2) { return "RGB"; }
    if (color_type == 3) { return "palette"; }
    if (color_type == 4) { return "grey+alpha"; }
    if (color_type == 6) { return "RGBA"; }
    return "?";
}

# Color-type → channels-per-pixel per spec § 11.2.2 / Table 11.1:
#   0 greyscale    → 1
#   2 RGB          → 3
#   3 palette      → 1 (output is palette index; PLTE→RGB lookup is M4)
#   4 grey+alpha   → 2
#   6 RGBA         → 4
# Returns -1 for unknown color_type. Used to derive bytes-per-pixel
# for row-size + filter undo math.
fn _png_color_channels(color_type): i64 {
    if (color_type == 0) { return 1; }
    if (color_type == 2) { return 3; }
    if (color_type == 3) { return 1; }
    if (color_type == 4) { return 2; }
    if (color_type == 6) { return 4; }
    return 0 - 1;
}

# PNG filter type 4 (Paeth) predictor — spec § 9.4. Given the
# byte to the left (a), the byte above (b), and the byte above-
# left (c), picks whichever of the three is "closest" to a+b-c
# in absolute-value distance. Ties broken left → up → up-left,
# matching the spec's order.
fn _png_paeth(a, b, c): i64 {
    var p = a + b - c;
    var pa = p - a; if (pa < 0) { pa = 0 - pa; }
    var pb = p - b; if (pb < 0) { pb = 0 - pb; }
    var pc = p - c; if (pc < 0) { pc = 0 - pc; }
    if (pa <= pb && pa <= pc) { return a; }
    if (pb <= pc) { return b; }
    return c;
}

# Apply a single row's filter undo. Spec § 9: each row in the
# inflated IDAT stream is prefixed with a filter-type byte (0–4),
# followed by `row_bytes` of filtered data. We reconstruct the
# raw row into `out_row` using the previous row's RAW (post-undo)
# bytes — caller is responsible for passing zero-row for row 0.
# `bpp` is bytes-per-pixel (1/2/3/4/6/8 for tier-1 scope).
# Returns 0 on success, -1 if filter_type ∉ {0,1,2,3,4}.
fn _png_unfilter_row(prev_row, curr_in, out_row, row_bytes, bpp, filter_type): i64 {
    var i = 0;
    if (filter_type == 0) {
        # None — passthrough.
        while (i < row_bytes) {
            store8(out_row + i, load8(curr_in + i));
            i = i + 1;
        }
        return 0;
    }
    if (filter_type == 1) {
        # Sub — out[i] = in[i] + (i<bpp ? 0 : out[i-bpp])
        while (i < row_bytes) {
            var left = 0;
            if (i >= bpp) { left = load8(out_row + i - bpp); }
            store8(out_row + i, (load8(curr_in + i) + left) & 0xFF);
            i = i + 1;
        }
        return 0;
    }
    if (filter_type == 2) {
        # Up — out[i] = in[i] + prev[i]
        while (i < row_bytes) {
            var up = load8(prev_row + i);
            store8(out_row + i, (load8(curr_in + i) + up) & 0xFF);
            i = i + 1;
        }
        return 0;
    }
    if (filter_type == 3) {
        # Average — out[i] = in[i] + floor((left + up) / 2)
        while (i < row_bytes) {
            var left = 0;
            if (i >= bpp) { left = load8(out_row + i - bpp); }
            var up = load8(prev_row + i);
            store8(out_row + i, (load8(curr_in + i) + ((left + up) / 2)) & 0xFF);
            i = i + 1;
        }
        return 0;
    }
    if (filter_type == 4) {
        # Paeth — out[i] = in[i] + paeth(left, up, up-left)
        while (i < row_bytes) {
            var left    = 0;
            var up_left = 0;
            if (i >= bpp) {
                left    = load8(out_row + i - bpp);
                up_left = load8(prev_row + i - bpp);
            }
            var up = load8(prev_row + i);
            store8(out_row + i, (load8(curr_in + i) + _png_paeth(left, up, up_left)) & 0xFF);
            i = i + 1;
        }
        return 0;
    }
    return 0 - 1;
}

# Decode IDAT bytes into raw pixels. Takes the populated pstruct
# from png_decode_structure, applies M3 rejection rules (Adam7
# + sub-byte bit-depths), inflates via sankoch's zlib_decompress,
# walks rows applying filter undo per spec § 9. On success:
#   - STRUCT_PIXELS_BUF_OFFSET  ← alloc'd ptr to raw pixel data
#   - STRUCT_PIXELS_SIZE_OFFSET ← byte count (= h × w × bpp)
# Palette-typed PNGs (color_type=3) emit palette INDICES at this
# layer; PLTE → RGB lookup is M4+ scope.
fn png_decode_pixels(pstruct): i64 {
    var width      = load64(pstruct + STRUCT_WIDTH_OFFSET);
    var height     = load64(pstruct + STRUCT_HEIGHT_OFFSET);
    var bit_depth  = load64(pstruct + STRUCT_BIT_DEPTH_OFFSET);
    var color_type = load64(pstruct + STRUCT_COLOR_TYPE_OFFSET);
    var interlace  = load64(pstruct + STRUCT_INTERLACE_OFFSET);
    var idat_buf   = load64(pstruct + STRUCT_IDAT_BUF_OFFSET);
    var idat_total = load64(pstruct + STRUCT_IDAT_TOTAL_SIZE_OFFSET);

    # ---- M3 rejection rules ----
    # Adam7 interlacing is post-v1 scope per CLAUDE.md color-tier
    # / format discipline. Defer-don't-half-implement.
    if (interlace != 0) { return PNG_ERR_INTERLACE; }
    # Sub-byte bit-depths (1/2/4) require bit-unpacking — also
    # post-v1 scope. tier-1 = 8 and 16 only.
    if (bit_depth != 8 && bit_depth != 16) { return PNG_ERR_BITDEPTH; }
    var channels = _png_color_channels(color_type);
    if (channels < 0) { return PNG_ERR_BITDEPTH; }
    # No IDAT data at all — structurally valid PNG but nothing
    # to decode.
    if (idat_buf == 0 || idat_total == 0) { return PNG_ERR_NO_IDAT; }

    # ---- size math ----
    # bit_depth ∈ {8,16} ⇒ bytes-per-channel ∈ {1,2}. bpp is
    # whole-byte at tier-1 (sub-byte unpacking deferred).
    var bpp           = channels * (bit_depth / 8);
    var row_bytes     = width * bpp;
    var inflated_size = height * (1 + row_bytes);   # 1 filter byte per row
    var pixel_size    = height * row_bytes;

    # ---- inflate ----
    var inflated = alloc(inflated_size);
    if (inflated == 0) { return PNG_ERR_INFLATE; }
    var n = zlib_decompress(idat_buf, idat_total, inflated, inflated_size);
    if (n < 0)              { return PNG_ERR_INFLATE; }
    if (n != inflated_size) { return PNG_ERR_INFLATE; }

    # ---- filter undo ----
    var pixels   = alloc(pixel_size);
    var zero_row = alloc(row_bytes);
    if (pixels == 0 || zero_row == 0) { return PNG_ERR_INFLATE; }
    var z = 0;
    while (z < row_bytes) { store8(zero_row + z, 0); z = z + 1; }

    var prev = zero_row;
    var r = 0;
    while (r < height) {
        var row_off     = r * (1 + row_bytes);
        var filter_byte = load8(inflated + row_off);
        var curr_in     = inflated + row_off + 1;
        var out_row     = pixels + r * row_bytes;
        var rc = _png_unfilter_row(prev, curr_in, out_row, row_bytes, bpp, filter_byte);
        if (rc != 0) { return PNG_ERR_FILTER; }
        prev = out_row;
        r = r + 1;
    }

    store64(pstruct + STRUCT_PIXELS_BUF_OFFSET,  pixels);
    store64(pstruct + STRUCT_PIXELS_SIZE_OFFSET, pixel_size);
    return PNG_OK;
}
