# quant.cyr — RGB → 16-color ANSI palette quantization.
#
# v1.0 tier-1 floor: nearest-neighbor in Euclidean RGB space.
# Skips the sqrt (monotonic for minimum-finding, saves a
# transcendental per pixel). Linear-scan all 16 palette entries.
#
# CIE Lab distance + perceptual color spaces + Floyd-Steinberg /
# ordered dither are explicit post-v1 scope per CLAUDE.md
# tier-1 color discipline. Higher-fidelity quantization can
# replace this module's internals without changing the public
# API (palette_idx in, palette_idx out).
#
# Multi-source convergent port: shape drawn from chafa's
# `chafa-canvas.c` glyph-selection (color-quantization micro-
# pattern), `libcaca`'s color picker, and the Wikipedia
# "Color quantization" article's vanilla algorithm. No
# single-source pin.

include "src/palette.cyr"
include "src/png.cyr"

# Squared Euclidean distance in RGB space between two color
# triples. Skips the sqrt — for minimum-finding we only need
# the ordering, which sqrt preserves. Max value at full RGB
# spread: 3 × 255² = 195,075 — fits comfortably in i64 with
# no overflow concern.
fn _color_dist2(r1, g1, b1, r2, g2, b2): i64 {
    var dr = r1 - r2;
    var dg = g1 - g2;
    var db = b1 - b2;
    return dr * dr + dg * dg + db * db;
}

# Map one RGB triple to the nearest-distance² palette index in
# [0, ANSI_PALETTE_SIZE). Ties resolved by lowest index because
# the loop's `<` (not `<=`) rejects equal-distance challengers.
# Caller passes raw byte channel values (0..255).
fn quantize_nearest_rgb(r, g, b): i64 {
    palette_init();
    # Seed best with entry 0 so the loop body has no sentinel.
    # The palette has ≥ 1 entry by ANSI_PALETTE_SIZE constraint.
    var best_idx = 0;
    var best_d2  = _color_dist2(r, g, b,
                                palette_r(0), palette_g(0), palette_b(0));
    var i = 1;
    while (i < ANSI_PALETTE_SIZE) {
        var d2 = _color_dist2(r, g, b,
                              palette_r(i), palette_g(i), palette_b(i));
        if (d2 < best_d2) {
            best_d2  = d2;
            best_idx = i;
        }
        i = i + 1;
    }
    return best_idx;
}

# NOTE: the M4-era image-wide quantizer `quantize_nearest_image` was
# removed in the PNG re-fold (v1.2.0). It read the native color_type +
# PLTE off pstruct to do per-color_type pixel extraction — but post-flip
# the chitra adapter normalizes every image to depth-8 ct6 RGBA8 (PLTE
# resolved inside chitra), so the function's source-format dispatch had
# no live inputs. The M5+ flow uses downscale_to_rgb (its _extract_rgb
# owns the RGB extraction) → quantize_downscaled instead, and the
# decoder-internal coverage moved to chitra's own tests. See ADR 0006.

# Quantize a packed RGB-triple source buffer into palette indices.
# Writes n_pixels bytes into out_buf (caller-owned). Returns 0 on
# success; never fails (palette_init is idempotent, the loop has
# no allocation, indices are in [0, 15]). Used by quantize_downscaled
# below — exposes the inner loop with no PNG / pstruct knowledge so
# future consumers (animation frames, multi-format decoders) can
# reuse it.
fn quantize_rgb_buf(rgb_buf, n_pixels, out_buf): i64 {
    palette_init();
    var i = 0;
    while (i < n_pixels) {
        var r = load8(rgb_buf + i * 3 + 0);
        var g = load8(rgb_buf + i * 3 + 1);
        var b = load8(rgb_buf + i * 3 + 2);
        store8(out_buf + i, quantize_nearest_rgb(r, g, b));
        i = i + 1;
    }
    return 0;
}

# Struct-aware wrapper: read pstruct's DOWNSCALED_BUF + DOWNSCALED_W
# + DOWNSCALED_H, alloc a (w × h)-byte index buffer, quantize, and
# store ptr + size into the QUANTIZED slots. Returns 0 on success,
# -1 on:
#   - downscale_to_rgb not yet run (DOWNSCALED_BUF == 0)
#   - bad dimensions (w or h <= 0)
#   - alloc failure
#
# This is the M5+ replacement for quantize_nearest_image in the
# main pipeline. The older fn stays for M4-test backward-compat;
# it carries the source-color_type pixel-extraction code path,
# which downscale.cyr now owns for the M5+ flow.
fn quantize_downscaled(pstruct): i64 {
    palette_init();
    var dbuf = load64(pstruct + STRUCT_DOWNSCALED_BUF_OFFSET);
    var dw   = load64(pstruct + STRUCT_DOWNSCALED_W_OFFSET);
    var dh   = load64(pstruct + STRUCT_DOWNSCALED_H_OFFSET);
    if (dbuf == 0)        { return 0 - 1; }
    if (dw <= 0 || dh <= 0) { return 0 - 1; }

    var n_pixels = dw * dh;
    var out_buf = alloc(n_pixels);
    if (out_buf == 0) { return 0 - 1; }

    quantize_rgb_buf(dbuf, n_pixels, out_buf);
    store64(pstruct + STRUCT_QUANTIZED_BUF_OFFSET,  out_buf);
    store64(pstruct + STRUCT_QUANTIZED_SIZE_OFFSET, n_pixels);
    return 0;
}
