# quant.cyr — RGB → 16-color ANSI palette quantization.
#
# v1.0 tier-1 floor: nearest-neighbor in Euclidean RGB space.
# Skips the sqrt (monotonic for minimum-finding, saves a
# transcendental per pixel). Linear-scan all 16 palette entries.
#
# CIE Lab distance + perceptual color spaces + Floyd-Steinberg /
# ordered dither are explicit post-v1 scope per CLAUDE.md
# tier-1 color discipline. Higher-fidelity quantization can
# replace this module's internals without changing the public
# API (palette_idx in, palette_idx out).
#
# Multi-source convergent port: shape drawn from chafa's
# `chafa-canvas.c` glyph-selection (color-quantization micro-
# pattern), `libcaca`'s color picker, and the Wikipedia
# "Color quantization" article's vanilla algorithm. No
# single-source pin.

include "src/palette.cyr"
include "src/png.cyr"

# Squared Euclidean distance in RGB space between two color
# triples. Skips the sqrt — for minimum-finding we only need
# the ordering, which sqrt preserves. Max value at full RGB
# spread: 3 × 255² = 195,075 — fits comfortably in i64 with
# no overflow concern.
fn _color_dist2(r1, g1, b1, r2, g2, b2): i64 {
    var dr = r1 - r2;
    var dg = g1 - g2;
    var db = b1 - b2;
    return dr * dr + dg * dg + db * db;
}

# Map one RGB triple to the nearest-distance² palette index in
# [0, ANSI_PALETTE_SIZE). Ties resolved by lowest index because
# the loop's `<` (not `<=`) rejects equal-distance challengers.
# Caller passes raw byte channel values (0..255).
fn quantize_nearest_rgb(r, g, b): i64 {
    palette_init();
    # Seed best with entry 0 so the loop body has no sentinel.
    # The palette has ≥ 1 entry by ANSI_PALETTE_SIZE constraint.
    var best_idx = 0;
    var best_d2  = _color_dist2(r, g, b,
                                palette_r(0), palette_g(0), palette_b(0));
    var i = 1;
    while (i < ANSI_PALETTE_SIZE) {
        var d2 = _color_dist2(r, g, b,
                              palette_r(i), palette_g(i), palette_b(i));
        if (d2 < best_d2) {
            best_d2  = d2;
            best_idx = i;
        }
        i = i + 1;
    }
    return best_idx;
}

# Walk all pixels in pstruct's decoded buffer, quantize each into
# a 16-color palette index, store the result back into pstruct at
# STRUCT_QUANTIZED_BUF_OFFSET + STRUCT_QUANTIZED_SIZE_OFFSET. One
# output byte per pixel; ordering matches scanline / pixel order
# in the source buffer.
#
# Per-color_type extraction:
#   0 greyscale     — R = G = B = sample byte
#   2 RGB           — straight pass through
#   3 palette        — PLTE-lookup (caller's responsibility to have
#                      PLTE populated; otherwise return -1)
#   4 grey+alpha    — R = G = B = grey sample; alpha dropped
#   6 RGBA          — R/G/B from sample; alpha dropped
#
# For bit_depth=16, each channel takes 2 bytes BE; we take the
# HIGH byte only (truncation quantization). Full-precision 16-bit
# quantization is tier-2 scope per CLAUDE.md color-tier discipline.
#
# Returns 0 on success, -1 on any error (PLTE missing when needed,
# alloc failure, png_decode_pixels not yet run).
fn quantize_nearest_image(pstruct): i64 {
    palette_init();
    var width      = load64(pstruct + STRUCT_WIDTH_OFFSET);
    var height     = load64(pstruct + STRUCT_HEIGHT_OFFSET);
    var bit_depth  = load64(pstruct + STRUCT_BIT_DEPTH_OFFSET);
    var color_type = load64(pstruct + STRUCT_COLOR_TYPE_OFFSET);
    var pixels     = load64(pstruct + STRUCT_PIXELS_BUF_OFFSET);
    var pixel_size = load64(pstruct + STRUCT_PIXELS_SIZE_OFFSET);
    var plte_buf   = load64(pstruct + STRUCT_PLTE_BUF_OFFSET);
    var plte_size  = load64(pstruct + STRUCT_PLTE_SIZE_OFFSET);

    if (pixels == 0)     { return 0 - 1; }
    if (pixel_size <= 0) { return 0 - 1; }
    var channels = _png_color_channels(color_type);
    if (channels < 0) { return 0 - 1; }
    var bps = bit_depth / 8;
    var bpp = channels * bps;
    var n_pixels = width * height;
    if (color_type == 3) {
        if (plte_buf == 0 || plte_size == 0) { return 0 - 1; }
    }
    var out_buf = alloc(n_pixels);
    if (out_buf == 0) { return 0 - 1; }

    # Sequential dispatch on color_type — each branch is mutually
    # exclusive (color_type is a single value), so only one fires
    # per pixel. Cheaper than nested if/elif at the source level
    # and the optimizer hoists the invariant comparisons.
    var i = 0;
    while (i < n_pixels) {
        var pix_off = i * bpp;
        var r = 0; var g = 0; var b = 0;
        if (color_type == 0) {
            # Greyscale: 1 sample × bps bytes per pixel.
            r = load8(pixels + pix_off);
            g = r; b = r;
        }
        if (color_type == 2) {
            # RGB: 3 samples × bps bytes per pixel.
            r = load8(pixels + pix_off);
            g = load8(pixels + pix_off + bps);
            b = load8(pixels + pix_off + 2 * bps);
        }
        if (color_type == 3) {
            # Palette: 1 byte index → PLTE RGB lookup.
            var pi = load8(pixels + pix_off);
            var po = pi * 3;
            # Defensive bounds check: out-of-range indices map to
            # entry 0 (black) rather than reading past the PLTE.
            # Real-world PNGs from libpng-style encoders never emit
            # OOB indices, but malformed input shouldn't crash.
            if (po + 2 < plte_size) {
                r = load8(plte_buf + po);
                g = load8(plte_buf + po + 1);
                b = load8(plte_buf + po + 2);
            }
        }
        if (color_type == 4) {
            # Greyscale + alpha: grey sample + alpha sample.
            r = load8(pixels + pix_off);
            g = r; b = r;
        }
        if (color_type == 6) {
            # RGBA: drop alpha, quantize on RGB only.
            r = load8(pixels + pix_off);
            g = load8(pixels + pix_off + bps);
            b = load8(pixels + pix_off + 2 * bps);
        }
        store8(out_buf + i, quantize_nearest_rgb(r, g, b));
        i = i + 1;
    }

    store64(pstruct + STRUCT_QUANTIZED_BUF_OFFSET,  out_buf);
    store64(pstruct + STRUCT_QUANTIZED_SIZE_OFFSET, n_pixels);
    return 0;
}
