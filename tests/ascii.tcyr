# tests/ascii.tcyr — character-glyph ("ASCII art") rendering mode (kii 1.3.0).
# Covers the luminance ramp + the per-row glyph emit. Standalone suite.
include "src/ascii.cyr"
include "lib/assert.cyr"

# Rec.709 integer luma: 54·R + 183·G + 19·B >> 8 (sum 256).
fn test_ascii_luma() {
    assert_eq(_ascii_luma(255, 255, 255), 255, "white -> 255");
    assert_eq(_ascii_luma(0, 0, 0),         0, "black -> 0");
    assert_eq(_ascii_luma(255, 0, 0),      53, "red -> 53");
    assert_eq(_ascii_luma(0, 255, 0),     182, "green -> 182");
    assert_eq(_ascii_luma(0, 0, 255),      18, "blue -> 18");
    return 0;
}

# Ramp " .:-=+*#%@": idx = luma·9/255. Glyph bytes are ASCII.
fn test_ascii_glyph() {
    assert_eq(_ascii_glyph(0),   32, "luma 0 -> ' ' (32)");
    assert_eq(_ascii_glyph(255), 64, "luma 255 -> '@' (64)");
    assert_eq(_ascii_glyph(29),  46, "luma 29 -> '.' (46)");
    assert_eq(_ascii_glyph(128), 61, "luma 128 -> '=' (61)");
    assert_eq(_ascii_glyph(200), 35, "luma 200 -> '#' (35)");
    return 0;
}

# emit_ascii_row_buf: a 2-cell row (black/idx0, white/idx15) — assert the
# structure (fg escapes + glyphs + per-row reset + LF) by bytes.
fn test_ascii_row_buf() {
    var rgb[8];
    var qbuf[8];
    var out[64];
    store8(&rgb + 0, 0);   store8(&rgb + 1, 0);   store8(&rgb + 2, 0);     # cell0 black
    store8(&rgb + 3, 255); store8(&rgb + 4, 255); store8(&rgb + 5, 255);   # cell1 white
    store8(&qbuf + 0, 0);  store8(&qbuf + 1, 15);
    var pos = emit_ascii_row_buf(&rgb, &qbuf, 2, 0, &out, 0);
    assert(pos > 0, "row_buf returns positive pos");
    # Row ends with the SGR reset (ESC [ 0 m) then LF.
    assert_eq(load8(&out + pos - 1), 10,   "row ends LF");
    assert_eq(load8(&out + pos - 2), 0x6D, "reset 'm'");
    assert_eq(load8(&out + pos - 3), 0x30, "reset '0'");
    assert_eq(load8(&out + pos - 4), 0x5B, "reset '['");
    assert_eq(load8(&out + pos - 5), 0x1B, "reset ESC");
    # Dark cell -> space glyph (32); bright cell -> '@' (64). Neither byte
    # occurs in a 256-color SGR escape, so a scan is unambiguous.
    var saw_space = 0;
    var saw_at = 0;
    var i = 0;
    while (i < pos) {
        var b = load8(&out + i);
        if (b == 32) { saw_space = 1; }
        if (b == 64) { saw_at = 1; }
        i = i + 1;
    }
    assert_eq(saw_space, 1, "dark cell -> ' ' glyph");
    assert_eq(saw_at, 1, "bright cell -> '@' glyph");
    return 0;
}

# emit_ascii rejects an un-run pipeline (null downscaled/quantized bufs).
fn test_ascii_emit_guards() {
    var pstruct[160];
    var z = 0;
    while (z < 160) { store8(&pstruct + z, 0); z = z + 1; }
    assert_eq(emit_ascii(&pstruct), 0 - 1, "null bufs -> -1");
    return 0;
}

fn main() {
    test_ascii_luma();
    test_ascii_glyph();
    test_ascii_row_buf();
    test_ascii_emit_guards();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
