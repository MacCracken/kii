# tests/ascii.tcyr — character-glyph ASCII mode, shape-vector matcher
# (kii 1.3.1). Covers Rec.709 luma, the 6-region nearest-glyph match
# against the coverage table, and the per-row glyph emit. Standalone suite.
include "src/ascii.cyr"
include "lib/assert.cyr"

# Rec.709 integer luma: 54·R + 183·G + 19·B >> 8 (sum 256).
fn test_ascii_luma() {
    assert_eq(_ascii_luma(255, 255, 255), 255, "white -> 255");
    assert_eq(_ascii_luma(0, 0, 0),         0, "black -> 0");
    assert_eq(_ascii_luma(255, 0, 0),      53, "red -> 53");
    assert_eq(_ascii_luma(0, 255, 0),     182, "green -> 182");
    assert_eq(_ascii_luma(0, 0, 255),      18, "blue -> 18");
    return 0;
}

# Helper: build a 6-byte region vector and match it.
fn _mk_match(a, b, c, d, e, f): i64 {
    var v[6];
    store8(&v + 0, a); store8(&v + 1, b); store8(&v + 2, c);
    store8(&v + 3, d); store8(&v + 4, e); store8(&v + 5, f);
    return _ascii_match(&v);
}

# Each glyph's own (normalized) coverage vector must match itself — a
# distance-0 hit, the strongest correctness check on the matcher + table.
fn test_ascii_match() {
    # all-dark -> space (32); also the tie-break to glyph 0.
    assert_eq(_mk_match(0, 0, 0, 0, 0, 0), 32, "all-dark -> ' '");
    # '|' coverage [119,81,119,81,119,81] -> '|' (124).
    assert_eq(_mk_match(119, 81, 119, 81, 119, 81), 124, "center column -> '|'");
    # '/' coverage [2,214,185,33,78,0] -> '/' (47) — the forward diagonal.
    assert_eq(_mk_match(2, 214, 185, 33, 78, 0), 47, "fwd diagonal -> '/'");
    # '@' coverage [223,255,191,248,221,176] -> '@' (64), the densest.
    assert_eq(_mk_match(223, 255, 191, 248, 221, 176), 64, "dense -> '@'");
    # Saturated cell -> the densest glyph '@'.
    assert_eq(_mk_match(255, 255, 255, 255, 255, 255), 64, "all-bright -> '@'");
    return 0;
}

# emit_ascii_shape_row_buf: a 2-cell row (cell0 black, cell1 white) over a
# 4×3 sub-sample buffer (sub_w=4). cell0 -> ' ', cell1 -> '@'.
fn test_ascii_shape_row_buf() {
    var rgb[36];
    var z = 0;
    while (z < 36) { store8(&rgb + z, 0); z = z + 1; }
    # cell1 = sub-columns 2,3 across all 3 rows -> white.
    var sy = 0;
    while (sy < 3) {
        var sx = 2;
        while (sx < 4) {
            var o = (sy * 4 + sx) * 3;
            store8(&rgb + o + 0, 255); store8(&rgb + o + 1, 255); store8(&rgb + o + 2, 255);
            sx = sx + 1;
        }
        sy = sy + 1;
    }
    var out[64];
    var pos = emit_ascii_shape_row_buf(&rgb, 4, 0, 2, &out, 0);
    assert(pos > 0, "row_buf returns positive pos");
    assert_eq(load8(&out + pos - 1), 10,   "row ends LF");
    assert_eq(load8(&out + pos - 2), 0x6D, "reset 'm'");
    assert_eq(load8(&out + pos - 5), 0x1B, "reset ESC");
    # Dark cell -> ' ' (32); white cell -> '@' (64). Neither byte occurs in
    # a 256-color SGR escape, so a scan is unambiguous.
    var saw_space = 0;
    var saw_at = 0;
    var i = 0;
    while (i < pos) {
        var b = load8(&out + i);
        if (b == 32) { saw_space = 1; }
        if (b == 64) { saw_at = 1; }
        i = i + 1;
    }
    assert_eq(saw_space, 1, "dark cell -> ' '");
    assert_eq(saw_at, 1, "white cell -> '@'");
    return 0;
}

# emit_ascii_shape rejects an un-run pipeline (null downscaled buf).
fn test_ascii_shape_guards() {
    var pstruct[160];
    var z = 0;
    while (z < 160) { store8(&pstruct + z, 0); z = z + 1; }
    assert_eq(emit_ascii_shape(&pstruct), 0 - 1, "null buf -> -1");
    return 0;
}

fn main() {
    test_ascii_luma();
    test_ascii_match();
    test_ascii_shape_row_buf();
    test_ascii_shape_guards();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
