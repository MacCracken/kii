# kii benchmarks — M4 quantization + M5 end-to-end latency.
# Stdlib auto-included via cyrius.cyml.
#
# M4 acceptance criterion (docs/development/roadmap.md):
#   "Bench: quantization latency at 1024×1024 captured in
#    docs/benchmarks.md"
# M5 acceptance criterion (docs/development/roadmap.md):
#   "Bench: end-to-end PNG → 80×24 ANSI for RAMGON.png"
#
# Pattern: bench_new → bench_batch_start → tight loop →
# bench_batch_stop → bench_report. For sub-1µs ops use batch_size
# ≥ 1000 to amortize clock_gettime overhead (~240 ns per
# start/stop pair on x86_64 Linux); 1M iterations clears that floor.
# For coarser-grain benches (full pipeline at ~ms-class latency),
# 50 iterations over a real fixture is enough to stabilize median.

include "src/quant.cyr"
include "src/png.cyr"
include "src/downscale.cyr"
include "src/emit.cyr"

# Per-iteration scratch sink for emit_halfblock_row_buf: 2 KB at row
# scope (M5 emit produces at most ~1.7 KB per row at 80 cols × idx 0–15).
# Module-scope `var arr[N]` = N × u64 = 16384 bytes total; we use
# the first 2 KB. Avoids per-iter alloc cost in the bench loop.
var _bench_emit_scratch[2048];

fn main(): i64 {
    alloc_init();
    palette_init();

    # ---- M4 bench: scalar quantizer ---------------------------------
    var bh1 = bench_new("quantize_nearest_rgb @ 1024×1024");
    var n1  = 1048576;
    bench_batch_start(bh1);
    var i = 0;
    while (i < n1) {
        var r  = i & 0xFF;
        var g  = (i >> 8) & 0xFF;
        var bb = (i >> 16) & 0xFF;
        quantize_nearest_rgb(r, g, bb);
        i = i + 1;
    }
    bench_batch_stop(bh1, n1);
    bench_report(bh1);

    # ---- M5/M6 bench: end-to-end RAMGON → terminal-sized ANSI -------
    # Drive the full pipeline at three target sizes:
    #   80×24  — the original BBS / VT100 floor (M5 baseline)
    #   120×40 — common-modern-laptop terminal (chafa's default test)
    #   200×60 — wide developer terminal (Alacritty / tmux on 4K)
    # We exercise emit_halfblock_row_buf in-process (writing into a
    # module-scope scratch buf) rather than emit_halfblock so the
    # syscall(write, fd 1) cost doesn't dominate the measurement —
    # this is the closest fair comparison of decode + render CPU cost.
    # Real-world `kii img.png` adds (rows × write(2)) ≈ tens of µs.
    #
    # Per-resolution `n` decreases with rendered cell count to keep
    # wall-clock per bench roughly bounded; the per-op time is what we
    # care about, not the iteration count.
    var bh_80  = bench_new("end-to-end RAMGON.png → 80×24 frame");
    var n_80 = 50;
    bench_batch_start(bh_80);
    var j80 = 0;
    while (j80 < n_80) {
        var pstr_80[160];
        kii_decode_png("tests/fixtures/RAMGON.png", &pstr_80);
        downscale_to_rgb(&pstr_80, 80, 48);
        quantize_downscaled(&pstr_80);
        var qb_80 = load64(&pstr_80 + STRUCT_QUANTIZED_BUF_OFFSET);
        var row_80 = 0;
        while (row_80 < 24) {
            emit_halfblock_row_buf(qb_80, 80, row_80, &_bench_emit_scratch, 0);
            row_80 = row_80 + 1;
        }
        j80 = j80 + 1;
    }
    bench_batch_stop(bh_80, n_80);
    bench_report(bh_80);

    var bh_120 = bench_new("end-to-end RAMGON.png → 120×40 frame");
    var n_120 = 30;
    bench_batch_start(bh_120);
    var j120 = 0;
    while (j120 < n_120) {
        var pstr_120[160];
        kii_decode_png("tests/fixtures/RAMGON.png", &pstr_120);
        downscale_to_rgb(&pstr_120, 120, 80);
        quantize_downscaled(&pstr_120);
        var qb_120 = load64(&pstr_120 + STRUCT_QUANTIZED_BUF_OFFSET);
        var row_120 = 0;
        while (row_120 < 40) {
            emit_halfblock_row_buf(qb_120, 120, row_120, &_bench_emit_scratch, 0);
            row_120 = row_120 + 1;
        }
        j120 = j120 + 1;
    }
    bench_batch_stop(bh_120, n_120);
    bench_report(bh_120);

    var bh_200 = bench_new("end-to-end RAMGON.png → 200×60 frame");
    var n_200 = 20;
    bench_batch_start(bh_200);
    var j200 = 0;
    while (j200 < n_200) {
        var pstr_200[160];
        kii_decode_png("tests/fixtures/RAMGON.png", &pstr_200);
        downscale_to_rgb(&pstr_200, 200, 120);
        quantize_downscaled(&pstr_200);
        var qb_200 = load64(&pstr_200 + STRUCT_QUANTIZED_BUF_OFFSET);
        var row_200 = 0;
        while (row_200 < 60) {
            emit_halfblock_row_buf(qb_200, 200, row_200, &_bench_emit_scratch, 0);
            row_200 = row_200 + 1;
        }
        j200 = j200 + 1;
    }
    bench_batch_stop(bh_200, n_200);
    bench_report(bh_200);

    # ---- M7(d) decode-latency matrix at three source resolutions ----
    # Audit acceptance: capture DoS-relevant worst-case timing envelope
    # across small / medium / large input sizes. Decode-only (no
    # downscale / quantize / emit) so the measurement isolates the
    # IDAT → raw-pixels cost — the part that scales with input size.
    # See docs/audit/2026-05-22-audit.md § Finding 1 + decode-latency
    # matrix section.
    #
    # Fixtures chosen from /usr/share to avoid bundling large blobs
    # in the repo. If a fixture is missing on a CI box, the bench
    # row is skipped (the iteration count drops to 0 and bench_report
    # surfaces that visibly).

    # 256² class: archlinux-logo.png is exactly 256×256.
    var bh_dec_256 = bench_new("png_decode (256² class) — archlinux-logo.png");
    var n_dec_256 = 50;
    var pstr_probe_256[160];
    if (kii_decode_png("/usr/share/pixmaps/archlinux-logo.png", &pstr_probe_256) == PNG_OK) {
        bench_batch_start(bh_dec_256);
        var jd256 = 0;
        while (jd256 < n_dec_256) {
            var pstr_d256[160];
            kii_decode_png("/usr/share/pixmaps/archlinux-logo.png", &pstr_d256);
            jd256 = jd256 + 1;
        }
        bench_batch_stop(bh_dec_256, n_dec_256);
        bench_report(bh_dec_256);
    }

    # 1024² class: starfield.png is 1597×1198 (~1.9M pixels — between
    # 1024² = 1M and 2048² = 4M, used as the "1024² class" sample).
    var bh_dec_1k = bench_new("png_decode (1024² class) — starfield.png 1597×1198");
    var n_dec_1k = 20;
    var pstr_probe_1k[160];
    if (kii_decode_png("/usr/share/grub/themes/starfield/starfield.png", &pstr_probe_1k) == PNG_OK) {
        bench_batch_start(bh_dec_1k);
        var jd1k = 0;
        while (jd1k < n_dec_1k) {
            var pstr_d1k[160];
            kii_decode_png("/usr/share/grub/themes/starfield/starfield.png", &pstr_d1k);
            jd1k = jd1k + 1;
        }
        bench_batch_stop(bh_dec_1k, n_dec_1k);
        bench_report(bh_dec_1k);
    }

    # 2048² class: sddm elarun background is 2560×1600 (~4M pixels —
    # close to 2048² = 4.2M, used as the "2048² class" sample).
    var bh_dec_2k = bench_new("png_decode (2048² class) — elarun background 2560×1600");
    var n_dec_2k = 10;
    var pstr_probe_2k[160];
    if (kii_decode_png("/usr/share/sddm/themes/elarun/images/background.png", &pstr_probe_2k) == PNG_OK) {
        bench_batch_start(bh_dec_2k);
        var jd2k = 0;
        while (jd2k < n_dec_2k) {
            var pstr_d2k[160];
            kii_decode_png("/usr/share/sddm/themes/elarun/images/background.png", &pstr_d2k);
            jd2k = jd2k + 1;
        }
        bench_batch_stop(bh_dec_2k, n_dec_2k);
        bench_report(bh_dec_2k);
    }

    return 0;
}

var r = main();
syscall(60, r);
