# kii fuzz harness — two crash-safety surfaces in one binary.
#
# 1. Arg parser (M1 sub-bite (d)): drives kii's flag set via
#    kii_register_flags with deterministic LCG-generated random
#    argv arrays. Contract: flags_parse never crashes on malformed
#    input, only returns FLAG_ERR_* cleanly.
#
# 2. PNG decoder (M2 sub-bite (d)): writes random byte sequences
#    to /tmp/kii-fuzz-png.bin + drives png_decode_structure over
#    them. 50% of iterations prepend a valid signature + IHDR so
#    the post-IHDR chunk walker gets exercised. Contract:
#    png_decode_structure never crashes; returns PNG_OK or any
#    PNG_ERR_* cleanly.
#
# Determinism: fixed seed (1) + Numerical Recipes LCG. Same byte
# sequences every CI run; failures bisect cleanly.
#
# Stdlib + flags + cli.cyr + png.cyr auto-included via cyrius.cyml
# + the includes below.

include "src/cli.cyr"
include "src/png.cyr"
include "src/palette.cyr"
include "src/quant.cyr"
include "src/downscale.cyr"
include "src/emit.cyr"

# Iteration counts.
#
# Arg-parser fuzz (FUZZ_ITERS): 10k baseline (no I/O, runs in <50 ms).
# PNG-decoder fuzz (PNG_FUZZ_ITERS): scaled 2k → 10⁶ at M7(b) per the
#   v1.0 acceptance criterion (docs/development/roadmap.md § M7). Each
#   iter does a /tmp file_write_all + open + read on tmpfs; 10⁶ iters
#   lands around ~35s on the dev box.
# Path-sanitizer fuzz (PATH_FUZZ_ITERS): pure-memory; 10⁶ at full
#   M7(b) scale, runs in <1 s.
# Geometry fuzz (GEOM_FUZZ_ITERS): pure-memory; 10⁶ at full M7(b)
#   scale, runs in <1 s.
# Emit-pipeline fuzz (EMIT_FUZZ_ITERS): decodes RAMGON.png once,
#   then varies (dst_cols, dst_rows) randomly per iter through
#   downscale → quantize → emit. 1k iters at ~1ms each (the
#   end-to-end bench at ~770ms/iter is mostly PNG decode, which
#   we skip here by reusing the decoded pstruct).
var FUZZ_ITERS        = 10000;
var PNG_FUZZ_ITERS    = 1000000;
var PATH_FUZZ_ITERS   = 1000000;
var GEOM_FUZZ_ITERS   = 1000000;
var EMIT_FUZZ_ITERS   = 1000;

# Per-iter argv shape. argc ∈ [1, FUZZ_MAX_ARGC]; each arg's body
# is ≤ FUZZ_MAX_ARG_LEN bytes plus an optional "-"/"--" prefix.
var FUZZ_MAX_ARGC    = 8;
var FUZZ_MAX_ARG_LEN = 24;

# Per-iter PNG fuzz shape. Random byte payload length ∈ [0,
# PNG_FUZZ_MAX_LEN]; optionally prepended with a 33-byte valid
# signature + IHDR prefix (50% of iters) so the chunk walker is
# reached. Scratch buf accommodates prefix + payload.
var PNG_FUZZ_MAX_LEN = 1024;

# ---- deterministic LCG ----------------------------------------------
# Numerical Recipes constants. Seed is mutable module state so each
# rand call advances it. Masked to 32 bits after multiply to keep
# the modulus operand positive (avoids sign weirdness with `%`).
var _fuzz_seed = 1;

fn _fuzz_rand(): i64 {
    _fuzz_seed = _fuzz_seed * 1664525 + 1013904223;
    _fuzz_seed = _fuzz_seed & 0xFFFFFFFF;
    return _fuzz_seed;
}

fn _fuzz_rand_range(n): i64 {
    return _fuzz_rand() % n;
}

# Pick a printable-ASCII byte (0x21–0x7E). NUL is excluded because
# argv entries are null-terminated cstrs; multi-byte UTF-8 leaders
# are excluded so we focus pressure on the parser's flag-recognition
# path (which is ASCII-only) rather than on string-handling
# robustness (separate concern, separate fuzz at M2+).
fn _fuzz_printable_byte(): i64 {
    var span = 0x7E - 0x21 + 1;              # 94 printable bytes
    return 0x21 + (_fuzz_rand() % span);
}

# Build one random arg in `buf`, null-terminated. Returns the
# byte length excluding the terminator. The first 1–2 bytes are
# biased to "-" / "--" 50% of the time so the parser actually
# exercises its flag-recognition path (a uniform random byte
# starts with '-' only ~1% of the time, far too rare to find
# parser bugs in 10k iters).
fn _fuzz_build_arg(buf, max_len): i64 {
    var mode = _fuzz_rand_range(4);
    var off  = 0;
    if (mode == 0) {
        # "--foo" / "--foo=bar" shape
        store8(buf + 0, 0x2D);
        store8(buf + 1, 0x2D);
        off = 2;
    } else { if (mode == 1) {
        # "-x" / "-xy" shape (bundled rejection path is reachable)
        store8(buf + 0, 0x2D);
        off = 1;
    } else {
        # bare positional / weird bytes
        off = 0;
    } }
    var body_len = 1 + _fuzz_rand_range(max_len - off - 1);
    var i = 0;
    while (i < body_len) {
        store8(buf + off + i, _fuzz_printable_byte());
        i = i + 1;
    }
    store8(buf + off + body_len, 0);
    return off + body_len;
}

# ---- PNG fuzz support ----------------------------------------------
# Pre-built 33-byte "valid prefix" (signature + IHDR for a 4x2 RGB
# image with computed IHDR CRC) — prepended to random-byte fuzz
# inputs 50% of the time so the chunk walker post-IHDR sees random
# chunks. Module-scope `var arr[33]` = 33 × u64 slots = 264 bytes
# (we use the first 33 bytes; rest is wasted but cheap). Caller
# must call _png_fuzz_init_prefix() once before the first PNG fuzz
# iter so the IHDR CRC is computed and stored.
var _png_fuzz_prefix[33];
var _png_fuzz_prefix_inited = 0;

fn _png_fuzz_init_prefix(): i64 {
    if (_png_fuzz_prefix_inited == 1) { return 0; }
    png_crc_init();
    var b = &_png_fuzz_prefix;
    # signature
    memcpy(b, PNG_MAGIC, PNG_MAGIC_LEN);
    # IHDR length = 13
    store8(b + 8, 0);  store8(b + 9, 0);  store8(b + 10, 0); store8(b + 11, 13);
    # IHDR type "IHDR"
    store8(b + 12, 0x49); store8(b + 13, 0x48); store8(b + 14, 0x44); store8(b + 15, 0x52);
    # IHDR data: 4×2, depth=8, RGB, comp=0, filter=0, interlace=0
    store8(b + 16, 0); store8(b + 17, 0); store8(b + 18, 0); store8(b + 19, 4);
    store8(b + 20, 0); store8(b + 21, 0); store8(b + 22, 0); store8(b + 23, 2);
    store8(b + 24, 8); store8(b + 25, 2);
    store8(b + 26, 0); store8(b + 27, 0); store8(b + 28, 0);
    # IHDR CRC32 over type + data (17 bytes at offset 12..28)
    var crc = png_crc32(b + 12, 17);
    store8(b + 29, (crc >> 24) & 0xFF);
    store8(b + 30, (crc >> 16) & 0xFF);
    store8(b + 31, (crc >> 8)  & 0xFF);
    store8(b + 32, crc & 0xFF);
    _png_fuzz_prefix_inited = 1;
    return 0;
}

# ---- M7(b) path-sanitizer fuzz surface -----------------------------
# Random-byte path buffers driven through kii_path_has_control_bytes
# (src/cli.cyr) to confirm the predicate never crashes and always
# returns 0 or 1, regardless of byte content. Each iter generates a
# null-terminated byte string in `buf` with each non-NUL byte chosen
# uniformly from 0x01..0xFF (NUL would terminate prematurely).
# Contract: predicate returns exactly 0 or 1; total call count
# matches PATH_FUZZ_ITERS.
fn fuzz_path_iter(buf, max_len): i64 {
    var n = 1 + _fuzz_rand_range(max_len - 1);
    var i = 0;
    while (i < n) {
        # 0x01..0xFF — exclude NUL (we add it as terminator)
        store8(buf + i, 1 + (_fuzz_rand() % 255));
        i = i + 1;
    }
    store8(buf + n, 0);
    var rc = kii_path_has_control_bytes(buf);
    # Defensive cross-check: return MUST be 0 or 1. If the predicate
    # somehow returns something else, count it as a failure (the
    # main loop tallies the bad-return count).
    if (rc == 0 || rc == 1) { return 0; }
    return 0 - 1;
}

# ---- M7(b) geometry fuzz surface -----------------------------------
# Random (src_w, src_h, max_cols, max_rows) inputs to the M6 geometry
# helpers. Drive both _kii_compute_target_geometry (--width N path)
# and _kii_compute_fit_geometry (terminal-fit path). Contract: both
# return 0 (success) or -1 (clean rejection); never crash on
# adversarial input including 0s, very large values, and asymmetric
# aspect ratios. The fuzz inputs are bounded to [0, 65535] for each
# field — large enough to exercise overflow paths, small enough to
# fit in the i64 multiplications without wrapping (which would be a
# separate finding, not a geometry bug).
fn fuzz_geom_iter(): i64 {
    var src_w    = _fuzz_rand() % 65536;
    var src_h    = _fuzz_rand() % 65536;
    var max_cols = _fuzz_rand() % 65536;
    var max_rows = _fuzz_rand() % 65536;
    var width_n  = _fuzz_rand() % 65536;

    var out_w  = 0;
    var out_sr = 0;
    var rc1 = _kii_compute_target_geometry(src_w, src_h, width_n, &out_w, &out_sr);
    if (rc1 != 0 && rc1 != (0 - 1)) { return 0 - 1; }
    var rc2 = _kii_compute_fit_geometry(src_w, src_h, max_cols, max_rows, &out_w, &out_sr);
    if (rc2 != 0 && rc2 != (0 - 1)) { return 0 - 1; }
    return 0;
}

# ---- M7(b) emit-pipeline fuzz surface ------------------------------
# Drive downscale → quantize → emit_halfblock_row_buf on a valid
# decoded PNG (RAMGON.png from the repo root) with randomized target
# dimensions per iter. Decoding the source PNG is expensive
# (~700 ms per the bench harness) so we do it once at startup;
# per-iter cost is just the M5 pipeline (~1 ms each on tmpfs).
#
# Contract: downscale_to_rgb / quantize_downscaled / emit_halfblock_row_buf
# return 0 on success or -1 on rejection (e.g. dst dims = 0); never
# crash. The fuzz exercises:
#   - dst_w / dst_h boundary cases (0, 1, near-source-size, larger-than-source)
#   - the per-row emit_halfblock_row_buf walk with random row index
fn fuzz_emit_iter(pstruct, line_buf): i64 {
    # Random target dims in [1, 200]. Cap at source-w / source-h
    # constraint inside downscale_to_rgb if it has one — but
    # contract is "never crash", so we don't pre-validate.
    var dst_w = 1 + (_fuzz_rand() % 200);
    var dst_h = 1 + (_fuzz_rand() % 200);
    var dr = downscale_to_rgb(pstruct, dst_w, dst_h);
    if (dr != 0 && dr != (0 - 1)) { return 0 - 1; }
    if (dr != 0) { return 0; }                  # rejection; nothing else to do
    var qr = quantize_downscaled(pstruct);
    if (qr != 0 && qr != (0 - 1)) { return 0 - 1; }
    if (qr != 0) { return 0; }
    # Pick a random row to emit. dst_h pairs of source rows produce
    # dst_h/2 terminal rows; safe to walk [0, dst_h/2).
    var term_rows = dst_h / 2;
    if (term_rows < 1) { return 0; }
    var row = _fuzz_rand() % term_rows;
    var qbuf = load64(pstruct + STRUCT_QUANTIZED_BUF_OFFSET);
    var dw   = load64(pstruct + STRUCT_DOWNSCALED_W_OFFSET);
    emit_halfblock_row_buf(qbuf, dw, row, line_buf, 0);
    return 0;
}

# One PNG-fuzz iteration. Builds a random byte buffer (optionally
# prefixed with a valid sig + IHDR), writes it to /tmp, drives
# png_decode_structure. Whatever the function returns is fine —
# the contract is "never crash". `scratch_buf` is caller-owned;
# `scratch_cap` is the buffer's capacity so we don't overflow.
fn fuzz_png_iter(scratch_buf, scratch_cap): i64 {
    # 50% of iters get the valid prefix; the rest are pure random.
    var off = 0;
    if (_fuzz_rand_range(2) == 0) {
        memcpy(scratch_buf, &_png_fuzz_prefix, 33);
        off = 33;
    }

    # Random payload length in [0, PNG_FUZZ_MAX_LEN].
    var payload = _fuzz_rand_range(PNG_FUZZ_MAX_LEN + 1);
    var max_fill = scratch_cap - off;
    if (payload > max_fill) { payload = max_fill; }
    var i = 0;
    while (i < payload) {
        store8(scratch_buf + off + i, _fuzz_rand() & 0xFF);
        i = i + 1;
    }
    var total = off + payload;

    # file_write_all uses O_TRUNC, so the file is fresh every iter.
    file_write_all("/tmp/kii-fuzz-png.bin", scratch_buf, total);

    # Drive the decoder. Result discarded — we only care about
    # not-crashing.
    var pstruct[64];
    png_decode_structure("/tmp/kii-fuzz-png.bin", &pstruct);
    return 0;
}

# One fuzz iteration. `scratch` holds the raw bytes of all args
# packed back-to-back (each null-terminated). `argv_arr` holds
# pointers into `scratch`, one per arg. argv[0] is always "kii"
# — programs always have an argv[0] and the parser stores it as
# prog_name; absent argv[0] would test a never-real path.
fn fuzz_iter(scratch, argv_arr): i64 {
    # Reset argv[0] = "kii"
    store8(scratch + 0, 0x6B);               # 'k'
    store8(scratch + 1, 0x69);               # 'i'
    store8(scratch + 2, 0x69);               # 'i'
    store8(scratch + 3, 0);
    store64(argv_arr + 0, scratch + 0);
    var off = 4;
    var argc_val = 1 + _fuzz_rand_range(FUZZ_MAX_ARGC - 1);
    var i = 1;
    while (i < argc_val) {
        var arg_len = _fuzz_build_arg(scratch + off, FUZZ_MAX_ARG_LEN);
        store64(argv_arr + i * 8, scratch + off);
        off = off + arg_len + 1;             # +1 for the null
        i = i + 1;
    }

    # Drive kii's actual flag set. flags_new allocates from the
    # bump allocator per iter; that's fine — 10k × ~few KB stays
    # under 100 MB worst-case, well below the heap layout's brk
    # ceiling (~77 MB final per the cyrius README, but the bump
    # allocator grows on demand). The contract: return value is
    # 0 or -1; never crash.
    var fs = flags_new();
    kii_register_flags(fs);
    flags_parse(fs, argc_val, argv_arr);
    return 0;
}

fn main(): i64 {
    alloc_init();
    _png_fuzz_init_prefix();

    # ---- arg-parser fuzz loop --------------------------------------
    # Function-scope `var buf[N]` = N bytes. 1 KB scratch is well
    # over FUZZ_MAX_ARGC × (FUZZ_MAX_ARG_LEN + 1) = 8 × 25 = 200
    # bytes. argv_arr at 80 bytes = 10 slots, one more than
    # FUZZ_MAX_ARGC for header alignment.
    var scratch[1024];
    var argv_arr[80];

    var iter = 0;
    while (iter < FUZZ_ITERS) {
        fuzz_iter(&scratch, &argv_arr);
        iter = iter + 1;
    }

    # ---- M7(b) path-sanitizer fuzz loop ----------------------------
    # Pure-memory; fast. 10⁶ iters runs in ~1 s.
    var path_buf[256];
    var path_iter = 0;
    var path_bad  = 0;
    while (path_iter < PATH_FUZZ_ITERS) {
        if (fuzz_path_iter(&path_buf, 256) != 0) { path_bad = path_bad + 1; }
        path_iter = path_iter + 1;
    }

    # ---- M7(b) geometry fuzz loop ----------------------------------
    # Pure-memory; fast. 10⁶ iters runs in ~1 s. Exercises both M6
    # geometry helpers.
    var geom_iter = 0;
    var geom_bad  = 0;
    while (geom_iter < GEOM_FUZZ_ITERS) {
        if (fuzz_geom_iter() != 0) { geom_bad = geom_bad + 1; }
        geom_iter = geom_iter + 1;
    }

    # ---- M7(b) emit-pipeline fuzz loop -----------------------------
    # Decode RAMGON.png once (the repo-root fixture), then run the
    # M5 pipeline at randomized target dims per iter. If RAMGON is
    # missing, skip the loop with emit_iter = 0 — fuzz infra still
    # runs cleanly on a CI checkout that doesn't bundle the fixture.
    var emit_iter = 0;
    var emit_bad  = 0;
    var emit_pstr[160];
    if (png_decode_structure("RAMGON.png", &emit_pstr) == PNG_OK) {
        if (png_decode_pixels(&emit_pstr) == PNG_OK) {
            # ANSI escape can produce up to ~25 bytes per cell at
            # 200 cols; 8 KB scratch is well above worst-case.
            var emit_line[8192];
            while (emit_iter < EMIT_FUZZ_ITERS) {
                if (fuzz_emit_iter(&emit_pstr, &emit_line) != 0) {
                    emit_bad = emit_bad + 1;
                }
                emit_iter = emit_iter + 1;
            }
        }
    }

    # ---- png-decoder fuzz loop -------------------------------------
    # Scaled 2k → 10⁶ at M7(b). Larger scratch: prefix (33) + max
    # payload (1024) = 1057 bytes. 2 KB stack buf has plenty of
    # headroom.
    var png_scratch[2048];
    var png_iter = 0;
    while (png_iter < PNG_FUZZ_ITERS) {
        fuzz_png_iter(&png_scratch, 2048);
        png_iter = png_iter + 1;
    }

    # ---- report ----------------------------------------------------
    # fmt_printf takes a vec for varargs (per lib/fmt.cyr — vec_get
    # walks args by index). One line per fuzz surface; "fuzz: ok"
    # closes the human-readable log so CI greps see a clear sentinel.
    var args_arg = vec_new();
    vec_push(args_arg, iter);
    fmt_printf("fuzz: %d iterations passed (arg-parser crash-safety)\n", args_arg);

    var args_path = vec_new();
    vec_push(args_path, path_iter);
    vec_push(args_path, path_bad);
    fmt_printf("fuzz: %d iterations passed (path-sanitizer; bad=%d)\n", args_path);

    var args_geom = vec_new();
    vec_push(args_geom, geom_iter);
    vec_push(args_geom, geom_bad);
    fmt_printf("fuzz: %d iterations passed (geometry; bad=%d)\n", args_geom);

    var args_emit = vec_new();
    vec_push(args_emit, emit_iter);
    vec_push(args_emit, emit_bad);
    fmt_printf("fuzz: %d iterations passed (emit-pipeline; bad=%d)\n", args_emit);

    var args_png = vec_new();
    vec_push(args_png, png_iter);
    fmt_printf("fuzz: %d iterations passed (png-decoder crash-safety)\n", args_png);

    println("fuzz: ok");
    return 0;
}

var r = main();
syscall(60, r);
