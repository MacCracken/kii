# kii test suite
# Stdlib + flags auto-included via cyrius.cyml.
#
# M1 coverage: kii_validate_color predicate + flag-parse wiring.
# M2(a) coverage: png_check_signature + png_validate_file_signature.
# M2(b) coverage: png_read_u32_be + png_decode_header (IHDR parse
# now ALSO validates CRC at sub-bite (c); the (b) fixtures here
# use computed CRCs rather than the XXXX placeholders the pre-(c)
# tests had).
# M2(c) coverage: png_crc32 canonical values + png_decode_structure
# (full chunk walk through IEND, CRC validation, missing-IEND
# soft warning, truncated-chunk hard error).
# The end-to-end binary smoke is exercised via the manual run
# shell — Cyrius can't trivially subprocess itself inside a unit
# test, so .tcyr owns the in-process pieces and the smoke shell
# owns the I/O surface.

include "src/cli.cyr"
include "src/png.cyr"
include "src/palette.cyr"

# ---- Test-only PNG fixture builders ---------------------------------
# Module-scope helpers so they don't clutter main(). All write to
# a caller-provided byte buffer + return the total byte count, so
# callers can either `file_write_all(path, buf, len)` or pass the
# buffer to in-memory tests.

# Write a big-endian u32 into `buf` at byte offset `off`. PNG is
# big-endian everywhere per spec § 7; same shape used by every
# fixture builder below.
fn _ut_put_u32_be(buf, off, val): i64 {
    store8(buf + off + 0, (val >> 24) & 0xFF);
    store8(buf + off + 1, (val >> 16) & 0xFF);
    store8(buf + off + 2, (val >> 8) & 0xFF);
    store8(buf + off + 3, val & 0xFF);
    return 0;
}

# Build a minimal valid PNG (signature + IHDR + IEND, no IDAT)
# into `buf`. Returns 45 — total byte count. IHDR CRC computed
# via png_crc32; IEND CRC is the well-known constant 0xAE426082
# (= crc32("IEND") — IEND carries no data so its CRC is constant
# across every PNG ever).
fn _ut_build_min_png(buf, w, h, bit_depth, color_type): i64 {
    memcpy(buf + 0, PNG_MAGIC, PNG_MAGIC_LEN);
    _ut_put_u32_be(buf, 8, 13);                          # IHDR length
    store8(buf + 12, 0x49); store8(buf + 13, 0x48);      # "IH"
    store8(buf + 14, 0x44); store8(buf + 15, 0x52);      # "DR"
    _ut_put_u32_be(buf, 16, w);                          # width
    _ut_put_u32_be(buf, 20, h);                          # height
    store8(buf + 24, bit_depth);
    store8(buf + 25, color_type);
    store8(buf + 26, 0);                                 # compression
    store8(buf + 27, 0);                                 # filter
    store8(buf + 28, 0);                                 # interlace
    var ihdr_crc = png_crc32(buf + 12, 17);              # type + 13 data bytes
    _ut_put_u32_be(buf, 29, ihdr_crc);
    _ut_put_u32_be(buf, 33, 0);                          # IEND length = 0
    store8(buf + 37, 0x49); store8(buf + 38, 0x45);      # "IE"
    store8(buf + 39, 0x4E); store8(buf + 40, 0x44);      # "ND"
    store8(buf + 41, 0xAE); store8(buf + 42, 0x42);      # IEND CRC = 0xAE426082
    store8(buf + 43, 0x60); store8(buf + 44, 0x82);
    return 45;
}

# Build a PNG with one IDAT chunk in between IHDR and IEND. Layout:
#   signature (8) + IHDR (25) + IDAT (12 + idat_len) + IEND (12)
# Interlace byte is parameterized so callers can craft Adam7
# fixtures for the M3(c) rejection test. IDAT CRC is computed at
# runtime; IEND CRC is the fixed constant. Returns total byte
# count = 57 + idat_len.
fn _ut_build_png_with_idat(buf, w, h, bit_depth, color_type, interlace,
                            idat_data, idat_len): i64 {
    # ---- signature ----
    memcpy(buf + 0, PNG_MAGIC, PNG_MAGIC_LEN);
    # ---- IHDR ----
    _ut_put_u32_be(buf, 8, 13);
    store8(buf + 12, 0x49); store8(buf + 13, 0x48);
    store8(buf + 14, 0x44); store8(buf + 15, 0x52);      # "IHDR"
    _ut_put_u32_be(buf, 16, w);
    _ut_put_u32_be(buf, 20, h);
    store8(buf + 24, bit_depth);
    store8(buf + 25, color_type);
    store8(buf + 26, 0);                                 # compression
    store8(buf + 27, 0);                                 # filter
    store8(buf + 28, interlace);                         # interlace (parameterized)
    var ihdr_crc = png_crc32(buf + 12, 17);
    _ut_put_u32_be(buf, 29, ihdr_crc);
    # ---- IDAT ----
    var idat_off = 33;
    _ut_put_u32_be(buf, idat_off, idat_len);
    store8(buf + idat_off + 4, 0x49); store8(buf + idat_off + 5, 0x44);
    store8(buf + idat_off + 6, 0x41); store8(buf + idat_off + 7, 0x54);  # "IDAT"
    if (idat_len > 0) { memcpy(buf + idat_off + 8, idat_data, idat_len); }
    var idat_crc = png_crc32(buf + idat_off + 4, 4 + idat_len);
    _ut_put_u32_be(buf, idat_off + 8 + idat_len, idat_crc);
    # ---- IEND ----
    var iend_off = idat_off + 12 + idat_len;
    _ut_put_u32_be(buf, iend_off, 0);
    store8(buf + iend_off + 4, 0x49); store8(buf + iend_off + 5, 0x45);
    store8(buf + iend_off + 6, 0x4E); store8(buf + iend_off + 7, 0x44);  # "IEND"
    store8(buf + iend_off + 8,  0xAE); store8(buf + iend_off + 9,  0x42);
    store8(buf + iend_off + 10, 0x60); store8(buf + iend_off + 11, 0x82);
    return iend_off + 12;
}

fn main() {
    alloc_init();

    # ---- smoke ------------------------------------------------------
    test_group("smoke");
    assert(1, "true is true");
    assert_eq(1 + 1, 2, "math works");

    # ---- M1(c): kii_validate_color predicate ------------------------
    # Tier-1 scope is 8 / 16 only; 256 / truecolor are post-v1 per
    # CLAUDE.md color-tier discipline. Locks the boundary in code so
    # any future change that quietly admits other values regresses
    # this test before the milestone gate.
    test_group("M1 — kii_validate_color");
    assert_eq(kii_validate_color(8),   1, "--color 8 valid");
    assert_eq(kii_validate_color(16),  1, "--color 16 valid");
    assert_eq(kii_validate_color(0),   0, "--color 0 rejected");
    assert_eq(kii_validate_color(7),   0, "--color 7 rejected");
    assert_eq(kii_validate_color(15),  0, "--color 15 rejected (off-by-one of 16)");
    assert_eq(kii_validate_color(17),  0, "--color 17 rejected (off-by-one of 16)");
    assert_eq(kii_validate_color(256), 0, "--color 256 rejected (tier-2, post-v1)");
    assert_eq(kii_validate_color(0 - 1), 0, "--color -1 rejected");

    # ---- M1(a)(b)(c): flag-parse happy paths ------------------------
    # Mirrors the anuenue M2 test shape. Each case builds a
    # synthetic argv, registers kii's flag set, parses, and reads
    # back the captured values. flags_parse's internal contract is
    # asserted in cyrius's own tests/flags.tcyr; here we verify
    # kii's wiring (correct short codes, defaults, value extraction).

    test_group("M1 — --help long form");
    var fs1 = flags_new();
    kii_register_flags(fs1);
    var argv1[16];
    store64(&argv1 + 0, "kii");
    store64(&argv1 + 8, "--help");
    assert_eq(flags_parse(fs1, 2, &argv1), 0, "--help parses clean");
    assert_eq(flags_get_bool(fs1, KII_F_HELP),    1, "--help → true");
    assert_eq(flags_get_bool(fs1, KII_F_VERSION), 0, "--version untouched");
    assert_eq(flags_get_int (fs1, KII_F_WIDTH),   0, "--width default (0 = match terminal)");
    assert_eq(flags_get_int (fs1, KII_F_COLOR),  16, "--color default 16");

    test_group("M1 — -V short form");
    var fs2 = flags_new();
    kii_register_flags(fs2);
    var argv2[16];
    store64(&argv2 + 0, "kii");
    store64(&argv2 + 8, "-V");
    assert_eq(flags_parse(fs2, 2, &argv2), 0, "-V parses clean");
    assert_eq(flags_get_bool(fs2, KII_F_VERSION), 1, "-V → true");

    test_group("M1 — --width N + --color N (long forms)");
    var fs3 = flags_new();
    kii_register_flags(fs3);
    var argv3[64];
    store64(&argv3 + 0,  "kii");
    store64(&argv3 + 8,  "--width");
    store64(&argv3 + 16, "120");
    store64(&argv3 + 24, "--color");
    store64(&argv3 + 32, "8");
    store64(&argv3 + 40, "photo.png");
    assert_eq(flags_parse(fs3, 6, &argv3), 0, "--width 120 --color 8 photo.png parses clean");
    assert_eq(flags_get_int(fs3, KII_F_WIDTH), 120, "--width extracted = 120");
    assert_eq(flags_get_int(fs3, KII_F_COLOR), 8,   "--color extracted = 8");
    assert_eq(flags_positional_count(fs3), 1, "one positional captured");

    test_group("M1 — -w N + -c N (short forms)");
    var fs4 = flags_new();
    kii_register_flags(fs4);
    var argv4[64];
    store64(&argv4 + 0,  "kii");
    store64(&argv4 + 8,  "-w");
    store64(&argv4 + 16, "60");
    store64(&argv4 + 24, "-c");
    store64(&argv4 + 32, "16");
    store64(&argv4 + 40, "img.png");
    assert_eq(flags_parse(fs4, 6, &argv4), 0, "-w 60 -c 16 img.png parses clean");
    assert_eq(flags_get_int(fs4, KII_F_WIDTH), 60, "-w extracted = 60");
    assert_eq(flags_get_int(fs4, KII_F_COLOR), 16, "-c extracted = 16");

    test_group("M1 — --width=N attached syntax");
    var fs5 = flags_new();
    kii_register_flags(fs5);
    var argv5[24];
    store64(&argv5 + 0,  "kii");
    store64(&argv5 + 8,  "--width=80");
    store64(&argv5 + 16, "img.png");
    assert_eq(flags_parse(fs5, 3, &argv5), 0, "--width=80 parses clean");
    assert_eq(flags_get_int(fs5, KII_F_WIDTH), 80, "--width=80 extracted");

    # ---- M1(d) — malformed-arg error variants -----------------------
    # Each FlagErr the parser can emit is reachable from a plausible
    # invocation. Locking the variant codes here means a future
    # flags-lib refactor (renumbering, splitting, etc.) trips this
    # test before kii silently mis-routes its error messages.

    test_group("M1(d) — error: unknown flag");
    var fs6 = flags_new();
    kii_register_flags(fs6);
    var argv6[16];
    store64(&argv6 + 0, "kii");
    store64(&argv6 + 8, "--bogus");
    assert_eq(flags_parse(fs6, 2, &argv6), 0 - 1, "--bogus rejected");
    assert_eq(flags_error(fs6), FLAG_ERR_UNKNOWN, "error = UNKNOWN");

    test_group("M1(d) — error: missing int value");
    var fs7 = flags_new();
    kii_register_flags(fs7);
    var argv7[16];
    store64(&argv7 + 0, "kii");
    store64(&argv7 + 8, "--width");          # no value follows
    assert_eq(flags_parse(fs7, 2, &argv7), 0 - 1, "--width without value rejected");
    assert_eq(flags_error(fs7), FLAG_ERR_MISSING_VALUE, "error = MISSING_VALUE");

    test_group("M1(d) — error: bad integer value");
    var fs8 = flags_new();
    kii_register_flags(fs8);
    var argv8[32];
    store64(&argv8 + 0,  "kii");
    store64(&argv8 + 8,  "--width");
    store64(&argv8 + 16, "abc");
    store64(&argv8 + 24, "img.png");
    assert_eq(flags_parse(fs8, 4, &argv8), 0 - 1, "--width abc rejected");
    assert_eq(flags_error(fs8), FLAG_ERR_BAD_INT, "error = BAD_INT");

    test_group("M1(d) — error: bundled short flags");
    var fs9 = flags_new();
    kii_register_flags(fs9);
    var argv9[16];
    store64(&argv9 + 0, "kii");
    store64(&argv9 + 8, "-hV");              # bundled — not supported
    assert_eq(flags_parse(fs9, 2, &argv9), 0 - 1, "-hV bundled rejected");
    assert_eq(flags_error(fs9), FLAG_ERR_BUNDLED, "error = BUNDLED");

    # ---- M1(d) — positional accumulation ----------------------------
    # Two-positional case is a usage error in main.cyr's dispatch
    # but flags_parse itself accepts it (and stashes them both).
    # Locks the "kii sees N positionals" view that the dispatch
    # branches on.
    test_group("M1(d) — multiple positionals captured (dispatched as usage error in main)");
    var fs10 = flags_new();
    kii_register_flags(fs10);
    var argv10[32];
    store64(&argv10 + 0,  "kii");
    store64(&argv10 + 8,  "a.png");
    store64(&argv10 + 16, "b.png");
    assert_eq(flags_parse(fs10, 3, &argv10), 0, "a.png b.png parses clean");
    assert_eq(flags_positional_count(fs10), 2, "two positionals captured");

    # ---- M2(a) — png_check_signature (pure in-memory) --------------
    # Spec source: W3C PNG § 5.2 — 8 magic bytes detect 7-bit
    # gateways, line-ending mangling, and naive `type` cmd. The
    # check is a memeq; the tests below pin each "what if the
    # transport corrupted byte N" failure mode.
    test_group("M2(a) — png_check_signature");

    # Happy path: exact magic.
    var sig_ok[8];
    store8(&sig_ok + 0, 0x89);
    store8(&sig_ok + 1, 0x50);   # 'P'
    store8(&sig_ok + 2, 0x4E);   # 'N'
    store8(&sig_ok + 3, 0x47);   # 'G'
    store8(&sig_ok + 4, 0x0D);   # \r
    store8(&sig_ok + 5, 0x0A);   # \n
    store8(&sig_ok + 6, 0x1A);   # DOS EOF
    store8(&sig_ok + 7, 0x0A);   # \n
    assert_eq(png_check_signature(&sig_ok), 1, "exact 8-byte magic → valid");

    # Off-by-one on byte 0 — the high-bit-set sentinel. A 7-bit
    # gateway would strip 0x89 → 0x09; we should reject.
    var sig_stripped[8];
    memcpy(&sig_stripped, &sig_ok, 8);
    store8(&sig_stripped + 0, 0x09);
    assert_eq(png_check_signature(&sig_stripped), 0, "byte 0 stripped 0x89→0x09 → reject");

    # Last byte corrupted — \r\n→\r conversion would drop byte 7.
    # Simulate the "byte 7 wrong" failure.
    var sig_last_bad[8];
    memcpy(&sig_last_bad, &sig_ok, 8);
    store8(&sig_last_bad + 7, 0x0D);
    assert_eq(png_check_signature(&sig_last_bad), 0, "byte 7 wrong → reject");

    # Middle-of-magic byte wrong — the 'P' becomes 'p'.
    var sig_lowered[8];
    memcpy(&sig_lowered, &sig_ok, 8);
    store8(&sig_lowered + 1, 0x70);   # 'p'
    assert_eq(png_check_signature(&sig_lowered), 0, "byte 1 'P'→'p' → reject");

    # All-zero buffer — the universally-wrong baseline.
    var sig_zero[8];
    var z = 0;
    while (z < 8) { store8(&sig_zero + z, 0); z = z + 1; }
    assert_eq(png_check_signature(&sig_zero), 0, "all-zero buf → reject");

    # ---- M2(a) — png_validate_file_signature (file-level) ----------
    # Writes test fixtures to /tmp/. file_write_all uses
    # O_WRONLY|O_CREAT|O_TRUNC (per lib/io.cyr) so each run starts
    # fresh; no cross-test contamination from stale files.
    test_group("M2(a) — png_validate_file_signature");

    # Happy path: write exactly the 8 magic bytes.
    file_write_all("/tmp/kii-test-sig-ok.png", PNG_MAGIC, PNG_MAGIC_LEN);
    assert_eq(png_validate_file_signature("/tmp/kii-test-sig-ok.png"),
              PNG_OK,
              "8-byte magic file → PNG_OK");

    # Truncated: 4 bytes is short.
    file_write_all("/tmp/kii-test-sig-trunc.bin", "JFIF", 4);
    assert_eq(png_validate_file_signature("/tmp/kii-test-sig-trunc.bin"),
              PNG_ERR_TRUNCATED,
              "4-byte file → PNG_ERR_TRUNCATED");

    # Empty file → also truncated (read returns 0).
    file_write_all("/tmp/kii-test-sig-empty.bin", "", 0);
    assert_eq(png_validate_file_signature("/tmp/kii-test-sig-empty.bin"),
              PNG_ERR_TRUNCATED,
              "empty file → PNG_ERR_TRUNCATED");

    # Wrong magic but ≥ 8 bytes.
    file_write_all("/tmp/kii-test-sig-notpng.bin", "JFIF\x00\x00\x00\x00\x00\x00", 10);
    assert_eq(png_validate_file_signature("/tmp/kii-test-sig-notpng.bin"),
              PNG_ERR_NOT_PNG,
              "10-byte non-PNG file → PNG_ERR_NOT_PNG");

    # Open failure: nonexistent path. The /tmp/kii-noexist- prefix
    # plus a randomish suffix avoids collision with any sibling
    # test that might run concurrently in CI.
    assert_eq(png_validate_file_signature("/tmp/kii-noexist-zzy42.png"),
              PNG_ERR_OPEN,
              "nonexistent path → PNG_ERR_OPEN");

    # ---- M2(b) — png_read_u32_be (pure big-endian decode) ----------
    # PNG is big-endian per spec § 7. Lock the byte-order at the
    # primitive level so any future endian-confusion regression
    # surfaces here rather than in IHDR / IDAT length parsing
    # downstream.
    test_group("M2(b) — png_read_u32_be");

    var be1[8];
    store8(&be1 + 0, 0x00);
    store8(&be1 + 1, 0x00);
    store8(&be1 + 2, 0x00);
    store8(&be1 + 3, 0x0D);
    assert_eq(png_read_u32_be(&be1, 0), 13, "00 00 00 0D → 13 (IHDR chunk length)");

    var be2[8];
    store8(&be2 + 0, 0x00);
    store8(&be2 + 1, 0x00);
    store8(&be2 + 2, 0x04);
    store8(&be2 + 3, 0x00);
    assert_eq(png_read_u32_be(&be2, 0), 1024, "00 00 04 00 → 1024 (width)");

    var be3[8];
    store8(&be3 + 0, 0xFF);
    store8(&be3 + 1, 0xFF);
    store8(&be3 + 2, 0xFF);
    store8(&be3 + 3, 0xFF);
    assert_eq(png_read_u32_be(&be3, 0), 4294967295, "FF FF FF FF → u32 max");

    # Offset-aware read — bytes at offset 2 (the 'A' 'B' in payload).
    var be4[8];
    store8(&be4 + 0, 0xDE);
    store8(&be4 + 1, 0xAD);
    store8(&be4 + 2, 0x00);
    store8(&be4 + 3, 0x00);
    store8(&be4 + 4, 0x01);
    store8(&be4 + 5, 0x00);
    assert_eq(png_read_u32_be(&be4, 2), 256, "offset 2: 00 00 01 00 → 256");

    # ---- M2(b) — png_decode_header (signature + IHDR + CRC) --------
    # Fixtures are built via _ut_build_min_png — the IHDR CRC is
    # computed at runtime via png_crc32 so the fixtures stay valid
    # as long as the CRC implementation is correct. (The CRC32
    # canonical-vector test below pins the implementation against
    # the zlib reference value.)
    test_group("M2(b) — png_decode_header happy path (4x2 RGB)");
    png_crc_init();   # explicit; png_crc32 also lazy-inits but the eager call documents the dep
    var pbuf_a[80];
    var len_a = _ut_build_min_png(&pbuf_a, 4, 2, 8, 2);
    file_write_all("/tmp/kii-test-ihdr-4x2.png", &pbuf_a, len_a);
    var ihdr_a[32];
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-4x2.png", &ihdr_a),
              PNG_OK,
              "4x2 RGB fixture → PNG_OK");
    assert_eq(load64(&ihdr_a + IHDR_WIDTH_OFFSET),      4, "width = 4");
    assert_eq(load64(&ihdr_a + IHDR_HEIGHT_OFFSET),     2, "height = 2");
    assert_eq(load64(&ihdr_a + IHDR_BIT_DEPTH_OFFSET),  8, "bit_depth = 8");
    assert_eq(load64(&ihdr_a + IHDR_COLOR_TYPE_OFFSET), 2, "color_type = 2 (RGB)");

    test_group("M2(b) — png_decode_header (1024x768 16-bit RGBA)");
    var pbuf_b[80];
    var len_b = _ut_build_min_png(&pbuf_b, 1024, 768, 16, 6);
    file_write_all("/tmp/kii-test-ihdr-1024.png", &pbuf_b, len_b);
    var ihdr_b[32];
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-1024.png", &ihdr_b),
              PNG_OK,
              "1024x768 16-bit RGBA fixture → PNG_OK");
    assert_eq(load64(&ihdr_b + IHDR_WIDTH_OFFSET),      1024, "width = 1024");
    assert_eq(load64(&ihdr_b + IHDR_HEIGHT_OFFSET),     768,  "height = 768");
    assert_eq(load64(&ihdr_b + IHDR_BIT_DEPTH_OFFSET),  16,   "bit_depth = 16");
    assert_eq(load64(&ihdr_b + IHDR_COLOR_TYPE_OFFSET), 6,    "color_type = 6 (RGBA)");

    test_group("M2(b) — png_decode_header all four color_types");
    # Greyscale (0), RGB (2), palette (3), grey+alpha (4) all parse
    # cleanly — the IHDR layer doesn't validate the bit_depth /
    # color_type compatibility matrix (M3 work; rejection of 1/2/4
    # bit depths + Adam7 lives there too per roadmap).
    var ihdr_c[32];
    var pbuf_grey[80];
    var len_grey = _ut_build_min_png(&pbuf_grey, 1, 1, 8, 0);
    file_write_all("/tmp/kii-test-ihdr-grey.png", &pbuf_grey, len_grey);
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-grey.png", &ihdr_c), PNG_OK, "greyscale parses");
    assert_eq(load64(&ihdr_c + IHDR_COLOR_TYPE_OFFSET), 0, "color_type = 0 (greyscale)");

    var pbuf_pal[80];
    var len_pal = _ut_build_min_png(&pbuf_pal, 1, 1, 8, 3);
    file_write_all("/tmp/kii-test-ihdr-pal.png", &pbuf_pal, len_pal);
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-pal.png", &ihdr_c), PNG_OK, "palette parses");
    assert_eq(load64(&ihdr_c + IHDR_COLOR_TYPE_OFFSET), 3, "color_type = 3 (palette)");

    var pbuf_ga[80];
    var len_ga = _ut_build_min_png(&pbuf_ga, 1, 1, 8, 4);
    file_write_all("/tmp/kii-test-ihdr-ga.png", &pbuf_ga, len_ga);
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-ga.png", &ihdr_c), PNG_OK, "grey+alpha parses");
    assert_eq(load64(&ihdr_c + IHDR_COLOR_TYPE_OFFSET), 4, "color_type = 4 (grey+alpha)");

    test_group("M2(b) — png_decode_header malformed cases");
    # Truncated mid-IHDR — signature ok but only 4 IHDR bytes follow.
    # Built by hand because the helper only emits well-formed PNGs.
    file_write_all("/tmp/kii-test-ihdr-trunc.png",
        "\x89PNG\r\n\x1a\n\x00\x00\x00\x0dIHDR", 12);
    var ihdr_d[32];
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-trunc.png", &ihdr_d),
              PNG_ERR_HEADER,
              "truncated mid-IHDR → PNG_ERR_HEADER");

    # Wrong chunk type ("NOPE" instead of "IHDR"). Length + type
    # bytes lie before the IHDR-fields, so length=13 stays correct.
    # CRC is junk — but PNG_ERR_HEADER fires on the type check
    # before CRC is reached.
    file_write_all("/tmp/kii-test-ihdr-wrongtype.png",
        "\x89PNG\r\n\x1a\n\x00\x00\x00\x0dNOPE\x00\x00\x00\x01\x00\x00\x00\x01\x08\x02\x00\x00\x00ZZZZ", 33);
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-wrongtype.png", &ihdr_d),
              PNG_ERR_HEADER,
              "first chunk type != IHDR → PNG_ERR_HEADER");

    # Wrong chunk length (claims 0xff bytes instead of 13).
    file_write_all("/tmp/kii-test-ihdr-wronglen.png",
        "\x89PNG\r\n\x1a\n\x00\x00\x00\xffIHDR\x00\x00\x00\x01\x00\x00\x00\x01\x08\x02\x00\x00\x00ZZZZ", 33);
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-wronglen.png", &ihdr_d),
              PNG_ERR_HEADER,
              "IHDR length != 13 → PNG_ERR_HEADER");

    # Bad signature → still surfaces as the earlier-stage error,
    # not PNG_ERR_HEADER. Ordering invariant: signature is checked
    # first.
    file_write_all("/tmp/kii-test-ihdr-badsig.png",
        "JFIF\x00\x00\x00\x00\x00\x00\x00\x0dIHDR\x00\x00\x00\x01\x00\x00\x00\x01\x08\x02\x00\x00\x00ZZZZ", 33);
    assert_eq(png_decode_header("/tmp/kii-test-ihdr-badsig.png", &ihdr_d),
              PNG_ERR_NOT_PNG,
              "bad signature short-circuits before IHDR parse");

    # Nonexistent path → PNG_ERR_OPEN, same as M2(a).
    assert_eq(png_decode_header("/tmp/kii-noexist-ihdr-zzz.png", &ihdr_d),
              PNG_ERR_OPEN,
              "nonexistent path → PNG_ERR_OPEN");

    # ---- M2(c) — png_crc32 canonical values ------------------------
    # Pin the CRC32 impl against the zlib / RFC 3309 reference and
    # the well-known IEND constant. Any regression in the table
    # builder or the update primitive trips here first.
    test_group("M2(c) — png_crc32 canonical");

    # Zlib/RFC 3309 "check" string. Universal across CRC-32
    # implementations of this polynomial.
    assert_eq(png_crc32("123456789", 9), 0xCBF43926, "crc32('123456789') = 0xCBF43926");

    # IEND chunk type: every valid PNG ends with the same 4 bytes
    # of type + the same constant CRC. Used as the IEND CRC by
    # _ut_build_min_png above; locks the constant in code.
    assert_eq(png_crc32("IEND", 4), 0xAE426082, "crc32('IEND') = 0xAE426082");

    # Empty buffer: register stays 0xFFFFFFFF, final xor → 0.
    assert_eq(png_crc32("", 0), 0, "crc32 of empty buffer = 0");

    # ---- M2(c) — png_decode_structure happy path -------------------
    # Minimal valid PNG (signature + IHDR + IEND, no IDAT). The
    # walker should: validate IHDR CRC, see IEND, validate its
    # CRC, report seen_iend=1 with zero IDATs.
    test_group("M2(c) — png_decode_structure (minimal valid)");
    var pbuf_min[80];
    var len_min = _ut_build_min_png(&pbuf_min, 4, 2, 8, 2);
    file_write_all("/tmp/kii-test-min.png", &pbuf_min, len_min);
    var pstr_min[64];
    assert_eq(png_decode_structure("/tmp/kii-test-min.png", &pstr_min),
              PNG_OK, "min PNG → PNG_OK");
    assert_eq(load64(&pstr_min + STRUCT_WIDTH_OFFSET),           4, "width = 4");
    assert_eq(load64(&pstr_min + STRUCT_HEIGHT_OFFSET),          2, "height = 2");
    assert_eq(load64(&pstr_min + STRUCT_BIT_DEPTH_OFFSET),       8, "bit_depth = 8");
    assert_eq(load64(&pstr_min + STRUCT_COLOR_TYPE_OFFSET),      2, "color_type = 2");
    assert_eq(load64(&pstr_min + STRUCT_IDAT_COUNT_OFFSET),      0, "no IDAT chunks");
    assert_eq(load64(&pstr_min + STRUCT_IDAT_TOTAL_SIZE_OFFSET), 0, "IDAT total = 0");
    assert_eq(load64(&pstr_min + STRUCT_SEEN_IEND_OFFSET),       1, "saw IEND");

    # ---- M2(c) — missing-IEND soft warning -------------------------
    # IHDR-only file: write the first 33 bytes of a valid PNG (sig
    # + IHDR chunk) but no IEND chunk after. Per spec § 5.3
    # tolerance, this is a warning, not an error — png_decode_structure
    # returns PNG_OK with seen_iend = 0.
    test_group("M2(c) — png_decode_structure (no IEND → soft warning)");
    var pbuf_noiend[80];
    _ut_build_min_png(&pbuf_noiend, 4, 2, 8, 2);
    file_write_all("/tmp/kii-test-noiend.png", &pbuf_noiend, 33);  # truncate at end of IHDR
    var pstr_noiend[64];
    assert_eq(png_decode_structure("/tmp/kii-test-noiend.png", &pstr_noiend),
              PNG_OK, "IHDR only (no IEND) still PNG_OK");
    assert_eq(load64(&pstr_noiend + STRUCT_SEEN_IEND_OFFSET), 0, "seen_iend = 0");
    # IHDR fields are still populated (the IHDR chunk was valid).
    assert_eq(load64(&pstr_noiend + STRUCT_WIDTH_OFFSET), 4, "IHDR fields preserved");

    # ---- M2(c) — CRC failures --------------------------------------
    test_group("M2(c) — png_decode_structure CRC failures");

    # Bit-flip the IHDR CRC at byte 29 (first byte of the IHDR CRC).
    var pbuf_bad_ihdr[80];
    var len_bi = _ut_build_min_png(&pbuf_bad_ihdr, 4, 2, 8, 2);
    store8(&pbuf_bad_ihdr + 29, load8(&pbuf_bad_ihdr + 29) ^ 0xFF);
    file_write_all("/tmp/kii-test-badcrc-ihdr.png", &pbuf_bad_ihdr, len_bi);
    var pstr_bi[64];
    assert_eq(png_decode_structure("/tmp/kii-test-badcrc-ihdr.png", &pstr_bi),
              PNG_ERR_CRC, "bit-flipped IHDR CRC → PNG_ERR_CRC");

    # Bit-flip the IEND CRC at byte 41 (first byte of IEND CRC).
    var pbuf_bad_iend[80];
    var len_be = _ut_build_min_png(&pbuf_bad_iend, 4, 2, 8, 2);
    store8(&pbuf_bad_iend + 41, load8(&pbuf_bad_iend + 41) ^ 0xFF);
    file_write_all("/tmp/kii-test-badcrc-iend.png", &pbuf_bad_iend, len_be);
    var pstr_be[64];
    assert_eq(png_decode_structure("/tmp/kii-test-badcrc-iend.png", &pstr_be),
              PNG_ERR_CRC, "bit-flipped IEND CRC → PNG_ERR_CRC");

    # ---- M2(c) — truncated post-IHDR chunk -------------------------
    # Truncate the file 4 bytes before the end (cuts off the IEND
    # CRC). Walker reads IEND header ok (length=0, type=IEND), then
    # tries to read 4 CRC bytes, gets 0 → PNG_ERR_CHUNK.
    test_group("M2(c) — png_decode_structure (truncated mid-chunk)");
    var pbuf_trunc[80];
    _ut_build_min_png(&pbuf_trunc, 4, 2, 8, 2);
    file_write_all("/tmp/kii-test-trunc-mid.png", &pbuf_trunc, 41);  # 45 - 4 = no IEND CRC
    var pstr_trunc[64];
    assert_eq(png_decode_structure("/tmp/kii-test-trunc-mid.png", &pstr_trunc),
              PNG_ERR_CHUNK, "truncated mid-IEND-CRC → PNG_ERR_CHUNK");

    # ---- M3(a) — sankoch zlib round-trip ---------------------------
    # First sub-bite of M3 — confirms the sankoch stdlib dep wires
    # up cleanly and that the exact API surface kii will consume at
    # M3(c) (zlib_compress + zlib_decompress) round-trips byte-
    # identical. PNG IDAT uses the zlib wrapper (not raw DEFLATE)
    # per spec § 10.3, so we exercise zlib_* and not deflate_*.
    test_group("M3(a) — sankoch zlib round-trip");

    # Deterministic 16-byte input: ASCII 'A'..'P'.
    var rt_in[16];
    var rt_i = 0;
    while (rt_i < 16) {
        store8(&rt_in + rt_i, 0x41 + rt_i);
        rt_i = rt_i + 1;
    }

    # Compress. Zlib overhead for 16 bytes of non-repeating ASCII is
    # ~12 bytes of header/checksum/Huffman framing; 64-byte buf is
    # plenty.
    var rt_compressed[64];
    var rt_clen = zlib_compress(&rt_in, 16, &rt_compressed, 64);
    assert(rt_clen > 0,  "zlib_compress returns positive length");
    assert(rt_clen < 64, "compressed fits in 64-byte buffer");

    # Decompress back into a fresh buffer; should recover all 16 bytes.
    var rt_decompressed[32];
    var rt_dlen = zlib_decompress(&rt_compressed, rt_clen, &rt_decompressed, 32);
    assert_eq(rt_dlen, 16, "zlib_decompress recovers original length");

    # Byte-identical verification.
    var rt_match = 1;
    var rt_j = 0;
    while (rt_j < 16) {
        if (load8(&rt_in + rt_j) != load8(&rt_decompressed + rt_j)) { rt_match = 0; }
        rt_j = rt_j + 1;
    }
    assert_eq(rt_match, 1, "decompressed bytes byte-identical to input");

    # Buffer-too-small surfaces as negative.
    var rt_dec_small[8];
    var rt_dlen_neg = zlib_decompress(&rt_compressed, rt_clen, &rt_dec_small, 8);
    assert(rt_dlen_neg < 0, "dst_cap too small → negative return");

    # ---- M3(b) — interlace capture --------------------------------
    # Existing min PNGs build with interlace=0; the new
    # STRUCT_INTERLACE_OFFSET slot should reflect that.
    test_group("M3(b) — png_decode_structure captures interlace byte");
    var pbuf_ilace0[80];
    var len_il0 = _ut_build_min_png(&pbuf_ilace0, 4, 2, 8, 2);
    file_write_all("/tmp/kii-test-ilace0.png", &pbuf_ilace0, len_il0);
    var pstr_il0[80];
    assert_eq(png_decode_structure("/tmp/kii-test-ilace0.png", &pstr_il0), PNG_OK,
              "interlace=0 fixture parses");
    assert_eq(load64(&pstr_il0 + STRUCT_INTERLACE_OFFSET), 0, "interlace = 0 captured");

    # Adam7 fixture: build with interlace byte = 1. M3(c) will
    # reject this in main.cyr's dispatch; (b) just confirms the
    # capture path works.
    var pbuf_ilace1[80];
    var ilace1_len = _ut_build_png_with_idat(&pbuf_ilace1, 4, 2, 8, 2, 1, "\x00", 1);
    file_write_all("/tmp/kii-test-ilace1.png", &pbuf_ilace1, ilace1_len);
    var pstr_il1[80];
    assert_eq(png_decode_structure("/tmp/kii-test-ilace1.png", &pstr_il1), PNG_OK,
              "interlace=1 (Adam7) fixture parses at structural layer");
    assert_eq(load64(&pstr_il1 + STRUCT_INTERLACE_OFFSET), 1, "interlace = 1 captured");

    # ---- M3(b) — IDAT buffer accumulation -------------------------
    # Build a PNG with a single IDAT chunk holding a known 4-byte
    # payload. After png_decode_structure, idat_buf should point
    # to a copy of those exact bytes; idat_total_size == 4.
    test_group("M3(b) — png_decode_structure accumulates IDAT bytes");
    var pbuf_idat[80];
    var idat_payload = "\x78\x9c\x03\x00";   # zlib empty-stream bytes; arbitrary 4 bytes work
    var pbuf_idat_len = _ut_build_png_with_idat(&pbuf_idat, 4, 2, 8, 2, 0,
                                                  idat_payload, 4);
    file_write_all("/tmp/kii-test-idat.png", &pbuf_idat, pbuf_idat_len);
    var pstr_idat[80];
    assert_eq(png_decode_structure("/tmp/kii-test-idat.png", &pstr_idat), PNG_OK,
              "PNG-with-IDAT fixture → PNG_OK");
    assert_eq(load64(&pstr_idat + STRUCT_IDAT_COUNT_OFFSET),      1, "1 IDAT chunk");
    assert_eq(load64(&pstr_idat + STRUCT_IDAT_TOTAL_SIZE_OFFSET), 4, "IDAT total = 4 bytes");
    var idat_buf_ptr = load64(&pstr_idat + STRUCT_IDAT_BUF_OFFSET);
    assert(idat_buf_ptr != 0, "idat_buf is non-null when IDATs present");
    # Byte-for-byte verify the copy.
    assert_eq(load8(idat_buf_ptr + 0), 0x78, "idat_buf[0] = 0x78");
    assert_eq(load8(idat_buf_ptr + 1), 0x9c, "idat_buf[1] = 0x9c");
    assert_eq(load8(idat_buf_ptr + 2), 0x03, "idat_buf[2] = 0x03");
    assert_eq(load8(idat_buf_ptr + 3), 0x00, "idat_buf[3] = 0x00");

    # No-IDAT case: idat_buf stays 0 (no alloc).
    test_group("M3(b) — no-IDAT case leaves idat_buf null");
    var pbuf_noidat[80];
    _ut_build_min_png(&pbuf_noidat, 4, 2, 8, 2);
    file_write_all("/tmp/kii-test-noidat.png", &pbuf_noidat, 45);
    var pstr_noidat[80];
    png_decode_structure("/tmp/kii-test-noidat.png", &pstr_noidat);
    assert_eq(load64(&pstr_noidat + STRUCT_IDAT_COUNT_OFFSET), 0, "0 IDATs");
    assert_eq(load64(&pstr_noidat + STRUCT_IDAT_BUF_OFFSET),   0, "idat_buf = 0 when no IDATs");

    # ---- M3(c) — _png_paeth predictor (spec § 9.4) -----------------
    # Lock the tie-breaking + sign behavior. The Paeth predictor
    # is the only filter type where naïve sign-extension or
    # tie-break-order errors silently corrupt pixels; pin the
    # canonical cases.
    test_group("M3(c) — _png_paeth predictor");
    # All-zero context → returns a (= 0). Tie pa=pb=pc=0; pa <= pb and pa <= pc.
    assert_eq(_png_paeth(0, 0, 0), 0, "paeth(0,0,0) → a (tie-break order)");
    # a closest: a=255, b=0, c=0. p=255+0-0=255, pa=|255-255|=0, pb=255, pc=255 → a.
    assert_eq(_png_paeth(255, 0, 0), 255, "paeth(255,0,0) → a (pa=0 wins)");
    # b closest: a=0, b=255, c=0. p=255, pa=255, pb=0, pc=255 → b.
    assert_eq(_png_paeth(0, 255, 0), 255, "paeth(0,255,0) → b");
    # c closest by elimination: a=0, b=0, c=255. p=-255, pa=255, pb=255, pc=510. pb<=pc → b.
    # Wait pb=255 pc=510 so pb wins → b=0. That's the spec's left/up-priority.
    assert_eq(_png_paeth(0, 0, 255), 0, "paeth(0,0,255) → b (up beats up-left on tie)");
    # Real-world middle case: a=10, b=15, c=5. p=20, pa=10, pb=5, pc=15 → b.
    assert_eq(_png_paeth(10, 15, 5), 15, "paeth(10,15,5) → b (closest predictor)");

    # ---- M3(c) — _png_unfilter_row per filter type -----------------
    # Each test crafts a known raw row + pre-filter-encoded row,
    # runs the undo, asserts byte-identical recovery. bpp=1
    # (greyscale-equiv) keeps the math simple; the algorithm is
    # bpp-agnostic so this proves correctness for all bpps.
    test_group("M3(c) — _png_unfilter_row filter 0 (None)");
    # raw = encoded for filter type None. Any pattern works.
    var raw0[4];      store8(&raw0 + 0, 10);   store8(&raw0 + 1, 20);
                      store8(&raw0 + 2, 30);   store8(&raw0 + 3, 40);
    var enc0[4];      memcpy(&enc0, &raw0, 4);
    var prev0[4];     store8(&prev0 + 0, 0);   store8(&prev0 + 1, 0);
                      store8(&prev0 + 2, 0);   store8(&prev0 + 3, 0);
    var out0[4];
    assert_eq(_png_unfilter_row(&prev0, &enc0, &out0, 4, 1, 0), 0, "filter 0 returns 0");
    var k = 0; var ok0 = 1;
    while (k < 4) { if (load8(&out0 + k) != load8(&raw0 + k)) { ok0 = 0; } k = k + 1; }
    assert_eq(ok0, 1, "filter 0 (None) round-trips byte-identical");

    test_group("M3(c) — _png_unfilter_row filter 1 (Sub)");
    # raw = [10,20,30,40], bpp=1, prev=[0,0,0,0]:
    # encoded[i] = raw[i] - (i==0 ? 0 : raw[i-1]) = [10, 10, 10, 10]
    var enc1[4]; store8(&enc1 + 0, 10); store8(&enc1 + 1, 10);
                 store8(&enc1 + 2, 10); store8(&enc1 + 3, 10);
    var out1[4];
    assert_eq(_png_unfilter_row(&prev0, &enc1, &out1, 4, 1, 1), 0, "filter 1 returns 0");
    assert_eq(load8(&out1 + 0), 10, "Sub: pixel 0 = 10");
    assert_eq(load8(&out1 + 1), 20, "Sub: pixel 1 = 20");
    assert_eq(load8(&out1 + 2), 30, "Sub: pixel 2 = 30");
    assert_eq(load8(&out1 + 3), 40, "Sub: pixel 3 = 40");

    test_group("M3(c) — _png_unfilter_row filter 2 (Up)");
    # raw = [10,20,30,40], prev = [5,15,25,35]:
    # encoded[i] = raw[i] - prev[i] = [5, 5, 5, 5]
    var prev2[4]; store8(&prev2 + 0, 5);  store8(&prev2 + 1, 15);
                  store8(&prev2 + 2, 25); store8(&prev2 + 3, 35);
    var enc2[4];  store8(&enc2 + 0, 5);   store8(&enc2 + 1, 5);
                  store8(&enc2 + 2, 5);   store8(&enc2 + 3, 5);
    var out2[4];
    assert_eq(_png_unfilter_row(&prev2, &enc2, &out2, 4, 1, 2), 0, "filter 2 returns 0");
    assert_eq(load8(&out2 + 0), 10, "Up: pixel 0 = 10");
    assert_eq(load8(&out2 + 1), 20, "Up: pixel 1 = 20");
    assert_eq(load8(&out2 + 2), 30, "Up: pixel 2 = 30");
    assert_eq(load8(&out2 + 3), 40, "Up: pixel 3 = 40");

    test_group("M3(c) — _png_unfilter_row filter 3 (Average)");
    # raw = [10,20,30,40], prev = [5,15,25,35], bpp=1:
    # encoded[i] = raw[i] - floor((left + up) / 2)
    #   i=0: left=0,  up=5  → avg=2,  e[0]=10-2=8
    #   i=1: left=10, up=15 → avg=12, e[1]=20-12=8
    #   i=2: left=20, up=25 → avg=22, e[2]=30-22=8
    #   i=3: left=30, up=35 → avg=32, e[3]=40-32=8
    var enc3[4]; store8(&enc3 + 0, 8); store8(&enc3 + 1, 8);
                 store8(&enc3 + 2, 8); store8(&enc3 + 3, 8);
    var out3[4];
    assert_eq(_png_unfilter_row(&prev2, &enc3, &out3, 4, 1, 3), 0, "filter 3 returns 0");
    assert_eq(load8(&out3 + 0), 10, "Average: pixel 0 = 10");
    assert_eq(load8(&out3 + 1), 20, "Average: pixel 1 = 20");
    assert_eq(load8(&out3 + 2), 30, "Average: pixel 2 = 30");
    assert_eq(load8(&out3 + 3), 40, "Average: pixel 3 = 40");

    test_group("M3(c) — _png_unfilter_row filter 4 (Paeth)");
    # raw = [10,20,30,40], prev = [5,15,25,35], bpp=1:
    # paeth predictor + delta = encoded
    #   i=0: a=0,  b=5,  c=0  → paeth=b=5,  e[0]=10-5=5
    #   i=1: a=10, b=15, c=5  → paeth=b=15, e[1]=20-15=5
    #   i=2: a=20, b=25, c=15 → paeth=b=25, e[2]=30-25=5
    #   i=3: a=30, b=35, c=25 → paeth=b=35, e[3]=40-35=5
    var enc4[4]; store8(&enc4 + 0, 5); store8(&enc4 + 1, 5);
                 store8(&enc4 + 2, 5); store8(&enc4 + 3, 5);
    var out4[4];
    assert_eq(_png_unfilter_row(&prev2, &enc4, &out4, 4, 1, 4), 0, "filter 4 returns 0");
    assert_eq(load8(&out4 + 0), 10, "Paeth: pixel 0 = 10");
    assert_eq(load8(&out4 + 1), 20, "Paeth: pixel 1 = 20");
    assert_eq(load8(&out4 + 2), 30, "Paeth: pixel 2 = 30");
    assert_eq(load8(&out4 + 3), 40, "Paeth: pixel 3 = 40");

    # Invalid filter byte: rejected.
    test_group("M3(c) — _png_unfilter_row rejects unknown filter byte");
    var out_bad[4];
    assert_eq(_png_unfilter_row(&prev0, &enc0, &out_bad, 4, 1, 5),
              0 - 1, "filter byte 5 → -1");
    assert_eq(_png_unfilter_row(&prev0, &enc0, &out_bad, 4, 1, 0 - 1),
              0 - 1, "filter byte -1 → -1");

    # ---- M3(c) — _png_color_channels --------------------------------
    test_group("M3(c) — _png_color_channels");
    assert_eq(_png_color_channels(0), 1, "greyscale → 1 channel");
    assert_eq(_png_color_channels(2), 3, "RGB → 3 channels");
    assert_eq(_png_color_channels(3), 1, "palette → 1 channel (index)");
    assert_eq(_png_color_channels(4), 2, "grey+alpha → 2 channels");
    assert_eq(_png_color_channels(6), 4, "RGBA → 4 channels");
    assert_eq(_png_color_channels(1), 0 - 1, "color_type 1 (unused/invalid) → -1");
    assert_eq(_png_color_channels(5), 0 - 1, "color_type 5 (unused) → -1");
    assert_eq(_png_color_channels(7), 0 - 1, "color_type 7 (unused) → -1");

    # ---- M3(c) — png_decode_pixels end-to-end (2x2 RGB) -------------
    # Build a 2x2 RGB image with known pixel values, filter byte 0
    # (None) on each row, zlib-compress the row stream, embed in a
    # PNG, run the full structure→pixels pipeline, verify the
    # decoded buffer byte-for-byte.
    test_group("M3(c) — png_decode_pixels end-to-end (2x2 RGB, filter 0)");
    # Raw row stream: filter byte + 2 pixels × 3 bytes per row = 7 bytes/row × 2 rows = 14 bytes.
    var raw_stream[14];
    store8(&raw_stream + 0,  0);    # filter byte (None) for row 0
    store8(&raw_stream + 1,  100);  # pixel (0,0) R
    store8(&raw_stream + 2,  101);  # pixel (0,0) G
    store8(&raw_stream + 3,  102);  # pixel (0,0) B
    store8(&raw_stream + 4,  103);  # pixel (1,0) R
    store8(&raw_stream + 5,  104);  # pixel (1,0) G
    store8(&raw_stream + 6,  105);  # pixel (1,0) B
    store8(&raw_stream + 7,  0);    # filter byte (None) for row 1
    store8(&raw_stream + 8,  110);  # pixel (0,1) R
    store8(&raw_stream + 9,  111);  # pixel (0,1) G
    store8(&raw_stream + 10, 112);  # pixel (0,1) B
    store8(&raw_stream + 11, 113);  # pixel (1,1) R
    store8(&raw_stream + 12, 114);  # pixel (1,1) G
    store8(&raw_stream + 13, 115);  # pixel (1,1) B
    # zlib_compress the row stream into the IDAT payload.
    var idat_payload_e2e[64];
    var idat_clen = zlib_compress(&raw_stream, 14, &idat_payload_e2e, 64);
    assert(idat_clen > 0, "row-stream compresses cleanly");
    # Build the full PNG fixture.
    var pbuf_e2e[128];
    var fixture_len = _ut_build_png_with_idat(&pbuf_e2e, 2, 2, 8, 2, 0,
                                                &idat_payload_e2e, idat_clen);
    file_write_all("/tmp/kii-test-decode-2x2.png", &pbuf_e2e, fixture_len);
    # Run the pipeline.
    var pstr_e2e[96];
    assert_eq(png_decode_structure("/tmp/kii-test-decode-2x2.png", &pstr_e2e),
              PNG_OK, "2x2 RGB fixture → PNG_OK on structure");
    assert_eq(png_decode_pixels(&pstr_e2e), PNG_OK, "2x2 RGB fixture → PNG_OK on pixels");
    assert_eq(load64(&pstr_e2e + STRUCT_PIXELS_SIZE_OFFSET), 12,
              "pixel size = 2 × 2 × 3 = 12 bytes");
    var pix_ptr = load64(&pstr_e2e + STRUCT_PIXELS_BUF_OFFSET);
    assert(pix_ptr != 0, "pixels_buf non-null on success");
    # Byte-for-byte: 12 bytes of RGB sequence, no filter bytes.
    assert_eq(load8(pix_ptr + 0),  100, "decoded pixel 0 R = 100");
    assert_eq(load8(pix_ptr + 1),  101, "decoded pixel 0 G = 101");
    assert_eq(load8(pix_ptr + 2),  102, "decoded pixel 0 B = 102");
    assert_eq(load8(pix_ptr + 3),  103, "decoded pixel 1 R = 103");
    assert_eq(load8(pix_ptr + 11), 115, "decoded pixel 3 B = 115");

    # ---- M3(c) — rejection paths ------------------------------------
    test_group("M3(c) — png_decode_pixels rejects Adam7 + sub-byte depth");
    # Adam7: interlace=1, same compressed IDAT payload (won't be
    # touched because we reject before inflate).
    var pbuf_adam7[128];
    var adam7_len = _ut_build_png_with_idat(&pbuf_adam7, 2, 2, 8, 2, 1,
                                              &idat_payload_e2e, idat_clen);
    file_write_all("/tmp/kii-test-adam7.png", &pbuf_adam7, adam7_len);
    var pstr_adam7[96];
    png_decode_structure("/tmp/kii-test-adam7.png", &pstr_adam7);
    assert_eq(png_decode_pixels(&pstr_adam7), PNG_ERR_INTERLACE,
              "interlace=1 → PNG_ERR_INTERLACE (no inflate attempted)");

    # Sub-byte bit depth (4): the IDAT payload is meaningless but
    # we reject at the M3 layer before reaching inflate.
    var pbuf_d4[128];
    var d4_len = _ut_build_png_with_idat(&pbuf_d4, 2, 2, 4, 0, 0,
                                           &idat_payload_e2e, idat_clen);
    file_write_all("/tmp/kii-test-d4.png", &pbuf_d4, d4_len);
    var pstr_d4[96];
    png_decode_structure("/tmp/kii-test-d4.png", &pstr_d4);
    assert_eq(png_decode_pixels(&pstr_d4), PNG_ERR_BITDEPTH,
              "bit_depth=4 → PNG_ERR_BITDEPTH (tier-1 scope rejects sub-byte)");

    # No-IDAT case: png_decode_pixels has nothing to inflate.
    var pstr_nopx[96];
    _ut_build_min_png(&pbuf_noidat, 4, 2, 8, 2);
    file_write_all("/tmp/kii-test-noidat-px.png", &pbuf_noidat, 45);
    png_decode_structure("/tmp/kii-test-noidat-px.png", &pstr_nopx);
    assert_eq(png_decode_pixels(&pstr_nopx), PNG_ERR_NO_IDAT,
              "no IDAT chunks → PNG_ERR_NO_IDAT");

    # ---- M3(c) — real-world: RAMGON.png (1152×925 RGBA) -------------
    # End-to-end against an actual PNG (committed at top level for
    # this purpose). Asserts that the full pipeline — sankoch
    # inflate + filter undo across whatever filter types the PNG
    # uses — produces a pixel buffer of the spec-derived size.
    test_group("M3(c) — png_decode_pixels real-world (RAMGON.png)");
    var pstr_real[96];
    assert_eq(png_decode_structure("RAMGON.png", &pstr_real), PNG_OK,
              "RAMGON.png → PNG_OK on structure");
    assert_eq(load64(&pstr_real + STRUCT_WIDTH_OFFSET),      1152, "RAMGON width = 1152");
    assert_eq(load64(&pstr_real + STRUCT_HEIGHT_OFFSET),     925,  "RAMGON height = 925");
    assert_eq(load64(&pstr_real + STRUCT_COLOR_TYPE_OFFSET), 6,    "RAMGON color_type = 6 (RGBA)");
    assert_eq(png_decode_pixels(&pstr_real), PNG_OK,
              "RAMGON.png → PNG_OK on pixels");
    # Expected size = 1152 × 925 × 4 bytes/pixel = 4,262,400.
    assert_eq(load64(&pstr_real + STRUCT_PIXELS_SIZE_OFFSET), 4262400,
              "RAMGON decoded size = 1152 × 925 × 4 = 4,262,400");

    # ---- M4(a) — 16-color ANSI palette ----------------------------
    # Canonical Linux-console table. Each entry's RGB triple is
    # pinned here so any drift (typo in palette_init, off-by-one
    # in indexing) regresses against the well-known constants.
    # Source values: https://en.wikipedia.org/wiki/ANSI_escape_code#3-bit_and_4-bit
    test_group("M4(a) — palette size + lazy init");
    assert_eq(ANSI_PALETTE_SIZE, 16, "16-color palette");
    # Lazy-init: read a color before any explicit palette_init().
    # palette_r/g/b should still return the correct values.
    assert_eq(palette_r(0), 0, "entry 0 (black) R = 0 (lazy-init works)");

    test_group("M4(a) — palette entries 0–7 (normal)");
    # 0: black (0, 0, 0)
    assert_eq(palette_r(0), 0);   assert_eq(palette_g(0), 0);   assert_eq(palette_b(0), 0);
    # 1: red (170, 0, 0)
    assert_eq(palette_r(1), 170); assert_eq(palette_g(1), 0);   assert_eq(palette_b(1), 0);
    # 2: green (0, 170, 0)
    assert_eq(palette_r(2), 0);   assert_eq(palette_g(2), 170); assert_eq(palette_b(2), 0);
    # 3: yellow/brown (170, 85, 0)
    assert_eq(palette_r(3), 170); assert_eq(palette_g(3), 85);  assert_eq(palette_b(3), 0);
    # 4: blue (0, 0, 170)
    assert_eq(palette_r(4), 0);   assert_eq(palette_g(4), 0);   assert_eq(palette_b(4), 170);
    # 5: magenta (170, 0, 170)
    assert_eq(palette_r(5), 170); assert_eq(palette_g(5), 0);   assert_eq(palette_b(5), 170);
    # 6: cyan (0, 170, 170)
    assert_eq(palette_r(6), 0);   assert_eq(palette_g(6), 170); assert_eq(palette_b(6), 170);
    # 7: white / light gray (170, 170, 170)
    assert_eq(palette_r(7), 170); assert_eq(palette_g(7), 170); assert_eq(palette_b(7), 170);

    test_group("M4(a) — palette entries 8–15 (bright)");
    # 8: bright black / dark gray (85, 85, 85)
    assert_eq(palette_r(8),  85);  assert_eq(palette_g(8),  85);  assert_eq(palette_b(8),  85);
    # 9: bright red (255, 85, 85)
    assert_eq(palette_r(9),  255); assert_eq(palette_g(9),  85);  assert_eq(palette_b(9),  85);
    # 10: bright green (85, 255, 85)
    assert_eq(palette_r(10), 85);  assert_eq(palette_g(10), 255); assert_eq(palette_b(10), 85);
    # 11: bright yellow (255, 255, 85)
    assert_eq(palette_r(11), 255); assert_eq(palette_g(11), 255); assert_eq(palette_b(11), 85);
    # 12: bright blue (85, 85, 255)
    assert_eq(palette_r(12), 85);  assert_eq(palette_g(12), 85);  assert_eq(palette_b(12), 255);
    # 13: bright magenta (255, 85, 255)
    assert_eq(palette_r(13), 255); assert_eq(palette_g(13), 85);  assert_eq(palette_b(13), 255);
    # 14: bright cyan (85, 255, 255)
    assert_eq(palette_r(14), 85);  assert_eq(palette_g(14), 255); assert_eq(palette_b(14), 255);
    # 15: bright white (255, 255, 255)
    assert_eq(palette_r(15), 255); assert_eq(palette_g(15), 255); assert_eq(palette_b(15), 255);

    test_group("M4(a) — palette bounds (every byte ≤ 255)");
    # Defensive — guard against accidentally writing > 0xFF
    # (Cyrius store8 truncates, but a typo like 1700 would still
    # be wrong even after truncation).
    var i = 0;
    var all_bounded = 1;
    while (i < 16) {
        if (palette_r(i) < 0 || palette_r(i) > 255) { all_bounded = 0; }
        if (palette_g(i) < 0 || palette_g(i) > 255) { all_bounded = 0; }
        if (palette_b(i) < 0 || palette_b(i) > 255) { all_bounded = 0; }
        i = i + 1;
    }
    assert_eq(all_bounded, 1, "every palette byte ∈ [0, 255]");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
